---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://calculatieloket.nl/" },
    { "@type": "ListItem", position: 2, name: "Cookiebeleid", item: "https://calculatieloket.nl/cookies/" },
  ],
};
---

<BaseLayout
  title="Cookiebeleid - Calculatieloket.nl"
  description="Cookiebeleid van Calculatieloket.nl: uitleg over welke cookies we gebruiken en hoe je toestemming beheert."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Cookiebeleid", current: true },
    ]}
    analyticsCategory="site-page"
  />

  <h1 class="page-title">Cookiebeleid</h1>
  <p class="page-subtitle">Laatst bijgewerkt: 12 juni 2026</p>

  <div class="calculator-card">
    <h2>Wat zijn cookies?</h2>
    <p>Cookies zijn kleine tekstbestandjes die door een website op je apparaat worden geplaatst. Ze helpen de site goed te functioneren en kunnen gebruikt worden voor analyses of advertenties.</p>

    <h2>Welke cookies gebruiken we?</h2>

    <h3>Noodzakelijke cookie</h3>
    <p>We plaatsen een noodzakelijke cookie die onthoudt welke keuze je in de cookiebanner hebt gemaakt. Deze cookie bevat geen persoonlijke gegevens.</p>

    <h3>Advertentiecookies (toekomstig)</h3>
    <p>In de toekomst kunnen we Google AdSense gebruiken om advertenties te tonen. Zodra advertenties actief worden, vragen we toestemming voor advertentiecookies via de cookiebanner.</p>

    <h2>Hoe beheer je cookies?</h2>
    <p>Je kunt je cookievoorkeur op elk moment wijzigen door je browserinstellingen aan te passen of de cookies te wissen. Via je browser kun je ook alle cookies verwijderen.</p>
  </div>
</BaseLayout>
