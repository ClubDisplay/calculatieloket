---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdSlot from "../components/AdSlot.astro";
import CrossSellCards from "../components/CrossSellCards.astro";
import RelatedCategories from "../components/category/RelatedCategories.astro";
import { categoryList } from "../lib/category-icons";

const title = "Calculatieloket.nl | Gratis calculators voor salaris, toeslagen, hypotheek, btw, zzp en meer";
const description = "Snel inzicht in salaris, toeslagen, hypotheek, btw, zzp en auto importkosten. Gratis calculators, geen account, gebaseerd op officiële bronnen.";

const categoryLinks = [
  { id: "Inkomen", label: "Inkomen", href: "/categorie/inkomen/" },
  { id: "Wonen", label: "Wonen", href: "/categorie/wonen/" },
  { id: "Ondernemen", label: "Ondernemen", href: "/categorie/ondernemen/" },
  { id: "Belasting", label: "Belasting", href: "/categorie/belasting/" },
  { id: "Auto", label: "Auto", href: "/categorie/auto/" },
];

const icons: Record<string, string> = {
  euro: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="11" stroke="currentColor" stroke-width="2"/><text x="14" y="19" text-anchor="middle" font-size="14" font-weight="700" fill="currentColor">€</text></svg>`,
  money: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="7" width="20" height="14" rx="3" stroke="currentColor" stroke-width="2"/><circle cx="14" cy="14" r="3" stroke="currentColor" stroke-width="2"/><path d="M8 11h2M18 17h2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  sun: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="5" stroke="currentColor" stroke-width="2"/><path d="M14 4V2M14 26V24M4 14H2M26 14H24M6.343 6.343 4.929 4.929M23.071 23.071l-1.414-1.414M6.343 21.657 4.929 23.071M23.071 4.929l-1.414 1.414" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  house: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M3 12L14 4L25 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><rect x="8" y="13" width="12" height="11" rx="1" stroke="currentColor" stroke-width="2"/><rect x="12" y="18" width="4" height="6" rx="1" stroke="currentColor" stroke-width="2"/></svg>`,
  calc: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="2" y="3" width="24" height="22" rx="3" stroke="currentColor" stroke-width="2"/><line x1="9" y1="10" x2="19" y2="10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="9" y1="15" x2="19" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="9" y1="20" x2="14" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  percent: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="2"/><circle cx="18" cy="18" r="3" stroke="currentColor" stroke-width="2"/><path d="M8 20 20 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  switch: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="6" width="20" height="16" rx="3" stroke="currentColor" stroke-width="2"/><path d="M9 14h10M9 14l-3-3M9 14l-3 3M19 14l3-3M19 14l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  person: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 22c0-4 2.5-6 6-6s6 2 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><rect x="18" y="9" width="8" height="12" rx="2" stroke="currentColor" stroke-width="2"/><line x1="20" y1="13" x2="24" y2="13" stroke="currentColor" stroke-width="1.5"/><line x1="20" y1="17" x2="24" y2="17" stroke="currentColor" stroke-width="1.5"/></svg>`,
  car: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 17l1.8-5.2A2 2 0 0 1 7.7 10.4h12.6a2 2 0 0 1 1.9 1.4L24 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="17" width="22" height="4" rx="1.5" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="21.5" r="2" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="19" cy="21.5" r="2" fill="none" stroke="currentColor" stroke-width="2"/></svg>`,
};


const cards = [
  {
    id: "bruto-netto",
    title: "Bruto netto 2026",
    href: "/bruto-netto-2026/",
    clusters: ["Inkomen", "Populair"],
    badge: "Populair",
    icon: icons.euro,
    accent: "#2563eb",
    question: "Wat houd ik netto over in 2026?",
    promise: "Gebaseerd op actuele Box 1 tarieven en heffingskortingen.",
    keywords: "bruto netto salaris inkomen loon 2026",
  },
  {
    id: "salaris",
    title: "Salaris calculator",
    href: "/salaris-calculator/",
    clusters: ["Inkomen"],
    badge: null,
    icon: icons.euro,
    accent: "#2563eb",
    question: "Hoeveel is mijn bruto salaris netto?",
    promise: "Vergelijk verschillende bruto bedragen met pensioen.",
    keywords: "salaris bruto netto loon inkomen",
  },
  {
    id: "vakantiegeld",
    title: "Vakantiegeld calculator",
    href: "/vakantiegeld-calculator/",
    clusters: ["Inkomen", "Populair"],
    badge: "Nieuw",
    icon: icons.sun,
    accent: "#0891b2",
    question: "Hoeveel vakantiegeld krijg ik netto?",
    promise: "Bereken 8% of een afwijkend percentage na inhoudingen.",
    keywords: "vakantiegeld netto bruto 8% vakantie geld",
  },
  {
    id: "toeslagen",
    title: "Toeslagen calculator",
    href: "/toeslagen-calculator/",
    clusters: ["Inkomen", "Populair"],
    badge: "Populair",
    icon: icons.money,
    accent: "#059669",
    question: "Heb ik recht op huur- of zorgtoeslag?",
    promise: "Indicatie op basis van inkomen, huur en huishouden.",
    keywords: "toeslagen huur zorg inkomen",
  },
  {
    id: "hypotheek",
    title: "Hypotheek calculator",
    href: "/hypotheek-calculator/",
    clusters: ["Wonen", "Populair"],
    badge: "Populair",
    icon: icons.house,
    accent: "#d97706",
    question: "Wat kan ik maximaal lenen?",
    promise: "Bereken maandlasten en totale rentekosten.",
    keywords: "hypotheek wonen lenen maandlasten",
  },
  {
    id: "btw",
    title: "BTW calculator",
    href: "/btw-calculator/",
    clusters: ["Belasting", "Populair"],
    badge: "Populair",
    icon: icons.calc,
    accent: "#2563eb",
    question: "Hoeveel btw moet ik berekenen?",
    promise: "21%, 9% of 0% tarief, exclusief ↔ inclusief.",
    keywords: "btw belasting 21% 9% berekenen",
  },
  {
    id: "btw-terugrekenen",
    title: "BTW terugrekenen",
    href: "/btw-terugrekenen/",
    clusters: ["Belasting"],
    badge: null,
    icon: icons.percent,
    accent: "#2563eb",
    question: "Wat is het bedrag exclusief btw?",
    promise: "Reken snel van inclusief naar exclusief.",
    keywords: "btw terugrekenen inclusief exclusief",
  },
  {
    id: "btw-inclusief-exclusief",
    title: "BTW inclusief/exclusief",
    href: "/btw-inclusief-exclusief/",
    clusters: ["Belasting"],
    badge: null,
    icon: icons.switch,
    accent: "#2563eb",
    question: "Omrekenen inclusief en exclusief btw?",
    promise: "Beide richtingen en alle gangbare tarieven.",
    keywords: "btw inclusief exclusief omrekenen",
  },
  {
    id: "zzp",
    title: "ZZP calculator",
    href: "/zzp-calculator/",
    clusters: ["Ondernemen", "Populair"],
    badge: "Voor ondernemers",
    icon: icons.person,
    accent: "#7c3aed",
    question: "Wat moet ik als zzp'er vragen?",
    promise: "Van gewenst netto inkomen naar uurtarief.",
    keywords: "zzp uurtarief ondernemer freelancer",
  },
  {
    id: "auto-importkosten",
    title: "Auto importkosten berekenen",
    href: "/auto-importkosten-berekenen/",
    clusters: ["Auto", "Ondernemen"],
    badge: "Nieuw",
    icon: icons.car,
    accent: "#0891b2",
    question: "Wat kost een auto importeren?",
    promise: "Inclusief bpm, RDW, transport en keuring.",
    keywords: "auto importkosten importeren bpm rdw",
  },
];

const incomeCards = cards.filter((c) => c.clusters.includes("Inkomen")).slice(0, 5);
const entrepreneurCards = cards.filter((c) => c.id === "btw" || c.id === "btw-terugrekenen" || c.id === "zzp" || c.id === "auto-importkosten");

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Calculatieloket.nl",
  "url": "https://calculatieloket.nl/",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://calculatieloket.nl/?q={search_term_string}",
    "query-input": "required name=search_term_string",
  },
};
---

<BaseLayout title={title} description={description} containerClass="container-wide">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(websiteSchema)} />

  <!-- ===== HERO ===== -->
  <section class="hero-home">
    <div class="hero-grid">
      <div class="hero-left">
        <h1 class="hero-home-title">Wat wil je berekenen?</h1>
        <p class="hero-home-sub">Snel inzicht in salaris, toeslagen, hypotheek, btw, zzp en meer. Gratis, zonder account en gebaseerd op officiële bronnen.</p>

        <div class="hp-search-wrap">
          <label for="hpSearch" class="visually-hidden">Zoek een calculator</label>
          <input type="text" id="hpSearch" class="hp-search" placeholder="Bijvoorbeeld: salaris, btw, hypotheek..." autocomplete="off" data-analytics="search-input" data-analytics-category="homepage" data-analytics-action="input" data-analytics-label="search" />
          <span class="hp-search-icon" aria-hidden="true">🔍</span>
        </div>

        <div class="hp-cluster-row" aria-label="Categorieën">
          {categoryLinks.map((cat) => (
            <a
              href={cat.href}
              class="hp-cluster-chip"
              data-analytics="category-chip"
              data-analytics-category="homepage"
              data-analytics-action="click"
              data-analytics-label={cat.id}
            >
              {cat.label}
            </a>
          ))}
        </div>
        <p class="hp-categories-link">
          <a href="#categorieen" data-analytics="category-overview-link" data-analytics-category="homepage" data-analytics-action="click" data-analytics-label="categorieen">Bekijk alle categorieën</a>
        </p>

        <div class="hero-trust">
          <div class="hero-trust-item">
            <svg class="hti-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#059669" stroke-width="2"/><path d="M5 8l2 2 4-4" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="trust-full">Gratis</span>
            <span class="trust-short">Gratis</span>
          </div>
          <div class="hero-trust-item">
            <svg class="hti-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#059669" stroke-width="2"/><path d="M5 8l2 2 4-4" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="trust-full">Geen account</span>
            <span class="trust-short">Geen account</span>
          </div>
          <div class="hero-trust-item">
            <svg class="hti-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#059669" stroke-width="2"/><path d="M5 8l2 2 4-4" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="trust-full">Geen opslag van je invoer</span>
            <span class="trust-short">Geen opslag</span>
          </div>
          <div class="hero-trust-item">
            <svg class="hti-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#059669" stroke-width="2"/><path d="M5 8l2 2 4-4" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="trust-full">Uitkomst is een indicatie</span>
            <span class="trust-short">Indicatie</span>
          </div>
        </div>
      </div>
      <div class="hero-right" aria-hidden="true">
        <div class="hero-dashboard">
          <div class="hero-dash-card dash-btw">
            <span class="hd-label">€121 incl. BTW</span>
            <span class="hd-result">→ €100 excl.</span>
          </div>
          <div class="hero-dash-card dash-salar">
            <span class="hd-label">Bruto €3.500</span>
            <span class="hd-result">→ netto indicatie</span>
          </div>
          <div class="hero-dash-card dash-zzp">
            <span class="hd-label">ZZP uurtarief</span>
            <span class="hd-result">indicatie op maat</span>
          </div>
          <div class="hero-dash-card dash-toeslag">
            <span class="hd-label">Huursubsidie</span>
            <span class="hd-result">zorgtoeslag indicatie</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SNEL STARTEN ===== -->
  <section class="hp-quick-start" aria-labelledby="qsTitle">
    <div class="hp-qs-inner">
      <h2 id="qsTitle" class="hp-qs-title">Snel starten</h2>
      <p class="hp-qs-sub">Kies een calculator, vul één bedrag in en ga direct naar de tool.</p>

      <div class="hp-qs-choices" role="group" aria-label="Kies een calculator">
        <button type="button" class="hp-qs-choice active" data-target="bruto-netto" data-label="Bruto maandsalaris" data-placeholder="3500" data-href="/bruto-netto-2026/" data-param="bruto" data-analytics="quick-start-choice" data-analytics-category="quick-start" data-analytics-action="select" data-analytics-label="bruto-netto">
          Netto salaris
        </button>
        <button type="button" class="hp-qs-choice" data-target="toeslagen" data-label="Bruto jaarinkomen" data-placeholder="35000" data-href="/toeslagen-calculator/" data-param="inkomen" data-analytics="quick-start-choice" data-analytics-category="quick-start" data-analytics-action="select" data-analytics-label="toeslagen">
          Toeslagen
        </button>
        <button type="button" class="hp-qs-choice" data-target="hypotheek" data-label="Bruto jaarinkomen" data-placeholder="50000" data-href="/hypotheek-calculator/" data-param="inkomen" data-analytics="quick-start-choice" data-analytics-category="quick-start" data-analytics-action="select" data-analytics-label="hypotheek">
          Hypotheek
        </button>
        <button type="button" class="hp-qs-choice" data-target="btw" data-label="Bedrag exclusief btw" data-placeholder="100" data-href="/btw-calculator/" data-param="bedrag" data-extra="tarief=21&richting=excl" data-analytics="quick-start-choice" data-analytics-category="quick-start" data-analytics-action="select" data-analytics-label="btw">
          BTW
        </button>
        <button type="button" class="hp-qs-choice" data-target="zzp" data-label="Gewenst netto inkomen per maand" data-placeholder="3500" data-href="/zzp-calculator/" data-param="netto" data-analytics="quick-start-choice" data-analytics-category="quick-start" data-analytics-action="select" data-analytics-label="zzp">
          ZZP uurtarief
        </button>
      </div>

      <div class="hp-qs-field">
        <label for="hpQsInput" class="hp-qs-label" id="hpQsLabel">Bruto maandsalaris</label>
        <div class="hp-qs-input-wrap">
          <span class="hp-qs-prefix" aria-hidden="true">&euro;</span>
          <input type="number" id="hpQsInput" class="hp-qs-input" placeholder="3500" min="0" step="1" />
        </div>
      </div>

      <button type="button" id="hpQsCta" class="btn btn-primary btn-lg hp-qs-cta" data-analytics="quick-start-cta" data-analytics-category="quick-start" data-analytics-action="click" data-analytics-label="start-berekening">Start berekening</button>
    </div>
  </section>

  <!-- ===== CALCULATOR GRID ===== -->
  <section id="calculators" class="hp-section">
    <div class="hp-section-header">
      <h2 class="section-heading">Alle calculators</h2>
      <p class="section-sub">Kies het onderwerp dat bij jou past.</p>
    </div>

    <div class="hp-grid" id="hpGrid">
      {cards.map((card) => (
        <a
          href={card.href}
          class="hp-card"
          data-clusters={card.clusters.join(",")}
          data-title={card.title.toLowerCase()}
          data-keywords={card.keywords.toLowerCase()}
          style={`--hp-accent: ${card.accent}`}
          data-analytics="calculator-card"
          data-analytics-category="homepage"
          data-analytics-action="click"
          data-analytics-label={card.id}
        >
          <span class="hp-card-icon" set:html={card.icon} />
          <div class="hp-card-body">
            <h3 class="hp-card-title">
              {card.title}
              {card.badge && <span class="hp-card-badge">{card.badge}</span>}
            </h3>
            <p class="hp-card-question">{card.question}</p>
            <p class="hp-card-promise">{card.promise}</p>
            <span class="hp-card-cta">Bereken direct</span>
          </div>
          <span class="hp-card-arrow" aria-hidden="true">&rarr;</span>
        </a>
      ))}
    </div>
    <p class="hp-no-results" id="hpNoResults" aria-live="polite" aria-atomic="true" style="display:none;">Geen calculator gevonden. Probeer een andere zoekterm of filter.</p>
  </section>

  <section id="categorieen" class="hp-section" aria-labelledby="catSectionTitle">
    <div class="hp-section-header">
      <h2 id="catSectionTitle" class="section-heading">Categorieën</h2>
      <p class="section-sub">Kies een onderwerp en ontdek alle relevante calculators.</p>
    </div>
    <RelatedCategories title="Categorieën" analyticsCategory="homepage" categories={categoryList} />
  </section>

  <AdSlot slot="1234567893" format="auto" style="min-height:120px" />

  <!-- ===== BEGIN MET JE INKOMEN ===== -->
  <CrossSellCards
    title="Begin met je inkomen"
    analyticsCategory="homepage"
    items={incomeCards.map((card) => ({
      href: card.href,
      title: card.title,
      description: card.question,
      accent: card.accent,
    }))}
  />

  <!-- ===== VOOR ONDERNEMERS ===== -->
  <CrossSellCards
    title="Voor ondernemers"
    analyticsCategory="homepage"
    items={entrepreneurCards.map((card) => ({
      href: card.href,
      title: card.title,
      description: card.question,
      accent: card.accent,
    }))}
  />

  <!-- ===== TRUSTBLOK ===== -->
  <section id="waarom" class="trust-band">
    <h2 class="section-heading">Waarom Calculatieloket?</h2>
    <div class="trust-band-inner">
      <div class="trust-band-item">
        <span class="tb-check">&check;</span>
        <span>Gratis en zonder account</span>
      </div>
      <div class="trust-band-item">
        <span class="tb-check">&check;</span>
        <span>Geen opslag van je invoer</span>
      </div>
      <div class="trust-band-item">
        <span class="tb-check">&check;</span>
        <span>Gebaseerd op officiële bronnen</span>
      </div>
      <div class="trust-band-item">
        <span class="tb-check">&check;</span>
        <span>Resultaten zijn een indicatie</span>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="faq-section">
    <h2 class="section-heading">Veelgestelde vragen</h2>

    <details class="faq-item">
      <summary>Zijn de calculators gratis?</summary>
      <p>Ja, alle calculators op Calculatieloket.nl zijn volledig gratis te gebruiken. Je hebt geen account nodig en er zijn geen verborgen kosten.</p>
    </details>

    <details class="faq-item">
      <summary>Worden mijn gegevens opgeslagen?</summary>
      <p>Nee. Alle berekeningen vinden plaats in je eigen browser. Wat je invult in een calculator wordt niet door ons opgeslagen of doorgestuurd. Lees meer in ons <a href="/privacy/">privacybeleid</a>.</p>
    </details>

    <details class="faq-item">
      <summary>Waarom is de uitkomst een indicatie?</summary>
      <p>Onze calculators gebruiken de officiële tarieven en regels, maar je persoonlijke situatie kan afwijken door factoren die wij niet kennen. Denk aan andere inkomsten, specifieke aftrekposten, vermogen of bijzondere regelingen. Gebruik de uitkomst als richtlijn, niet als definitief bedrag.</p>
    </details>

    <details class="faq-item">
      <summary>Welke bronnen gebruikt Calculatieloket?</summary>
      <p>We baseren onze calculators op informatie van de <a href="https://www.belastingdienst.nl">Belastingdienst</a>, <a href="https://www.toeslagen.nl">Dienst Toeslagen</a> en <a href="https://www.rijksoverheid.nl">Rijksoverheid</a>. Bij elke calculator vermelden we de gebruikte bronnen.</p>
    </details>

    <details class="faq-item">
      <summary>Kan ik de uitkomst gebruiken voor aangifte of aanvraag?</summary>
      <p>De uitkomsten zijn indicatief. Gebruik ze als hulpmiddel, maar doe voor officiële zaken zoals belastingaangifte of toeslagaanvraag altijd een officiële proefberekening op de website van de Belastingdienst of Dienst Toeslagen. Raadpleeg bij twijfel een financieel adviseur.</p>
    </details>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById("hpSearch") as HTMLInputElement;
  const grid = document.getElementById("hpGrid") as HTMLElement;
  const cards = Array.from(grid.querySelectorAll(".hp-card")) as HTMLElement[];
  const noResults = document.getElementById("hpNoResults") as HTMLElement;

  function updateSearchUrl(term: string) {
    const url = new URL(window.location.href);
    if (term) {
      url.searchParams.set("q", term);
    } else {
      url.searchParams.delete("q");
    }
    window.history.replaceState({}, "", url.toString());
  }

  function filterCards() {
    const rawTerm = searchInput.value.trim();
    const term = rawTerm.toLowerCase();
    updateSearchUrl(rawTerm);

    let visibleCount = 0;
    cards.forEach((card) => {
      const title = (card.dataset.title || "").toLowerCase();
      const keywords = (card.dataset.keywords || "").toLowerCase();

      const matchesSearch =
        term === "" ||
        title.includes(term) ||
        keywords.includes(term) ||
        card.textContent?.toLowerCase().includes(term);

      card.style.display = matchesSearch ? "" : "none";
      if (matchesSearch) visibleCount++;
    });

    noResults.style.display = visibleCount === 0 ? "block" : "none";
  }

  // Initialize search from URL
  const initialParams = new URLSearchParams(window.location.search);
  const initialQuery = initialParams.get("q") || "";
  if (initialQuery) {
    searchInput.value = initialQuery;
    filterCards();
  }

  searchInput.addEventListener("input", filterCards);
  searchInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      filterCards();
      grid.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  });

  // ===== SNEL STARTEN =====
  const qsChoices = Array.from(document.querySelectorAll(".hp-qs-choice")) as HTMLButtonElement[];
  const qsInput = document.getElementById("hpQsInput") as HTMLInputElement;
  const qsLabel = document.getElementById("hpQsLabel") as HTMLLabelElement;
  const qsCta = document.getElementById("hpQsCta") as HTMLButtonElement;

  function selectQuickStartChoice(btn: HTMLButtonElement) {
    qsChoices.forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
    qsLabel.textContent = btn.dataset.label || "Bedrag";
    qsInput.placeholder = btn.dataset.placeholder || "";
    qsInput.value = "";
    qsInput.focus();
  }

  function startQuickCalculation() {
    const active = qsChoices.find((b) => b.classList.contains("active"));
    if (!active) return;

    const value = parseFloat(qsInput.value);
    if (!Number.isFinite(value) || value <= 0) {
      qsInput.focus();
      return;
    }

    const href = active.dataset.href || "/";
    const param = active.dataset.param || "waarde";
    const extra = active.dataset.extra ? `&${active.dataset.extra}` : "";
    window.location.href = `${href}?${param}=${Math.round(value)}${extra}`;
  }

  qsChoices.forEach((btn) => {
    btn.addEventListener("click", () => selectQuickStartChoice(btn));
  });

  qsCta.addEventListener("click", startQuickCalculation);
  qsInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      startQuickCalculation();
    }
  });
</script>

