---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://calculatieloket.nl/" },
    { "@type": "ListItem", position: 2, name: "Over ons", item: "https://calculatieloket.nl/over-ons/" },
  ],
};
---

<BaseLayout
  title="Over Calculatieloket - Gratis online calculators"
  description="Lees over Calculatieloket.nl: gratis calculators gebaseerd op officiële bronnen. Jaarlijks gecontroleerd, privacyvriendelijk en anoniem."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Over ons", current: true },
    ]}
    analyticsCategory="site-page"
  />

  <h1 class="page-title">Over Calculatieloket.nl</h1>
  <p class="page-subtitle">Gratis, snel en duidelijk rekenen. Zonder account, zonder opslag van je calculatorinvoer.</p>

  <div class="calculator-card">
    <h2>Wat is Calculatieloket.nl?</h2>
    <p>Calculatieloket.nl biedt gratis online calculators voor veelvoorkomende financiële vragen. Of je nu BTW wilt berekenen, je nettoloon wilt weten, een hypotheek wilt inschatten, of je toeslagen wilt checken &mdash; wij hebben een simpele, snelle tool voor je klaarstaan.</p>

    <h2>Onafhankelijk</h2>
    <p>Wij zijn niet verbonden aan een bank, verzekeraar of overheidsinstelling. Onze calculators werken voor iedereen hetzelfde, zonder voorkeur voor een bepaald product of merk.</p>

    <h2>Privacyvriendelijk</h2>
    <p>We slaan je calculatorinvoer niet op. Alle berekeningen vinden plaats in je eigen browser. Je hebt geen account nodig. Wat je invult, blijft bij jou. Lees meer in ons <a href="/privacy/">privacybeleid</a>.</p>

    <h2>Hoe verdienen we geld?</h2>
    <p>We tonen mogelijk in de toekomst advertenties via Google AdSense om de site draaiende te houden. Dit doen we alleen met jouw toestemming, via de cookiebanner. Je kunt advertenties weigeren &mdash; de site werkt dan nog steeds volledig.</p>

    <h2>Betrouwbaar en transparant</h2>
    <p>Onze calculators zijn gebaseerd op officiële bronnen zoals de Belastingdienst, de Rijksoverheid en het Nibud. We controleren de tarieven en regels jaarlijks en werken de berekeningen bij zodra er nieuwe cijfers beschikbaar zijn. Bij elke calculator vermelden we de gebruikte bronnen.</p>

    <h2>Altijd up-to-date</h2>
    <p>We werken de tarieven en regels jaarlijks bij zodra de nieuwe belastingplannen bekend zijn. Bij elke calculator vermelden we welke gegevens we gebruiken en wat de bronnen zijn.</p>
  </div>
</BaseLayout>
