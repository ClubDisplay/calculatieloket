---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AdSlot from "../components/AdSlot.astro";
import CrossSellCards from "../components/CrossSellCards.astro";
import CalculatorShell from "../components/calculator/CalculatorShell.astro";
import InputPanel from "../components/calculator/InputPanel.astro";
import ResultPanel from "../components/calculator/ResultPanel.astro";
import UseCasesPanel from "../components/calculator/UseCasesPanel.astro";
import FaqAccordion from "../components/calculator/FaqAccordion.astro";
import ToolFooter from "../components/calculator/ToolFooter.astro";
import SourceCards from "../components/SourceCards.astro";
import TrustPanel from "../components/calculator/TrustPanel.astro";
import FinancialJourney from "../components/calculator/FinancialJourney.astro";
import HowToSchema from "../components/calculator/HowToSchema.astro";
import InlineSources from "../components/calculator/InlineSources.astro";
import { calculateVacationPay } from "../lib/calculators/vacation-pay";
import { getRecommendations } from "../lib/recommendations/engine";
import { formatEuro } from "../lib/format/currency";

const title = "Vakantiegeld berekenen 2026 | Netto vakantiegeld | Calculatieloket.nl";
const description = "Bereken hoeveel vakantiegeld je netto krijgt in 2026. Gebaseerd op je bruto maandsalaris, pensioen en loonheffingskorting. Gratis, anoniem en direct resultaat.";

const defaultGross = 3000;
const defaultPercentage = 8;
const defaultPension = 150;
const defaultLhk = true;

const initialResult = calculateVacationPay({
  grossMonthlySalary: defaultGross,
  vacationPayPercentage: defaultPercentage,
  applyLoonheffingskorting: defaultLhk,
  pensionAmount: defaultPension,
});

const initialRecommendations = getRecommendations({
  calculator: "vakantiegeld",
  values: {
    grossMonthlySalary: defaultGross,
    vacationPayPercentage: defaultPercentage,
    pensionAmount: defaultPension,
    lhk: defaultLhk ? 1 : 0,
  },
  result: initialResult,
});

const lastUpdated = "2 juli 2026";

const quickAmounts = [2500, 3000, 3500, 4000, 5000];

const useCases = [
  {
    id: "bruto-netto",
    title: "Bruto netto 2026",
    description: "Bekijk wat je bruto maandsalaris netto oplevert in 2026.",
    href: "/bruto-netto-2026/",
    accent: "#2563eb",
  },
  {
    id: "salaris",
    title: "Salaris vergelijken",
    description: "Vergelijk bruto en netto salaris op de salaris calculator.",
    href: "/salaris-calculator/",
    accent: "#2563eb",
  },
  {
    id: "toeslagen",
    title: "Toeslagen berekenen",
    description: "Check of je recht hebt op huur- of zorgtoeslag.",
    href: "/toeslagen-calculator/",
    accent: "#059669",
  },
  {
    id: "hypotheek",
    title: "Hypotheek berekenen",
    description: "Wat kan je lenen met dit inkomen?",
    href: "/hypotheek-calculator/",
    accent: "#d97706",
  },
  {
    id: "zzp",
    title: "ZZP uurtarief berekenen",
    description: "Bereken je benodigde uurtarief als zelfstandige.",
    href: "/zzp-calculator/",
    accent: "#7c3aed",
  },
];

const sources = [
  {
    label: "Officiële bron",
    title: "Belastingdienst — Box 1 tarieven 2026",
    description: "Actuele tarieven en schijven voor de inkomstenbelasting.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/boxen_en_tarieven/box_1/box_1",
  },
  {
    label: "Officiële bron",
    title: "Belastingdienst — Algemene heffingskorting 2026",
    description: "Tabel en maximale bedragen voor de algemene heffingskorting.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/heffingskortingen/algemene_heffingskorting/tabel-algemene-heffingskorting-2026",
  },
  {
    label: "Officiële bron",
    title: "Belastingdienst — Arbeidskorting 2026",
    description: "Tabel en maximale bedragen voor de arbeidskorting.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/heffingskortingen/arbeidskorting/tabel-arbeidskorting-2026",
  },
  {
    label: "Officiële bron",
    title: "Rijksoverheid — Vakantiegeld",
    description: "Algemene informatie over vakantiegeld en wanneer je het krijgt.",
    href: "https://www.rijksoverheid.nl/onderwerpen/vakantiegeld",
  },
];

const faq = [
  {
    question: "Wat is vakantiegeld?",
    answer: "Vakantiegeld is een wettelijke toeslag die je werkgever jaarlijks moet uitbetalen. De minimum is 8% van je bruto jaarsalaris, bovenop je normale salaris. Het bedrag is bedoeld voor vakantie, maar je mag het zelf besteden.",
  },
  {
    question: "Hoeveel vakantiegeld krijg ik?",
    answer: "De wettelijke minimum is 8% van je bruto jaarsalaris. In veel cao's of contracten kan dit hoger zijn, bijvoorbeeld 8,33% of meer. Je werkgever mag niet minder dan 8% uitkeren.",
  },
  {
    question: "Wanneer krijg ik vakantiegeld?",
    answer: "De meeste werkgevers betalen vakantiegeld een keer per jaar, vaak in mei of juni. Sommige werkgevers betalen het maandelijks of per kwartaal. Check je arbeidsovereenkomst of cao.",
  },
  {
    question: "Is vakantiegeld belast?",
    answer: "Ja, vakantiegeld wordt belast als loon. Over het bruto vakantiegeld betaal je loonheffing, premies en eventueel pensioenpremie. Wat er netto overblijft, hangt af van je totale inkomen en heffingskortingen.",
  },
  {
    question: "Wordt pensioenpremie ook ingehouden over vakantiegeld?",
    answer: "Dat hangt af van je pensioenregeling. In veel regelingen wordt pensioenpremie berekend over alle looncomponenten, inclusief vakantiegeld. Deze calculator vult zelf een maandelijks pensioenbedrag in, wat een indicatie geeft.",
  },
  {
    question: "Hoe accuraat is deze vakantiegeld calculator?",
    answer: "De calculator geeft een indicatie op basis van de 2026 Box 1 tarieven, heffingskortingen en het door jou ingevoerde pensioenbedrag. Je loonstrook kan afwijken door cao, extra vergoedingen, lease-auto bijtelling of meerdere werkgevers.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://calculatieloket.nl/",
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Vakantiegeld berekenen",
      "item": "https://calculatieloket.nl/vakantiegeld-calculator/",
    },
  ],
};
---

<BaseLayout title={title} description={description} containerClass="container-wide">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <HowToSchema
    slot="head"
    name="Vakantiegeld berekenen"
    description="Stappen om een indicatie te krijgen van je netto vakantiegeld in 2026."
    totalTime="PT1M"
    steps={[
      { name: "Vul je bruto maandsalaris in", text: "Voer het bruto maandsalaris in waarover je vakantiegeld wilt berekenen." },
      { name: "Kies het vakantiegeldpercentage", text: "De standaard is 8%, maar je kunt een afwijkend percentage invullen." },
      { name: "Vul je pensioenpremie in", text: "Voer het werknemersdeel van je pensioenpremie per maand in." },
      { name: "Pas loonheffingskorting toe", text: "Zet de loonheffingskorting aan als je deze bij je werkgever hebt." },
      { name: "Bekijk je netto vakantiegeld", text: "De calculator toont je bruto vakantiegeld, de geschatte inhouding en het netto bedrag." },
    ]}
  />

  <AdSlot slot="1234567900" format="auto" style="min-height:280px" />

  <Breadcrumbs items={[
    { label: "Home", href: "/" },
    { label: "Inkomen", href: "/categorie/inkomen/" },
    { label: "Vakantiegeld calculator", current: true },
  ]} />

  <CalculatorShell title="Vakantiegeld berekenen" subtitle="Vul je bruto maandsalaris, vakantiegeldpercentage, pensioenpremie en loonheffingskorting in en zie direct een indicatie van je netto vakantiegeld.">
    <InputPanel title="Jouw situatie" slot="input">
      <div class="form-group">
        <label for="grossSalary">Bruto maandsalaris</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="grossSalary" value={defaultGross} min="0" step="1" />
        </div>
      </div>

      <div class="quick-chips">
        <span class="quick-chips-label">Snel kiezen:</span>
        {quickAmounts.map((amount) => (
          <button type="button" class="quick-chip" data-amount={amount} data-analytics="quick-chip" data-analytics-category="calculator-page" data-analytics-action="select" data-analytics-label={amount}>
            &euro; {amount.toLocaleString("nl-NL")}
          </button>
        ))}
      </div>

      <div class="form-group">
        <label for="vacationPayPercentage">Vakantiegeld percentage</label>
        <div class="input-prefix">
          <span class="prefix">%</span>
          <input type="number" id="vacationPayPercentage" value={defaultPercentage} min="0" max="100" step="0.01" />
        </div>
      </div>

      <div class="form-group">
        <label for="pensionAmount">Pensioenpremie per maand <span class="hint">(werknemersdeel)</span></label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="pensionAmount" value={defaultPension} min="0" step="1" />
        </div>
      </div>

      <div class="form-group">
        <div class="toggle-row">
          <span class="toggle-label">Loonheffingskorting toepassen</span>
          <label class="toggle" for="loonheffingskorting">
            <input type="checkbox" id="loonheffingskorting" checked={defaultLhk} />
            <span class="slider"></span>
          </label>
        </div>
      </div>

      <button id="berekenBtn" class="btn btn-primary btn-lg" style="width:100%" data-analytics="cta" data-analytics-category="calculator-page" data-analytics-action="click" data-analytics-label="bereken">Bereken vakantiegeld</button>
      <p class="calc-error" id="calcError" style="display:none;">Vul een geldig bruto maandsalaris in (hoger dan 0) en een percentage tussen 0 en 100.</p>
    </InputPanel>

    <ResultPanel
      slot="result"
      title="Netto vakantiegeld"
      heroLabel="Jouw netto vakantiegeld"
      heroValue={initialResult.valid ? formatEuro(initialResult.netVacationPay, 0) : "—"}
      heroSubtext="Indicatie op basis van 2026-tarieven"
      badge="Indicatie"
    >
      <div class="result-meta">
        <span class="meta-badge">Bijgewerkt: 2026</span>
        <span class="meta-badge">Bron: Belastingdienst</span>
      </div>

      <div class="result-row"><span class="label">Bruto maandsalaris</span><span class="value" id="detailGross">{formatEuro(defaultGross, 0)}</span></div>
      <div class="result-row"><span class="label">Vakantiegeld percentage</span><span class="value" id="detailPercentage">{defaultPercentage}%</span></div>
      <div class="result-row"><span class="label">Bruto vakantiegeld</span><span class="value" id="detailGrossVacation">{initialResult.valid ? formatEuro(initialResult.grossVacationPay, 0) : "—"}</span></div>
      <div class="result-divider"></div>
      <div class="result-row"><span class="label">Geschatte inhouding</span><span class="value" id="detailTax">{initialResult.valid ? formatEuro(initialResult.estimatedTax, 0) : "—"}</span></div>
      <div class="result-row result-row-total"><span class="label">Netto vakantiegeld</span><span class="value" id="detailNetVacation">{initialResult.valid ? formatEuro(initialResult.netVacationPay, 0) : "—"}</span></div>
      <div class="result-row"><span class="label">Effectief tarief</span><span class="value" id="detailEffectiveRate">{initialResult.valid ? `${(initialResult.effectiveRate * 100).toFixed(1).replace(".", ",")}%` : "—"}</span></div>
      <div class="result-divider"></div>
      <div class="result-row"><span class="label">Netto per jaar met vakantiegeld</span><span class="value" id="detailTotalNet">{initialResult.valid ? formatEuro(initialResult.breakdown.totalNetYearly, 0) : "—"}</span></div>
      <div class="result-row"><span class="label">Netto per jaar zonder vakantiegeld</span><span class="value" id="detailNoVacationNet">{initialResult.valid ? formatEuro(initialResult.breakdown.noVacationNetYearly, 0) : "—"}</span></div>

      <button class="copy-link-btn" id="copyLinkBtn" type="button" slot="actions" data-analytics="copy-link" data-analytics-category="calculator-page" data-analytics-action="click" data-analytics-label="copy-link">
        <span class="copy-link-icon">🔗</span>
        <span class="copy-link-text">Deel deze berekening</span>
      </button>

      <FinancialJourney recommendations={initialRecommendations} />

      <InlineSources title="Gebruikte bronnen" items={sources} />
    </ResultPanel>

    <TrustPanel slot="result" lastUpdated={lastUpdated} sourcesId="calculator-sources" />

    <UseCasesPanel title="Wat kun je hiermee?" items={useCases} slot="useCases" />

    <SourceCards id="calculator-sources" title="Bronnen" items={sources} slot="sources" />

    <FaqAccordion title="Veelgestelde vragen" items={faq} slot="faq" />

    <ToolFooter categoryLink="/categorie/inkomen/" categoryLabel="Inkomen"
      slot="footer"
      disclaimer="Deze berekening is een indicatie op basis van de ingevoerde gegevens en de bekende belastingtarieven van 2026. Je loonstrook en het daadwerkelijke netto vakantiegeld kunnen afwijken door pensioen, cao, werkgever, bijzondere beloningen en persoonlijke situatie. Gebruik de uitkomst als richtlijn, niet als definitief bedrag. Raadpleeg bij belangrijke financiële beslissingen een financieel adviseur."
      lastUpdated={lastUpdated}
    />
  </CalculatorShell>

  <div class="calculator-card calc-content" id="calculator-content">
    <p class="badge-indicatie">Indicatie 2026</p>

    <h2 class="page-title">Vakantiegeld berekenen</h2>
    <p>Met deze vakantiegeld calculator bereken je eenvoudig hoeveel vakantiegeld je netto krijgt in 2026. De uitkomst is een indicatie, gebaseerd op je bruto maandsalaris, het vakantiegeldpercentage, je pensioenpremie en de loonheffingskorting.</p>
    <p>Wil je je totale salaris bekijken? Gebruik de <a href="/bruto-netto-2026/">bruto-netto calculator</a> of <a href="/salaris-calculator/">salaris calculator</a>. Voor toeslagen, hypotheek of ZZP-uurtarief gebruik je de <a href="/toeslagen-calculator/">toeslagen calculator</a>, <a href="/hypotheek-calculator/">hypotheek calculator</a> of <a href="/zzp-calculator/">ZZP calculator</a>.</p>

    <h2>Hoe werkt vakantiegeld?</h2>
    <p>In Nederland heeft vrijwel elke werknemer recht op vakantiegeld. De wettelijke minimum is 8% van je bruto jaarsalaris. Dat betekent:</p>
    <ul class="calc-list">
      <li><strong>Bruto maandsalaris:</strong> het vastgestelde bruto salaris per maand.</li>
      <li><strong>Vakantiegeld:</strong> 8% × 12 maanden × bruto maandsalaris = circa 0,96 maand salaris.</li>
      <li><strong>Uitbetaling:</strong> meestal eenmalig per jaar (mei/juni), soms maandelijks.</li>
    </ul>
    <p>Je werkgever mag vakantiegeld niet verrekenen met gewoon salaris en moet het altijd bovenop je loon uitkeren.</p>

    <h2>Voorbeeldberekening</h2>
    <p>Stel, je bruto maandsalaris is <strong>€ 3.000</strong>, je vakantiegeldpercentage is 8%, je pensioenpremie is <strong>€ 150</strong> per maand en je hebt de loonheffingskorting toegepast. Dan is je bruto vakantiegeld circa <strong>€ 2.880</strong> (12 × € 3.000 × 8%). Na inhoudingen houd je een indicatief netto vakantiegeld over van ongeveer <strong>€ 1.700</strong>.</p>
    <p>De exacte netto-uitkering hangt af van je totale jaarinkomen, pensioen, heffingskortingen en eventuele andere looncomponenten.</p>

    <h2>Belasting over vakantiegeld</h2>
    <p>Vakantiegeld wordt belast als gewoon loon. Dat betekent dat:</p>
    <ul class="calc-list">
      <li>De inkomstenbelasting (Box 1) wordt berekend over je totale jaarinkomen inclusief vakantiegeld.</li>
      <li>De <strong>algemene heffingskorting</strong> en <strong>arbeidskorting</strong> je netto kunnen verhogen.</li>
      <li>Hogere inkomens betalen een hoger marginaltarief over het extra vakantiegeld.</li>
    </ul>
    <p>Deze calculator gebruikt de actuele 2026 Box 1 tarieven, de algemene heffingskorting en de arbeidskorting.</p>

    <h2>Wanneer krijg ik vakantiegeld?</h2>
    <p>De meeste werknemers ontvangen vakantiegeld in mei of juni. Sommige cao's regelen een maandelijkse of kwartaaluitkering. Ben je niet zeker? Check je loonstrook, arbeidsovereenkomst of cao.</p>

    <h2>Veelgemaakte fouten</h2>
    <ul class="calc-list">
      <li><strong>Netto vakantiegeld gelijk stellen aan bruto:</strong> over vakantiegeld betaal je loonheffing.</li>
      <li><strong>Pensioen vergeten:</strong> de werknemersbijdrage verlaagt je belastbare inkomen.</li>
      <li><strong>Loonheffingskorting onterecht niet meerekenen:</strong> als je deze bij je werkgever hebt, scheelt dat netto belasting.</li>
      <li><strong>Extra percentage verwarren:</strong> de wettelijke minimum is 8%, maar je eigen cao kan meer geven.</li>
    </ul>
  </div>

  <CrossSellCards
    title="Ook handig om te berekenen"
    items={[
      { title: "Bruto netto 2026", description: "Bereken een indicatie van je nettoloon in 2026.", href: "/bruto-netto-2026/", accent: "#2563eb" },
      { title: "Salaris vergelijken", description: "Vergelijk bruto en netto op de salaris calculator.", href: "/salaris-calculator/", accent: "#2563eb" },
      { title: "Hoeveel hypotheek kan ik krijgen?", description: "Indicatie op basis van je inkomen.", href: "/hypotheek-calculator/", accent: "#d97706" },
    ]}
  />
</BaseLayout>

<script>
  import { calculateVacationPay } from "../lib/calculators/vacation-pay";
  import { formatEuro } from "../lib/format/currency";
  import { getRecommendations } from "../lib/recommendations/engine";
  import { updateFinancialJourney } from "../lib/recommendations/client";

  const grossInput = document.getElementById("grossSalary") as HTMLInputElement;
  const percentageInput = document.getElementById("vacationPayPercentage") as HTMLInputElement;
  const pensionInput = document.getElementById("pensionAmount") as HTMLInputElement;
  const lhCheckbox = document.getElementById("loonheffingskorting") as HTMLInputElement;
  const hero = document.querySelector(".calc-result-panel-hero") as HTMLElement;
  const errorBox = document.getElementById("calcError") as HTMLElement;
  const berekenBtn = document.getElementById("berekenBtn") as HTMLButtonElement;
  const copyLinkBtn = document.getElementById("copyLinkBtn") as HTMLButtonElement;
  const financialJourney = document.querySelector(".calc-financial-journey") as HTMLElement;

  const detailGross = document.getElementById("detailGross")!;
  const detailPercentage = document.getElementById("detailPercentage")!;
  const detailGrossVacation = document.getElementById("detailGrossVacation")!;
  const detailTax = document.getElementById("detailTax")!;
  const detailNetVacation = document.getElementById("detailNetVacation")!;
  const detailEffectiveRate = document.getElementById("detailEffectiveRate")!;
  const detailTotalNet = document.getElementById("detailTotalNet")!;
  const detailNoVacationNet = document.getElementById("detailNoVacationNet")!;

  function updateUrl() {
    const params = new URLSearchParams(window.location.search);
    const gross = parseFloat(grossInput.value) || 0;
    const percentage = parseFloat(percentageInput.value);
    const pension = parseFloat(pensionInput.value) || 0;

    if (gross > 0) params.set("bruto", gross.toString());
    else params.delete("bruto");

    if (Number.isFinite(percentage) && percentage >= 0 && percentage <= 100) {
      params.set("percentage", percentage.toString());
    } else {
      params.delete("percentage");
    }

    if (pension > 0) params.set("pensioen", pension.toString());
    else params.delete("pensioen");

    params.set("lhk", lhCheckbox.checked ? "1" : "0");

    const newUrl = `${window.location.pathname}?${params.toString()}`;
    window.history.replaceState(null, "", newUrl);
  }

  function calculate() {
    const gross = parseFloat(grossInput.value);
    const percentage = parseFloat(percentageInput.value);
    const pension = parseFloat(pensionInput.value) || 0;
    const hasLHK = lhCheckbox.checked;

    const isInvalid =
      !Number.isFinite(gross) ||
      gross <= 0 ||
      !Number.isFinite(percentage) ||
      percentage < 0 ||
      percentage > 100;

    if (isInvalid) {
      errorBox.style.display = "block";
      hero.textContent = "—";
      detailGrossVacation.textContent = "—";
      detailTax.textContent = "—";
      detailNetVacation.textContent = "—";
      detailEffectiveRate.textContent = "—";
      detailTotalNet.textContent = "—";
      detailNoVacationNet.textContent = "—";
      return;
    }

    errorBox.style.display = "none";

    const result = calculateVacationPay({
      grossMonthlySalary: gross,
      vacationPayPercentage: percentage,
      pensionAmount: pension,
      applyLoonheffingskorting: hasLHK,
    });

    if (!result.valid) {
      errorBox.style.display = "block";
      hero.textContent = "—";
      detailGrossVacation.textContent = "—";
      detailTax.textContent = "—";
      detailNetVacation.textContent = "—";
      detailEffectiveRate.textContent = "—";
      detailTotalNet.textContent = "—";
      detailNoVacationNet.textContent = "—";
      return;
    }

    hero.textContent = formatEuro(result.netVacationPay, 0);
    detailGross.textContent = formatEuro(gross, 0);
    detailPercentage.textContent = `${percentage}%`;
    detailGrossVacation.textContent = formatEuro(result.grossVacationPay, 0);
    detailTax.textContent = formatEuro(result.estimatedTax, 0);
    detailNetVacation.textContent = formatEuro(result.netVacationPay, 0);
    detailEffectiveRate.textContent = `${(result.effectiveRate * 100).toFixed(1).replace(".", ",")}%`;
    detailTotalNet.textContent = formatEuro(result.breakdown.totalNetYearly, 0);
    detailNoVacationNet.textContent = formatEuro(result.breakdown.noVacationNetYearly, 0);

    if (financialJourney) {
      const recs = getRecommendations({
        calculator: "vakantiegeld",
        values: {
          grossMonthlySalary: gross,
          vacationPayPercentage: percentage,
          pensionAmount: pension,
          lhk: hasLHK ? 1 : 0,
        },
        result,
      });
      updateFinancialJourney(financialJourney, recs);
    }

    updateUrl();
  }

  function applyUrlParams() {
    const params = new URLSearchParams(window.location.search);
    const gross = params.get("bruto");
    const percentage = params.get("percentage");
    const pension = params.get("pensioen");
    const lhk = params.get("lhk");

    if (gross !== null) grossInput.value = gross;
    if (percentage !== null) percentageInput.value = percentage;
    if (pension !== null) pensionInput.value = pension;
    if (lhk !== null) lhCheckbox.checked = lhk === "1";
  }

  function initQuickChips() {
    document.querySelectorAll(".quick-chip").forEach((btn) => {
      btn.addEventListener("click", () => {
        const amount = (btn as HTMLElement).dataset.amount;
        if (amount) {
          grossInput.value = amount;
          grossInput.focus();
          calculate();
        }
      });
    });
  }

  function initCopyLink() {
    copyLinkBtn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const textEl = copyLinkBtn.querySelector(".copy-link-text") as HTMLElement;
        const originalText = textEl.textContent || "Deel deze berekening";
        textEl.textContent = "Link gekopieerd";
        copyLinkBtn.classList.add("copy-link-success");
        setTimeout(() => {
          textEl.textContent = originalText;
          copyLinkBtn.classList.remove("copy-link-success");
        }, 2000);
      } catch (err) {
        console.error("Kon link niet kopiëren", err);
      }
    });
  }

  applyUrlParams();
  calculate();
  initQuickChips();
  initCopyLink();

  grossInput.addEventListener("input", calculate);
  percentageInput.addEventListener("input", calculate);
  pensionInput.addEventListener("input", calculate);
  lhCheckbox.addEventListener("change", calculate);
  berekenBtn.addEventListener("click", calculate);
  grossInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      calculate();
      grossInput.blur();
    }
  });
</script>

