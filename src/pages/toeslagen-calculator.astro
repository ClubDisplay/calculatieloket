---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdSlot from "../components/AdSlot.astro";
import CrossSellCards from "../components/CrossSellCards.astro";
import CalculatorShell from "../components/calculator/CalculatorShell.astro";
import InputPanel from "../components/calculator/InputPanel.astro";
import ResultPanel from "../components/calculator/ResultPanel.astro";
import UseCasesPanel from "../components/calculator/UseCasesPanel.astro";
import FaqAccordion from "../components/calculator/FaqAccordion.astro";
import ToolFooter from "../components/calculator/ToolFooter.astro";
import SourceCards from "../components/SourceCards.astro";
import FinancialJourney from "../components/calculator/FinancialJourney.astro";
import { calculateAllowances } from "../lib/calculators/allowances";
import { formatEuro } from "../lib/format/currency";

const title = "Toeslagen Calculator 2026 — Zorgtoeslag en huurtoeslag indicatie | Calculatieloket.nl";
const description = "Bereken een indicatie van zorgtoeslag en huurtoeslag op basis van inkomen, huur en huishouden. Gebaseerd op regels 2026 van Dienst Toeslagen.";

const defaultIncome = 28000;
const defaultRent = 700;
const defaultIsCouple = false;
const defaultPartnerIncome = 20000;
const defaultVermogen = 0;
const defaultKinderen = 0;

const initialResult = calculateAllowances({
  income: defaultIncome,
  partnerIncome: defaultPartnerIncome,
  isCouple: defaultIsCouple,
  rent: defaultRent,
});

const totalMonthlyBenefit = initialResult.rentBenefit + initialResult.zorgBenefit;
const totalYearlyBenefit = totalMonthlyBenefit * 12;

const lastUpdated = "30 juni 2026";

const quickIncomeAmounts = [25000, 35000, 45000, 60000];

const useCases = [
  {
    id: "bruto-netto",
    title: "Bruto-netto 2026",
    description: "Bekijk wat je netto overhoudt bij een inkomen van {{inkomen}}.",
    href: "/bruto-netto-2026/",
    accent: "#2563eb",
  },
  {
    id: "salaris",
    title: "Salaris calculator",
    description: "Vergelijk bruto en netto op basis van {{inkomen}} per jaar.",
    href: "/salaris-calculator/",
    accent: "#3b82f6",
  },
  {
    id: "hypotheek",
    title: "Hypotheek berekenen",
    description: "Wat kan je lenen met een totaal inkomen van {{totaal}}?",
    href: "/hypotheek-calculator/",
    accent: "#d97706",
  },
  {
    id: "zzp",
    title: "ZZP uurtarief berekenen",
    description: "Hoeveel moet je als ZZP'er vragen om dit inkomen te halen?",
    href: "/zzp-calculator/",
    accent: "#7c3aed",
  },
];

const sources = [
  {
    label: "Officiële bron",
    title: "Dienst Toeslagen — Huurtoeslag",
    description: "Informatie en voorwaarden voor huurtoeslag.",
    href: "https://www.toeslagen.nl/huurtoeslag",
  },
  {
    label: "Officiële bron",
    title: "Dienst Toeslagen — Zorgtoeslag",
    description: "Informatie en inkomensgrenzen voor zorgtoeslag.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/nl/zorgtoeslag/content/maximaal-inkomen-voor-zorgtoeslag",
  },
  {
    label: "Officiële bron",
    title: "Toeslagenkaart 2026",
    description: "Overzicht van alle toeslagen en bedragen voor 2026.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/themaoverstijgend/brochures_en_publicaties/toeslagenkaart-2026",
  },
];

const faq = [
  {
    question: "Is dit hetzelfde als de officiële proefberekening?",
    answer: "Nee. Dit is een indicatie. De Dienst Toeslagen kijkt naar meer factoren waaronder je uiteindelijke toetsingsinkomen en vermogen. Doe de officiële proefberekening op <a href=\"https://www.toeslagen.nl\" target=\"_blank\" rel=\"noopener\">Toeslagen.nl</a>.",
  },
  {
    question: "Wat is een toeslagpartner?",
    answer: "Je toeslagpartner is de persoon met wie je een gezamenlijk huishouden voert. Het inkomen van je toeslagpartner telt mee voor de berekening.",
  },
  {
    question: "Waarom telt vermogen mee?",
    answer: "Naast inkomen kijkt de Belastingdienst naar je vermogen (spaargeld, beleggingen). Deze calculator houdt hier nog geen rekening mee — dit kan invloed hebben op je mogelijke toeslag.",
  },
  {
    question: "Waarom kan het definitieve bedrag afwijken?",
    answer: "De Dienst Toeslagen berekent je toeslag op basis van een geschat inkomen. Na afloop van het jaar volgt een definitieve berekening op basis van je werkelijke inkomen.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://calculatieloket.nl/",
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Toeslagen Calculator",
      "item": "https://calculatieloket.nl/toeslagen-calculator/",
    },
  ],
};
---

<BaseLayout title={title} description={description} containerClass="container-wide">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <AdSlot slot="1234567896" format="auto" style="min-height:100px" />

  <CalculatorShell title="Toeslagen calculator 2026" subtitle="Bereken een indicatie van huurtoeslag en zorgtoeslag op basis van jouw inkomen, huur en huishouden.">
    <InputPanel title="Jouw situatie" slot="input">
      <p class="input-note">Vul je bruto jaarinkomen, huur en huishouden in. Vermogen en kinderen worden nog niet meegerekend in deze indicatie.</p>

      <div class="form-group">
        <label for="income">Bruto jaarinkomen</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="income" value={defaultIncome} min="0" step="100" />
        </div>
      </div>

      <div class="quick-chips">
        <span class="quick-chips-label">Snel inkomen:</span>
        {quickIncomeAmounts.map((amount) => (
          <button type="button" class="quick-chip" data-amount={amount}>
            &euro; {amount.toLocaleString("nl-NL")}
          </button>
        ))}
      </div>

      <div class="form-group">
        <label>Huishouden</label>
        <div class="radio-group" id="household">
          <button type="button" data-type="single" class={!defaultIsCouple ? "active" : ""}>Alleenstaand</button>
          <button type="button" data-type="couple" class={defaultIsCouple ? "active" : ""}>Met partner</button>
        </div>
      </div>

      <div class="form-group" id="partnerIncomeGroup" style={defaultIsCouple ? undefined : "display:none;"}>
        <label for="partnerIncome">Bruto jaarinkomen partner</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="partnerIncome" value={defaultPartnerIncome} min="0" step="100" />
        </div>
      </div>

      <div class="form-group">
        <label for="rent">Maandelijkse huur <span class="hint">(kale huur, excl. servicekosten)</span></label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="rent" value={defaultRent} min="0" step="1" />
        </div>
      </div>

      <div class="form-group form-group-row">
        <div>
          <label for="vermogen">Vermogen <span class="hint">(spaargeld + beleggingen)</span></label>
          <div class="input-prefix">
            <span class="prefix">&euro;</span>
            <input type="number" id="vermogen" value={defaultVermogen} min="0" step="100" />
          </div>
        </div>
        <div>
          <label for="kinderen">Kinderen</label>
          <input type="number" id="kinderen" value={defaultKinderen} min="0" max="20" step="1" />
        </div>
      </div>

      <button id="berekenBtn" class="btn btn-primary btn-lg" style="width:100%">Bereken toeslagen</button>
      <p class="calc-error" id="calcError" style="display:none;">Vul een geldig inkomen en huur in.</p>
    </InputPanel>

    <ResultPanel
      slot="result"
      title="Toeslag indicatie"
      heroLabel="Totale toeslag per maand"
      heroValue={formatEuro(totalMonthlyBenefit, 0)}
      heroSubtext="Huurtoeslag + zorgtoeslag"
      badge="Indicatie"
    >
      <div class="result-meta">
        <span class="meta-badge">Bijgewerkt: 2026</span>
        <span class="meta-badge">Bron: Belastingdienst</span>
      </div>

      <div class="result-row"><span class="label">Bruto jaarinkomen</span><span class="value" id="detailIncome">{formatEuro(defaultIncome, 0)}</span></div>
      <div class="result-row"><span class="label">Huishouden</span><span class="value" id="detailHousehold">{defaultIsCouple ? "Met partner" : "Alleenstaand"}</span></div>
      <div class="result-row"><span class="label">Maandelijkse huur</span><span class="value" id="detailRent">{formatEuro(defaultRent, 0)}</span></div>
      <div class="result-divider"></div>
      <div class="result-row"><span class="label">Huurtoeslag per maand</span><span class="value" id="detailRentBenefit">{formatEuro(initialResult.rentBenefit, 0)}</span></div>
      <div class="result-row"><span class="label">Zorgtoeslag per maand</span><span class="value" id="detailZorgBenefit">{formatEuro(initialResult.zorgBenefit, 0)}</span></div>
      <div class="result-divider"></div>
      <div class="result-row result-row-total"><span class="label">Totaal toeslag per maand</span><span class="value" id="detailTotalMonthly">{formatEuro(totalMonthlyBenefit, 0)}</span></div>
      <div class="result-row result-row-total"><span class="label">Totaal toeslag per jaar</span><span class="value" id="detailTotalYearly">{formatEuro(totalYearlyBenefit, 0)}</span></div>

      <div class="result-assumptions">
        <div class="result-assumptions-title">Gebruikte uitgangspunten</div>
        <div class="result-row"><span class="label">Rekengrens huurtoeslag</span><span class="value">€ 932,93</span></div>
        <div class="result-row"><span class="label">Max. zorgtoeslag (alleen)</span><span class="value">€ 1.550/jaar</span></div>
        <div class="result-row"><span class="label">Max. zorgtoeslag (samen)</span><span class="value">€ 2.963/jaar</span></div>
      </div>

      <FinancialJourney
        income={defaultIncome}
        partnerIncome={defaultPartnerIncome}
        totalIncome={initialResult.totalIncome}
        rent={defaultRent}
        isCouple={defaultIsCouple}
      />

      <button class="copy-link-btn" id="copyLinkBtn" type="button" slot="actions">
        <span class="copy-link-icon">🔗</span>
        <span class="copy-link-text">Deel deze berekening</span>
      </button>

      <div class="result-next-steps" slot="actions">
        <span class="result-next-steps-label">Verder rekenen:</span>
        <a href="/bruto-netto-2026/">Bruto-netto</a>
        <a href="/salaris-calculator/">Salaris</a>
        <a href="/hypotheek-calculator/">Hypotheek</a>
        <a href="/zzp-calculator/">ZZP</a>
      </div>
    </ResultPanel>

    <UseCasesPanel title="Wat kun je hiermee?" items={useCases} slot="useCases" />

    <SourceCards title="Bronnen" items={sources} slot="sources" />

    <FaqAccordion title="Veelgestelde vragen" items={faq} slot="faq" />

    <ToolFooter
      slot="footer"
      disclaimer="Deze berekening is een indicatie. Je werkelijke toeslag kan afwijken. Doe altijd de officiële proefberekening op Toeslagen.nl. Aan deze indicatie kunnen geen rechten worden ontleend."
      lastUpdated={lastUpdated}
    />
  </CalculatorShell>

  <div class="calculator-card calc-content" id="calculator-content">
    <h2 class="page-title">Toeslagen calculator 2026</h2>
    <p>Bereken een indicatie van huurtoeslag en zorgtoeslag op basis van jouw inkomen, huur en situatie. Gebaseerd op de regels van 2026.</p>

    <h2>Hoe werkt deze berekening?</h2>
    <p>Deze calculator geeft een indicatie van huurtoeslag en zorgtoeslag op basis van de regels van 2026.</p>
    <ul class="calc-list">
      <li><strong>Huurtoeslag:</strong> vanaf 2026 kan je huur niet meer 'te hoog' zijn om huurtoeslag aan te vragen. De rekengrenzen (€ 932,93 voor 21+) tellen nog wel mee voor de hoogte. Vermogensgrens: € 38.479 (alleen) / € 76.958 (samen).</li>
      <li><strong>Zorgtoeslag:</strong> maximaal € 1.550/jaar (circa € 129/maand) voor alleenstaanden, € 2.963/jaar (circa € 247/maand) met partner. Inkomensgrens € 40.857 (alleen) / € 51.142 (samen). Vermogensgrens: € 146.011 (alleen) / € 184.633 (samen).</li>
    </ul>
  </div>

  <CrossSellCards
    title="Ook handig om te berekenen"
    items={[
      { href: "/bruto-netto-2026/", title: "Bruto netto 2026", description: "Bereken een indicatie van je nettoloon.", accent: "#2563eb" },
      { href: "/salaris-calculator/", title: "Salaris Calculator", description: "Bereken een indicatie van bruto naar netto.", accent: "#3b82f6" },
      { href: "/hypotheek-calculator/", title: "Hypotheek Calculator", description: "Maak een indicatie van maandlasten.", accent: "#d97706" },
    ]}
  />
</BaseLayout>

<script>
  import { calculateAllowances } from "../lib/calculators/allowances";
  import { formatEuro } from "../lib/format/currency";

  const incomeInput = document.getElementById("income") as HTMLInputElement;
  const rentInput = document.getElementById("rent") as HTMLInputElement;
  const partnerIncomeInput = document.getElementById("partnerIncome") as HTMLInputElement;
  const partnerIncomeGroup = document.getElementById("partnerIncomeGroup") as HTMLDivElement;
  const vermogenInput = document.getElementById("vermogen") as HTMLInputElement;
  const kinderenInput = document.getElementById("kinderen") as HTMLInputElement;
  const hero = document.querySelector(".calc-result-panel-hero") as HTMLElement;
  const errorBox = document.getElementById("calcError") as HTMLElement;
  const berekenBtn = document.getElementById("berekenBtn") as HTMLButtonElement;
  const copyLinkBtn = document.getElementById("copyLinkBtn") as HTMLButtonElement;

  const detailIncome = document.getElementById("detailIncome")!;
  const detailHousehold = document.getElementById("detailHousehold")!;
  const detailRent = document.getElementById("detailRent")!;
  const detailRentBenefit = document.getElementById("detailRentBenefit")!;
  const detailZorgBenefit = document.getElementById("detailZorgBenefit")!;
  const detailTotalMonthly = document.getElementById("detailTotalMonthly")!;
  const detailTotalYearly = document.getElementById("detailTotalYearly")!;

  let household: "single" | "couple" = "single";

  const formatNumber = (n: number, decimals = 0): string =>
    n.toFixed(decimals).replace(".", ",").replace(/\B(?=(\d{3})+(?!\d))/g, ".");

  function updateUseCases(income: number, totalIncome: number) {
    const replacements: Record<string, string> = {
      "{{inkomen}}": formatNumber(income, 0),
      "{{totaal}}": formatNumber(totalIncome, 0),
    };

    document.querySelectorAll("[data-usecase]").forEach((card) => {
      const desc = card.querySelector(".calc-use-cases-card-desc") as HTMLElement;
      if (!desc) return;
      const template = desc.dataset.template;
      if (!template) return;
      let text = template;
      Object.entries(replacements).forEach(([key, value]) => {
        text = text.replaceAll(key, value);
      });
      desc.textContent = text;
    });
  }

  function updateFinancialJourney(income: number, partnerIncome: number, totalIncome: number, isCouple: boolean) {
    const journey = document.querySelector(".calc-financial-journey") as HTMLElement;
    if (!journey) return;

    const brutoMonthly = income > 0 ? Math.round(income / 12) : 0;
    const totalIncomeValue = totalIncome > 0 ? totalIncome : income + partnerIncome;

    const nettoStep = journey.querySelector('[data-step="netto"]') as HTMLAnchorElement;
    const hypotheekStep = journey.querySelector('[data-step="hypotheek"]') as HTMLAnchorElement;

    if (nettoStep) {
      nettoStep.href = brutoMonthly > 0 ? `/salaris-calculator/?bruto=${brutoMonthly}` : "/salaris-calculator/";
    }
    if (hypotheekStep) {
      hypotheekStep.href =
        totalIncomeValue > 0
          ? `/hypotheek-calculator/?inkomen=${totalIncomeValue}&partner=${isCouple ? 1 : 0}&partnerInkomen=${partnerIncome}`
          : "/hypotheek-calculator/";
    }
  }

  function updateUrl() {
    const params = new URLSearchParams(window.location.search);
    const income = parseFloat(incomeInput.value) || 0;
    const rent = parseFloat(rentInput.value) || 0;
    const partnerIncome = parseFloat(partnerIncomeInput.value) || 0;
    const vermogen = parseFloat(vermogenInput.value) || 0;
    const kinderen = parseInt(kinderenInput.value, 10) || 0;

    if (income > 0) params.set("inkomen", income.toString());
    else params.delete("inkomen");

    if (rent > 0) params.set("huur", rent.toString());
    else params.delete("huur");

    params.set("partner", household === "couple" ? "1" : "0");

    if (household === "couple" && partnerIncome > 0) params.set("partnerInkomen", partnerIncome.toString());
    else params.delete("partnerInkomen");

    if (vermogen > 0) params.set("vermogen", vermogen.toString());
    else params.delete("vermogen");

    if (kinderen > 0) params.set("kinderen", kinderen.toString());
    else params.delete("kinderen");

    const newUrl = `${window.location.pathname}?${params.toString()}`;
    window.history.replaceState(null, "", newUrl);
  }

  function calculate() {
    const income = parseFloat(incomeInput.value) || 0;
    const rent = parseFloat(rentInput.value) || 0;
    const partnerIncome = parseFloat(partnerIncomeInput.value) || 0;
    const isCouple = household === "couple";

    const result = calculateAllowances({
      income,
      partnerIncome,
      isCouple,
      rent,
    });

    if (!result.valid) {
      errorBox.style.display = "block";
      hero.textContent = "—";
      detailIncome.textContent = "—";
      detailHousehold.textContent = "—";
      detailRent.textContent = "—";
      detailRentBenefit.textContent = "—";
      detailZorgBenefit.textContent = "—";
      detailTotalMonthly.textContent = "—";
      detailTotalYearly.textContent = "—";
      return;
    }

    errorBox.style.display = "none";

    const totalMonthly = result.rentBenefit + result.zorgBenefit;
    const totalYearly = totalMonthly * 12;

    hero.textContent = formatEuro(totalMonthly, 0);
    detailIncome.textContent = formatEuro(income, 0);
    detailHousehold.textContent = isCouple ? "Met partner" : "Alleenstaand";
    detailRent.textContent = formatEuro(rent, 0);
    detailRentBenefit.textContent = formatEuro(result.rentBenefit, 0);
    detailZorgBenefit.textContent = formatEuro(result.zorgBenefit, 0);
    detailTotalMonthly.textContent = formatEuro(totalMonthly, 0);
    detailTotalYearly.textContent = formatEuro(totalYearly, 0);

    updateUseCases(income, result.totalIncome);
    updateFinancialJourney(income, partnerIncome, result.totalIncome, isCouple);
    updateUrl();
  }

  function applyUrlParams() {
    const params = new URLSearchParams(window.location.search);
    const income = params.get("inkomen");
    const rent = params.get("huur");
    const partner = params.get("partner");
    const partnerIncome = params.get("partnerInkomen");
    const vermogen = params.get("vermogen");
    const kinderen = params.get("kinderen");

    if (income !== null) incomeInput.value = income;
    if (rent !== null) rentInput.value = rent;
    if (partner !== null) {
      household = partner === "1" ? "couple" : "single";
      document.querySelectorAll("#household button").forEach((btn) => {
        const button = btn as HTMLButtonElement;
        button.classList.toggle("active", button.dataset.type === household);
      });
      partnerIncomeGroup.style.display = household === "couple" ? "block" : "none";
    }
    if (partnerIncome !== null) partnerIncomeInput.value = partnerIncome;
    if (vermogen !== null) vermogenInput.value = vermogen;
    if (kinderen !== null) kinderenInput.value = kinderen;
  }

  function initQuickChips() {
    document.querySelectorAll(".quick-chip").forEach((btn) => {
      btn.addEventListener("click", () => {
        const amount = (btn as HTMLElement).dataset.amount;
        if (amount) {
          incomeInput.value = amount;
          incomeInput.focus();
          calculate();
        }
      });
    });
  }

  function initCopyLink() {
    copyLinkBtn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const textEl = copyLinkBtn.querySelector(".copy-link-text") as HTMLElement;
        const originalText = textEl.textContent || "Deel deze berekening";
        textEl.textContent = "Link gekopieerd";
        copyLinkBtn.classList.add("copy-link-success");
        setTimeout(() => {
          textEl.textContent = originalText;
          copyLinkBtn.classList.remove("copy-link-success");
        }, 2000);
      } catch (err) {
        console.error("Kon link niet kopiëren", err);
      }
    });
  }

  function initHouseholdButtons() {
    document.getElementById("household")!.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button") as HTMLButtonElement | null;
      if (!btn) return;
      document.querySelectorAll("#household button").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      household = btn.dataset.type as "single" | "couple";
      partnerIncomeGroup.style.display = household === "couple" ? "block" : "none";
      calculate();
    });
  }

  applyUrlParams();
  calculate();
  initQuickChips();
  initCopyLink();
  initHouseholdButtons();

  incomeInput.addEventListener("input", calculate);
  rentInput.addEventListener("input", calculate);
  partnerIncomeInput.addEventListener("input", calculate);
  vermogenInput.addEventListener("input", calculate);
  kinderenInput.addEventListener("input", calculate);
  berekenBtn.addEventListener("click", calculate);
  incomeInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      calculate();
      incomeInput.blur();
    }
  });
</script>

<style>
  .input-note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    background: #fff8e1;
    border: 1px solid #f9a825;
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .calc-content {
    padding: 1.5rem;
  }

  .calc-content h2,
  .calc-content .page-title {
    font-size: 1.3rem;
    font-weight: 700;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .calc-content .page-title {
    font-size: 1.75rem;
    margin-top: 0;
  }

  .calc-content p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .calc-content ul {
    margin-left: 1.25rem;
    margin-bottom: 1rem;
  }

  .calc-content li {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .calc-error {
    color: #b91c1c;
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .result-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

