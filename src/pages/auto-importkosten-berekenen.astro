<script>
  import { calculateImportCosts } from "../lib/calculators/import-costs";
  import { formatEuro } from "../lib/format/currency";
  import { getRecommendations } from "../lib/recommendations/engine";
  import { updateFinancialJourney } from "../lib/recommendations/client";

  const purchasePriceInput = document.getElementById("purchasePrice") as HTMLInputElement;
  const estimatedBpmInput = document.getElementById("estimatedBpm") as HTMLInputElement;
  const rdwCostsInput = document.getElementById("rdwCosts") as HTMLInputElement;
  const transportCostsInput = document.getElementById("transportCosts") as HTMLInputElement;
  const exportCostsInput = document.getElementById("exportCosts") as HTMLInputElement;
  const inspectionCostsInput = document.getElementById("inspectionCosts") as HTMLInputElement;
  const plateCostsInput = document.getElementById("plateCosts") as HTMLInputElement;
  const otherCostsInput = document.getElementById("otherCosts") as HTMLInputElement;
  const nlPriceInput = document.getElementById("nlPrice") as HTMLInputElement;
  const purchaseCountryInput = document.getElementById("purchaseCountry") as HTMLSelectElement;
  const vehicleTypeGroup = document.getElementById("vehicleType") as HTMLElement;

  const hero = document.querySelector("[data-calc-result-hero]") as HTMLElement;
  const errorBox = document.getElementById("calcError") as HTMLElement;
  const berekenBtn = document.getElementById("berekenBtn") as HTMLButtonElement;
  const copyLinkBtn = document.getElementById("copyLinkBtn") as HTMLButtonElement;
  const comparisonSection = document.getElementById("comparisonSection") as HTMLElement;
  const financialJourney = document.querySelector(".calc-financial-journey") as HTMLElement;

  const detailPurchase = document.getElementById("detailPurchase")!;
  const detailBpm = document.getElementById("detailBpm")!;
  const detailRdw = document.getElementById("detailRdw")!;
  const detailTransport = document.getElementById("detailTransport")!;
  const detailExport = document.getElementById("detailExport")!;
  const detailInspection = document.getElementById("detailInspection")!;
  const detailPlates = document.getElementById("detailPlates")!;
  const detailOther = document.getElementById("detailOther")!;
  const detailTotal = document.getElementById("detailTotal")!;
  const detailNlPrice = document.getElementById("detailNlPrice")!;
  const detailDifference = document.getElementById("detailDifference")!;
  const differenceLabel = document.getElementById("differenceLabel")!;

  let vehicleType = "auto";

  function getInputs() {
    return {
      vehicleType,
      purchasePrice: parseFloat(purchasePriceInput.value) || 0,
      estimatedBpm: parseFloat(estimatedBpmInput.value) || 0,
      rdwCosts: parseFloat(rdwCostsInput.value) || 0,
      transportCosts: parseFloat(transportCostsInput.value) || 0,
      exportCosts: parseFloat(exportCostsInput.value) || 0,
      inspectionCosts: parseFloat(inspectionCostsInput.value) || 0,
      plateCosts: parseFloat(plateCostsInput.value) || 0,
      otherCosts: parseFloat(otherCostsInput.value) || 0,
      nlPrice: parseFloat(nlPriceInput.value) || 0,
    };
  }

  function updateUrl() {
    const inputs = getInputs();
    const url = new URL(window.location.href);

    url.searchParams.set("voertuig", inputs.vehicleType);
    url.searchParams.set("land", purchaseCountryInput.value);

    const setParam = (name: string, value: number) => {
      if (value > 0) url.searchParams.set(name, String(value));
      else url.searchParams.delete(name);
    };

    setParam("aankoopprijs", inputs.purchasePrice);
    setParam("bpm", inputs.estimatedBpm);
    setParam("rdw", inputs.rdwCosts);
    setParam("transport", inputs.transportCosts);
    setParam("export", inputs.exportCosts);
    setParam("keuring", inputs.inspectionCosts);
    setParam("kenteken", inputs.plateCosts);
    setParam("overig", inputs.otherCosts);
    setParam("nl", inputs.nlPrice);

    window.history.replaceState({}, "", url.toString());
  }

  function calculate() {
    const inputs = getInputs();
    const result = calculateImportCosts(inputs);

    if (!result.valid) {
      errorBox.style.display = "block";
      hero.textContent = "—";
      return;
    }

    errorBox.style.display = "none";

    hero.textContent = formatEuro(result.totalCost, 0);
    detailPurchase.textContent = formatEuro(result.purchasePrice, 0);
    detailBpm.textContent = formatEuro(result.estimatedBpm, 0);
    detailRdw.textContent = formatEuro(result.rdwCosts, 0);
    detailTransport.textContent = formatEuro(result.transportCosts, 0);
    detailExport.textContent = formatEuro(result.exportCosts, 0);
    detailInspection.textContent = formatEuro(result.inspectionCosts, 0);
    detailPlates.textContent = formatEuro(result.plateCosts, 0);
    detailOther.textContent = formatEuro(result.otherCosts, 0);
    detailTotal.textContent = formatEuro(result.totalCost, 0);

    if (result.nlPrice && result.nlPrice > 0) {
      comparisonSection.style.display = "block";
      detailNlPrice.textContent = formatEuro(result.nlPrice, 0);
      differenceLabel.textContent = result.differenceLabel ?? "Verschil";
      detailDifference.textContent = formatEuro(Math.abs(result.priceDifference ?? 0), 0);
    } else {
      comparisonSection.style.display = "none";
    }

    if (financialJourney) {
      const recs = getRecommendations({
        calculator: "auto-importkosten",
        values: inputs,
        result,
      });
      updateFinancialJourney(financialJourney, recs);
    }

    updateUrl();
  }

  function applyUrlParams() {
    const url = new URL(window.location.href);
    const setValue = (param: string, input: HTMLInputElement) => {
      const value = url.searchParams.get(param);
      if (value !== null) input.value = value;
    };

    setValue("aankoopprijs", purchasePriceInput);
    setValue("bpm", estimatedBpmInput);
    setValue("rdw", rdwCostsInput);
    setValue("transport", transportCostsInput);
    setValue("export", exportCostsInput);
    setValue("keuring", inspectionCostsInput);
    setValue("kenteken", plateCostsInput);
    setValue("overig", otherCostsInput);
    setValue("nl", nlPriceInput);

    const land = url.searchParams.get("land");
    if (land !== null) purchaseCountryInput.value = land;

    const voertuig = url.searchParams.get("voertuig");
    if (voertuig === "auto" || voertuig === "camper") {
      vehicleType = voertuig;
      document.querySelectorAll("#vehicleType button").forEach((b) => {
        const btn = b as HTMLButtonElement;
        btn.classList.toggle("active", btn.dataset.type === vehicleType);
      });
    }
  }

  function initVehicleType() {
    vehicleTypeGroup.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button") as HTMLButtonElement | null;
      if (!btn || !btn.dataset.type) return;
      document.querySelectorAll("#vehicleType button").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      vehicleType = btn.dataset.type;
      calculate();
    });
  }

  function initPresetChips() {
    document.querySelectorAll(".quick-chip").forEach((btn) => {
      btn.addEventListener("click", () => {
        const preset = (btn as HTMLElement).dataset.preset;
        if (!preset) return;
        const data = JSON.parse(preset);
        purchasePriceInput.value = data.purchasePrice ?? 0;
        estimatedBpmInput.value = data.estimatedBpm ?? 0;
        rdwCostsInput.value = data.rdwCosts ?? 0;
        transportCostsInput.value = data.transportCosts ?? 0;
        exportCostsInput.value = data.exportCosts ?? 0;
        inspectionCostsInput.value = data.inspectionCosts ?? 0;
        plateCostsInput.value = data.plateCosts ?? 0;
        otherCostsInput.value = data.otherCosts ?? 0;
        calculate();
      });
    });
  }

  function initCopyLink() {
    copyLinkBtn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const textEl = copyLinkBtn.querySelector(".copy-link-text") as HTMLElement;
        const originalText = textEl.textContent || "Deel deze berekening";
        textEl.textContent = "Link gekopieerd";
        copyLinkBtn.classList.add("copy-link-success");
        setTimeout(() => {
          textEl.textContent = originalText;
          copyLinkBtn.classList.remove("copy-link-success");
        }, 2000);
      } catch (err) {
        console.error("Kon link niet kopiëren", err);
      }
    });
  }

  applyUrlParams();
  initVehicleType();
  initPresetChips();
  initCopyLink();

  [
    purchasePriceInput,
    estimatedBpmInput,
    rdwCostsInput,
    transportCostsInput,
    exportCostsInput,
    inspectionCostsInput,
    plateCostsInput,
    otherCostsInput,
    nlPriceInput,
  ].forEach((input) => {
    input.addEventListener("input", calculate);
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        calculate();
        input.blur();
      }
    });
  });

  purchaseCountryInput.addEventListener("change", calculate);
  berekenBtn.addEventListener("click", calculate);

  calculate();
</script>

