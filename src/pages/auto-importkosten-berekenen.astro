---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdSlot from "../components/AdSlot.astro";
import CrossSellCards from "../components/CrossSellCards.astro";
import CalculatorShell from "../components/calculator/CalculatorShell.astro";
import InputPanel from "../components/calculator/InputPanel.astro";
import ResultPanel from "../components/calculator/ResultPanel.astro";
import UseCasesPanel from "../components/calculator/UseCasesPanel.astro";
import FaqAccordion from "../components/calculator/FaqAccordion.astro";
import ToolFooter from "../components/calculator/ToolFooter.astro";
import SourceCards from "../components/SourceCards.astro";
import FinancialJourney from "../components/calculator/FinancialJourney.astro";
import HowToSchema from "../components/calculator/HowToSchema.astro";
import InlineSources from "../components/calculator/InlineSources.astro";
import { calculateImportCosts } from "../lib/calculators/import-costs";
import { getRecommendations } from "../lib/recommendations/engine";
import { formatEuro } from "../lib/format/currency";

const title = "Auto importkosten berekenen — Auto of camper importeren | Calculatieloket.nl";
const description = "Bereken een indicatie van de kosten om een auto of camper te importeren naar Nederland. Inclusief aankoopprijs, bpm, RDW, transport en overige kosten.";

const defaultVehicleType = "auto";
const defaultPurchaseCountry = "Duitsland";
const defaultPurchasePrice = 15000;
const defaultEstimatedBpm = 3000;
const defaultRdwCosts = 150;
const defaultTransportCosts = 400;
const defaultExportCosts = 150;
const defaultInspectionCosts = 150;
const defaultPlateCosts = 50;
const defaultOtherCosts = 100;
const defaultNlPrice = 0;

const initialResult = calculateImportCosts({
  vehicleType: defaultVehicleType,
  purchasePrice: defaultPurchasePrice,
  estimatedBpm: defaultEstimatedBpm,
  rdwCosts: defaultRdwCosts,
  transportCosts: defaultTransportCosts,
  exportCosts: defaultExportCosts,
  inspectionCosts: defaultInspectionCosts,
  plateCosts: defaultPlateCosts,
  otherCosts: defaultOtherCosts,
  nlPrice: defaultNlPrice,
});

const initialRecommendations = getRecommendations({
  calculator: "auto-importkosten",
  values: {
    vehicleType: defaultVehicleType,
    purchasePrice: defaultPurchasePrice,
    estimatedBpm: defaultEstimatedBpm,
    rdwCosts: defaultRdwCosts,
    transportCosts: defaultTransportCosts,
    exportCosts: defaultExportCosts,
    inspectionCosts: defaultInspectionCosts,
    plateCosts: defaultPlateCosts,
    otherCosts: defaultOtherCosts,
    nlPrice: defaultNlPrice,
  },
  result: initialResult,
});

const lastUpdated = "1 juli 2026";

const quickPresets = [
  {
    label: "Lage kosten",
    data: {
      purchasePrice: 10000,
      estimatedBpm: 2000,
      rdwCosts: 100,
      transportCosts: 200,
      exportCosts: 100,
      inspectionCosts: 100,
      plateCosts: 50,
      otherCosts: 50,
    },
  },
  {
    label: "Gemiddeld",
    data: {
      purchasePrice: 15000,
      estimatedBpm: 3000,
      rdwCosts: 150,
      transportCosts: 400,
      exportCosts: 150,
      inspectionCosts: 150,
      plateCosts: 50,
      otherCosts: 100,
    },
  },
  {
    label: "Hoog",
    data: {
      purchasePrice: 30000,
      estimatedBpm: 6000,
      rdwCosts: 300,
      transportCosts: 800,
      exportCosts: 300,
      inspectionCosts: 300,
      plateCosts: 100,
      otherCosts: 300,
    },
  },
];

const useCases = [
  {
    id: "btw",
    title: "BTW Calculator",
    description: "Reken btw over bedragen.",
    href: "/btw-calculator/",
    accent: "#2563eb",
  },
  {
    id: "zzp",
    title: "ZZP Calculator",
    description: "Handig als je zakelijke kosten of uurtarief wilt inschatten.",
    href: "/zzp-calculator/",
    accent: "#7c3aed",
  },
  {
    id: "bruto-netto",
    title: "Bruto netto 2026",
    description: "Bereken een indicatie van je nettoloon in 2026.",
    href: "/bruto-netto-2026/",
    accent: "#2563eb",
  },
  {
    id: "hypotheek",
    title: "Hypotheek Calculator",
    description: "Bereken een indicatie van je hypotheeklasten.",
    href: "/hypotheek-calculator/",
    accent: "#d97706",
  },
];

const sources = [
  {
    label: "RDW",
    title: "Voertuig invoeren vanuit een Europees land",
    description: "Stappen en eisen voor het invoeren van een voertuig uit de EU.",
    href: "https://www.rdw.nl/invoeren-exporteren-doorvoeren/invoeren-binnen-europa",
  },
  {
    label: "RDW",
    title: "Invoeren, exporteren of doorvoeren",
    description: "Overzicht van de RDW-procedures rond in- en uitvoer van voertuigen.",
    href: "https://www.rdw.nl/invoeren-exporteren-doorvoeren",
  },
  {
    label: "Belastingdienst",
    title: "Bpm",
    description: "Algemene informatie over de bpm bij voertuigen.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/nl/bpm/bpm",
  },
  {
    label: "Belastingdienst",
    title: "Aangifte bpm bij aanvraag Nederlands kenteken",
    description: "Hoe je bpm-aangifte doet bij een aanvraag voor een Nederlands kenteken.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/nl/bpm/content/online-aangifte-bpm",
  },
  {
    label: "Belastingdienst",
    title: "Hoe kan ik de bpm berekenen?",
    description: "Uitleg over het berekenen van de bpm.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/nl/bpm/content/hoe-bpm-berekenen",
  },
  {
    label: "Belastingdienst",
    title: "Bpm berekenen voor een personenauto",
    description: "Berekeningswijze van de bpm voor personenauto's.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/nl/bpm/content/personenauto-bpm-tarief-berekenen",
  },
  {
    label: "Belastingdienst",
    title: "Hoe bereken ik de bpm voor een kampeerauto?",
    description: "Berekeningswijze van de bpm voor kampeerauto's.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/nl/bpm/content/kampeerauto-bpm-tarief-berekenen",
  },
  {
    label: "Rijksoverheid",
    title: "Auto uit het buitenland importeren",
    description: "Algemene uitleg over het importeren van een auto naar Nederland.",
    href: "https://www.rijksoverheid.nl/vraag-en-antwoord/auto/hoe-kan-ik-een-auto-uit-het-buitenland-in-nederland-importeren-invoeren",
  },
];

const faq = [
  {
    question: "Wat kost een auto importeren naar Nederland?",
    answer: "De kosten vari&euml;ren sterk per voertuig. Naast de aankoopprijs moet je rekening houden met bpm, RDW-kosten, transport, exportkenteken, keuring en kentekenplaten. Gebruik de calculator bovenaan deze pagina voor een indicatie.",
  },
  {
    question: "Hoe bereken je importkosten voor een auto?",
    answer: "Tel de aankoopprijs, geschatte bpm, RDW-kosten, transport, exportkenteken, aankoopkeuring, kentekenplaten en overige kosten bij elkaar op. De bpm moet je apart inschatten via de offici&euml;le tool van de Belastingdienst.",
  },
  {
    question: "Moet ik bpm betalen bij auto importeren?",
    answer: "Ja, bij het importeren van een personenauto, motor of camper naar Nederland moet je in de meeste gevallen bpm betalen. De hoogte hangt af van het type voertuig en de CO2-uitstoot. Voor elektrische auto's geldt een vrijstelling.",
  },
  {
    question: "Kan ik de bpm automatisch berekenen?",
    answer: "Deze calculator berekent de bpm niet automatisch. Je vult zelf een geschatte bpm in. Gebruik de <a href=\"https://www.belastingdienst.nl/wps/wcm/connect/nl/bpm/content/hoe-bpm-berekenen\" target=\"_blank\" rel=\"noopener\">offici&euml;le bpm-tool van de Belastingdienst</a> voor een nauwkeurige berekening.",
  },
  {
    question: "Wat kost een camper importeren?",
    answer: "De kosten voor het importeren van een camper zijn vergelijkbaar met een auto, maar de bpm wordt anders berekend. Ook kunnen RDW-eisen afwijken. Raadpleeg de Belastingdienst-pagina over bpm voor kampeerauto's.",
  },
  {
    question: "Is een auto importeren uit Duitsland altijd goedkoper?",
    answer: "Niet altijd. Hoewel de aankoopprijs in Duitsland vaak lager ligt, kunnen bpm, transport en keuringskosten het voordeel tenietdoen. Maak altijd een volledige kostenindicatie voordat je een aankoopbeslissing neemt.",
  },
  {
    question: "Hoe zit het met btw bij import uit de EU?",
    answer: "Bij aankoop van een particulier in de EU betaal je meestal geen btw bij import. Bij aankoop via een buitenlands bedrijf kunnen btw-regels anders uitpakken. Raadpleeg de Belastingdienst voor jouw specifieke situatie.",
  },
  {
    question: "Kan ik deze berekening gebruiken voor een aankoopbeslissing?",
    answer: "Deze berekening is een indicatie. Gebruik hem als hulpmiddel, maar doe altijd een offici&euml;le bpm-berekening en raadpleeg de RDW en Belastingdienst voor actuele tarieven en regels.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://calculatieloket.nl/",
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Auto importkosten",
      "item": "https://calculatieloket.nl/auto-importkosten-berekenen/",
    },
  ],
};
---

<BaseLayout title={title} description={description} containerClass="container-wide">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <HowToSchema
    slot="head"
    name="Auto importkosten berekenen"
    description="Stappen om een indicatie te krijgen van de kosten voor het importeren van een auto of camper naar Nederland."
    totalTime="PT2M"
    steps={[
      { name: "Kies voertuigtype en aankoopland", text: "Selecteer auto of camper en het land waar je het voertuig koopt." },
      { name: "Vul de aankoopprijs in", text: "Voer het bedrag in dat je in het buitenland voor het voertuig betaalt." },
      { name: "Vul de geschatte bpm in", text: "Gebruik de officiële bpm-tool van de Belastingdienst om een inschatting te maken." },
      { name: "Vul transport, RDW en keuringskosten in", text: "Voer de verwachte kosten voor transport, kenteken, keuring en exportkenteken in." },
      { name: "Bekijk de totale importkosten", text: "De calculator toont een indicatie van de totale kosten, inclusief een vergelijking met een Nederlandse prijs." },
    ]}
  />

  <AdSlot slot="1234567899" format="auto" style="min-height:100px" />

  <CalculatorShell
    title="Auto importkosten berekenen"
    subtitle="Bereken een indicatie van de totale kosten voor het importeren van een auto of camper naar Nederland."
  >
    <InputPanel title="Jouw situatie" slot="input">
      <p class="calc-group-title">Voertuig</p>

      <div class="form-group">
        <label>Voertuigtype</label>
        <div class="radio-group" id="vehicleType">
          <button type="button" data-type="auto" class={defaultVehicleType === "auto" ? "active" : ""}>Auto</button>
          <button type="button" data-type="camper" class={defaultVehicleType === "camper" ? "active" : ""}>Camper</button>
        </div>
      </div>

      <div class="form-group">
        <label for="purchaseCountry">Aankoopland</label>
        <select id="purchaseCountry">
          <option value="Duitsland" selected={defaultPurchaseCountry === "Duitsland"}>Duitsland</option>
          <option value="Frankrijk" selected={defaultPurchaseCountry === "Frankrijk"}>Frankrijk</option>
          <option value="België" selected={defaultPurchaseCountry === "België"}>België</option>
          <option value="Spanje" selected={defaultPurchaseCountry === "Spanje"}>Spanje</option>
          <option value="Anders" selected={defaultPurchaseCountry === "Anders"}>Anders</option>
        </select>
      </div>

      <p class="calc-group-title">Aankoop en bpm</p>

      <div class="form-group">
        <label for="purchasePrice">Aankoopprijs buitenland</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="purchasePrice" value={defaultPurchasePrice} min="0" step="1" />
        </div>
      </div>

      <div class="form-group">
        <label for="estimatedBpm">Geschatte bpm <span class="hint">(zelf invullen)</span></label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="estimatedBpm" value={defaultEstimatedBpm} min="0" step="1" />
        </div>
      </div>

      <p class="calc-field-hint">Bpm wordt niet automatisch berekend. Controleer de <a href="https://www.belastingdienst.nl/wps/wcm/connect/nl/bpm/content/hoe-bpm-berekenen" target="_blank" rel="noopener">bpm-informatie van de Belastingdienst</a>.</p>

      <p class="calc-group-title">Importkosten</p>

      <div class="form-group">
        <label for="rdwCosts">RDW-/kenteken-/keuringskosten</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="rdwCosts" value={defaultRdwCosts} min="0" step="1" />
        </div>
      </div>

      <div class="form-group">
        <label for="transportCosts">Transport- of ophaalkosten</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="transportCosts" value={defaultTransportCosts} min="0" step="1" />
        </div>
      </div>

      <div class="form-group">
        <label for="exportCosts">Exportkenteken / tijdelijke verzekering</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="exportCosts" value={defaultExportCosts} min="0" step="1" />
        </div>
      </div>

      <div class="form-group">
        <label for="inspectionCosts">Aankoopkeuring</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="inspectionCosts" value={defaultInspectionCosts} min="0" step="1" />
        </div>
      </div>

      <div class="form-group">
        <label for="plateCosts">Kentekenplaten</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="plateCosts" value={defaultPlateCosts} min="0" step="1" />
        </div>
      </div>

      <div class="form-group">
        <label for="otherCosts">Overige kosten</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="otherCosts" value={defaultOtherCosts} min="0" step="1" />
        </div>
      </div>

      <p class="calc-group-title">Vergelijking met Nederlandse prijs</p>
      <div class="form-group">
        <label for="nlPrice">Vergelijkbare Nederlandse prijs <span class="hint">(optioneel)</span></label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="nlPrice" value={defaultNlPrice || ""} min="0" step="1" />
        </div>
      </div>

      <div class="quick-chips">
        <span class="quick-chips-label">Snel scenario:</span>
        {quickPresets.map((preset) => (
          <button type="button" class="quick-chip" data-preset={JSON.stringify(preset.data)}>
            {preset.label}
          </button>
        ))}
      </div>

      <button id="berekenBtn" class="btn btn-primary btn-lg" style="width:100%">Bereken importkosten</button>
      <p class="calc-error" id="calcError" style="display:none;">Vul een geldige aankoopprijs in (hoger dan 0).</p>

      <p class="bpm-waarschuwing">Bpm, btw en keuringskosten kunnen per voertuig en situatie verschillen. Controleer altijd de offici&euml;le informatie van RDW en Belastingdienst.</p>
    </InputPanel>

    <ResultPanel
      slot="result"
      title="Importkosten indicatie"
      heroLabel="Totale importkosten"
      heroValue={formatEuro(initialResult.totalCost, 0)}
      heroSubtext="Indicatie op basis van ingevoerde kosten"
      badge="Indicatie"
    >
      <div class="result-meta">
        <span class="meta-badge">Bijgewerkt: 2026</span>
        <span class="meta-badge">Bron: RDW / Belastingdienst</span>
      </div>

      <div class="result-row"><span class="label">Aankoopprijs buitenland</span><span class="value" id="detailPurchase">{formatEuro(initialResult.purchasePrice, 0)}</span></div>
      <div class="result-row"><span class="label">Geschatte bpm</span><span class="value" id="detailBpm">{formatEuro(initialResult.estimatedBpm, 0)}</span></div>
      <div class="result-row"><span class="label">RDW/kenteken/keuring</span><span class="value" id="detailRdw">{formatEuro(initialResult.rdwCosts, 0)}</span></div>
      <div class="result-row"><span class="label">Transport/ophalen</span><span class="value" id="detailTransport">{formatEuro(initialResult.transportCosts, 0)}</span></div>
      <div class="result-row"><span class="label">Exportkenteken/verzekering</span><span class="value" id="detailExport">{formatEuro(initialResult.exportCosts, 0)}</span></div>
      <div class="result-row"><span class="label">Aankoopkeuring</span><span class="value" id="detailInspection">{formatEuro(initialResult.inspectionCosts, 0)}</span></div>
      <div class="result-row"><span class="label">Kentekenplaten</span><span class="value" id="detailPlates">{formatEuro(initialResult.plateCosts, 0)}</span></div>
      <div class="result-row"><span class="label">Overige kosten</span><span class="value" id="detailOther">{formatEuro(initialResult.otherCosts, 0)}</span></div>
      <div class="result-divider"></div>
      <div class="result-row result-row-total"><span class="label">Totaal</span><span class="value" id="detailTotal">{formatEuro(initialResult.totalCost, 0)}</span></div>

      <div id="comparisonSection" style={initialResult.nlPrice && initialResult.nlPrice > 0 ? undefined : "display:none;"}>
        <div class="result-divider"></div>
        <div class="result-row"><span class="label">Vergelijkbare NL prijs</span><span class="value" id="detailNlPrice">{formatEuro(initialResult.nlPrice ?? 0, 0)}</span></div>
        <div class="result-row"><span class="label" id="differenceLabel">{initialResult.differenceLabel ?? "Verschil"}</span><span class="value" id="detailDifference">{formatEuro(Math.abs(initialResult.priceDifference ?? 0), 0)}</span></div>
      </div>

      <button class="copy-link-btn" id="copyLinkBtn" type="button" slot="actions">
        <span class="copy-link-icon">🔗</span>
        <span class="copy-link-text">Deel deze berekening</span>
      </button>

      <FinancialJourney recommendations={initialRecommendations} />

      <InlineSources title="Gebruikte bronnen" items={sources} />
    </ResultPanel>

    <UseCasesPanel title="Wat kun je hiermee?" items={useCases} slot="useCases" />

    <SourceCards title="Bronnen" items={sources} slot="sources" />

    <FaqAccordion title="Veelgestelde vragen" items={faq} slot="faq" />

    <ToolFooter
      slot="footer"
      disclaimer="Deze berekening is een indicatie. Bpm, btw en keuringskosten kunnen per voertuig en situatie verschillen. Controleer belangrijke bedragen altijd via de officiële bronnen van RDW en Belastingdienst. Aan deze indicatie kunnen geen rechten worden ontleend. Raadpleeg bij twijfel een auto-importspecialist."
      lastUpdated={lastUpdated}
    />
  </CalculatorShell>

  <div class="calculator-card calc-content" id="calculator-content">
    <p class="badge-indicatie">Indicatie 2026</p>

    <h2 class="page-title">Auto importkosten berekenen</h2>
    <p>Bereken een indicatie van de totale kosten voor het importeren van een auto of camper naar Nederland. De uitkomst is een indicatie. Bpm, btw en keuringskosten kunnen per voertuig en situatie verschillen. Gebruik ook de <a href="/btw-calculator/">BTW Calculator</a>, <a href="/zzp-calculator/">ZZP Calculator</a>, <a href="/bruto-netto-2026/">bruto-netto calculator</a> of <a href="/hypotheek-calculator/">hypotheek calculator</a>.</p>

    <h2>Welke kosten betaal je bij auto importeren?</h2>
    <p>Bij het importeren van een auto of camper naar Nederland komen meerdere kostenposten kijken. Hieronder een overzicht:</p>
    <ul class="calc-list">
      <li><strong>Aankoopprijs:</strong> het bedrag dat je in het buitenland betaalt voor het voertuig.</li>
      <li><strong>Bpm:</strong> de belasting van personenauto's en motorrijwielen. Dit kan een forse kostenpost zijn, afhankelijk van het voertuigtype en de CO2-uitstoot.</li>
      <li><strong>RDW-keuring/kenteken:</strong> na import moet het voertuig gekeurd worden door de RDW en op Nederlands kenteken worden gezet.</li>
      <li><strong>Transport of ophalen:</strong> kosten om het voertuig van het buitenland naar Nederland te krijgen.</li>
      <li><strong>Exportkenteken/tijdelijke verzekering:</strong> om het voertuig legaal naar Nederland te rijden, heb je vaak een exportkenteken en tijdelijke verzekering nodig.</li>
      <li><strong>Aankoopkeuring:</strong> het is verstandig om het voertuig voor aankoop technisch te laten keuren.</li>
      <li><strong>Kentekenplaten:</strong> nieuwe Nederlandse kentekenplaten na registratie.</li>
      <li><strong>Overige kosten:</strong> denk aan tol, brandstof, administratiekosten of een verblijf in het buitenland.</li>
    </ul>

    <h2>Hoe zit het met bpm bij import?</h2>
    <p>Bpm (belasting van personenauto's en motorrijwielen) kan een grote kostenpost zijn bij het importeren van een auto. De hoogte hangt af van:</p>
    <ul class="calc-list">
      <li>Het type voertuig (personenauto, camper, motor)</li>
      <li>De CO2-uitstoot (voor personenauto's)</li>
      <li>De catalogusprijs en leeftijd van het voertuig</li>
    </ul>
    <p>Deze calculator berekent de bpm <strong>niet automatisch</strong>. Vul zelf een geschatte bpm in op basis van de offici&euml;le bpm-tool van de Belastingdienst. Voor campers en kampeerauto's gelden aparte regels.</p>

    <h2>Hoe zit het met btw bij import?</h2>
    <p>Bij de import van een voertuig uit een ander EU-land is de btw-situatie afhankelijk van de verkoper en de leeftijd van het voertuig:</p>
    <ul class="calc-list">
      <li>Bij aankoop van een <strong>particulier</strong> in de EU betaal je meestal geen btw in het land van aankoop en ook niet bij import in Nederland.</li>
      <li>Bij aankoop van een <strong>bedrijf</strong> kunnen btw-regels anders uitpakken, vooral bij nieuwe of bijna nieuwe voertuigen.</li>
      <li>Bij <strong>gebruikte voertuigen</strong> kan de margeregeling van toepassing zijn.</li>
    </ul>
    <p>Gebruik onze <a href="/btw-calculator/">BTW Calculator</a> of <a href="/btw-inclusief-exclusief/">BTW inclusief/exclusief tool</a> voor btw-berekeningen. Raadpleeg bij twijfel de Belastingdienst.</p>

    <h2>Auto importeren uit Duitsland of Frankrijk</h2>
    <p>Duitsland en Frankrijk zijn populaire landen om een auto te importeren. De aankoopprijs kan daar lager lijken, maar de totale importkosten bepalen of het echt interessant is. Controleer altijd:</p>
    <ul class="calc-list">
      <li>De geschatte bpm via de offici&euml;le Belastingdienst-tool</li>
      <li>Transportkosten: Duitsland is dichterbij dan Frankrijk, dus transport kan goedkoper zijn</li>
      <li>Keuringseisen: elk land heeft eigen technische eisen; controleer of het voertuig aan de Nederlandse eisen voldoet</li>
      <li>Administratieve rompslomp: exportdocumenten, T&Uuml;V/CT-keuring, RDW-aanvraag</li>
    </ul>
    <p>Of importeren uiteindelijk voordeliger is, hangt af van het specifieke voertuig. Gebruik deze calculator als indicatie.</p>

    <h2>Camper importeren: extra aandachtspunten</h2>
    <p>Voor campers en kampeerauto's gelden bij import extra regels:</p>
    <ul class="calc-list">
      <li>De bpm voor campers wordt anders berekend dan voor personenauto's</li>
      <li>De RDW-keuring kan aanvullende eisen stellen aan de inrichting van de camper</li>
      <li>Controleer of het voertuig voldoet aan de Nederlandse definitie van een kampeerauto</li>
      <li>Raadpleeg de specifieke Belastingdienst-pagina over <a href="https://www.belastingdienst.nl/wps/wcm/connect/nl/bpm/content/kampeerauto-bpm-tarief-berekenen" target="_blank" rel="noopener">bpm voor kampeerauto's</a></li>
    </ul>

    <h2>Voorbeeld importkosten berekenen</h2>
    <p>Stel, je koopt een auto in Duitsland voor <strong>&euro;15.000</strong>. Hieronder een voorbeeld van de totale importkosten:</p>
    <ul class="calc-list">
      <li>Aankoopprijs Duitsland: <strong>&euro;15.000</strong></li>
      <li>Geschatte bpm: <strong>&euro;3.000</strong></li>
      <li>RDW/kenteken/keuring: <strong>&euro;150</strong></li>
      <li>Transport/ophalen: <strong>&euro;400</strong></li>
      <li>Exportkenteken/tijdelijke verzekering: <strong>&euro;150</strong></li>
      <li>Aankoopkeuring: <strong>&euro;150</strong></li>
      <li>Kentekenplaten: <strong>&euro;50</strong></li>
      <li>Overige kosten: <strong>&euro;100</strong></li>
    </ul>
    <p><strong>Totale importkosten: circa &euro;19.000</strong> (indicatie).</p>

    <h2>Veelgemaakte fouten bij auto importeren</h2>
    <ul class="calc-list">
      <li><strong>Alleen naar de aankoopprijs kijken:</strong> de totale kosten kunnen flink oplopen door bpm, transport, keuring en administratie.</li>
      <li><strong>Bpm onderschatten:</strong> de bpm kan hoger uitvallen dan verwacht, vooral bij auto's met een hoge CO2-uitstoot.</li>
      <li><strong>Camperregels gelijkstellen aan gewone auto's:</strong> voor campers gelden andere bpm-berekeningen en RDW-eisen.</li>
      <li><strong>Btw bij nieuwe/bijna nieuwe voertuigen vergeten:</strong> bij aankoop via een buitenlands bedrijf kan btw verschuldigd zijn.</li>
      <li><strong>Transport, exportkenteken en keuring vergeten:</strong> deze kosten kunnen samen enkele honderden euro's bedragen.</li>
      <li><strong>Geen aankoopkeuring doen:</strong> een technische keuring voorkomt verrassingen achteraf.</li>
      <li><strong>Denken dat importeren altijd goedkoper is:</strong> de totale kosten kunnen tegenvallen. Bereken vooraf een indicatie.</li>
    </ul>
  </div>

