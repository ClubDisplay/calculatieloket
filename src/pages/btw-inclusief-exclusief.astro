---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdSlot from "../components/AdSlot.astro";
import CrossSellCards from "../components/CrossSellCards.astro";
import CalculatorShell from "../components/calculator/CalculatorShell.astro";
import InputPanel from "../components/calculator/InputPanel.astro";
import ResultPanel from "../components/calculator/ResultPanel.astro";
import UseCasesPanel from "../components/calculator/UseCasesPanel.astro";
import FaqAccordion from "../components/calculator/FaqAccordion.astro";
import ToolFooter from "../components/calculator/ToolFooter.astro";
import SourceCards from "../components/SourceCards.astro";
import FinancialJourney from "../components/calculator/FinancialJourney.astro";
import { calculateBtw } from "../lib/calculators/btw";
import { getRecommendations } from "../lib/recommendations/engine";
import { formatEuro } from "../lib/format/currency";

const title = "BTW inclusief en exclusief berekenen — 21%, 9% en 0% | Calculatieloket.nl";
const description = "Bereken eenvoudig btw inclusief of exclusief. Kies 21%, 9% of 0% btw en krijg een duidelijke indicatie van het bedrag inclusief btw, exclusief btw en het btw-bedrag.";

const defaultAmount = 100;
const defaultRate = 21;
const defaultDirection: "excl" | "incl" = "excl";

const initialResult = calculateBtw({
  amount: defaultAmount,
  rate: defaultRate,
  direction: defaultDirection === "excl" ? "exclusive_to_inclusive" : "inclusive_to_exclusive",
});

const initialRecommendations = getRecommendations({
  calculator: "btw-inclusief-exclusief",
  values: { amount: defaultAmount, rate: defaultRate, direction: defaultDirection },
  result: initialResult,
});

const heroLabel = defaultDirection === "excl" ? "Bedrag inclusief btw" : "Bedrag exclusief btw";
const heroValue = formatEuro(defaultDirection === "excl" ? initialResult.amountIncl : initialResult.amountExcl, 2);
const heroSubtext = `Gebaseerd op ${defaultRate}% btw over ${formatEuro(defaultAmount, 2)}`;

const lastUpdated = "2 juli 2026";

const quickAmounts = [100, 250, 500, 1000];

const useCases = [
  {
    id: "btw-calculator",
    title: "BTW Calculator",
    description: "Reken {{bedrag}} om met alle tarieven en richtingen.",
    href: "/btw-calculator/",
    accent: "#2563eb",
  },
  {
    id: "terugrekenen",
    title: "BTW terugrekenen",
    description: "Reken {{incl}} van inclusief naar exclusief btw terug.",
    href: "/btw-terugrekenen/",
    accent: "#3b82f6",
  },
  {
    id: "zzp",
    title: "ZZP uurtarief",
    description: "Bereken wat je als ZZP'er moet vragen.",
    href: "/zzp-calculator/",
    accent: "#7c3aed",
  },
  {
    id: "import",
    title: "Auto importkosten",
    description: "Bereken een indicatie van importkosten voor auto of camper.",
    href: "/auto-importkosten-berekenen/",
    accent: "#d97706",
  },
];

const sources = [
  {
    label: "Officiële bron",
    title: "Belastingdienst — BTW-tarieven",
    description: "Actuele btw-tarieven: 21%, 9% en 0%.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/zakelijk/btw/btw_berekenen_aan_uw_klanten/btw_berekenen/btw_tarief/btw_tarief",
  },
  {
    label: "Officiële bron",
    title: "Belastingdienst — Rekenvoorbeeld btw berekenen",
    description: "Voorbeelden van btw berekenen inclusief en exclusief.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/zakelijk/btw/btw_berekenen_aan_uw_klanten/btw_berekenen/rekenvoorbeeld_btw_berekenen",
  },
];

const faq = [
  {
    question: "Hoe bereken je btw inclusief?",
    answer: "Vermenigvuldig het bedrag exclusief btw met (1 + het btw-percentage gedeeld door 100). Bij 21% btw vermenigvuldig je met 1,21. Bij 9% btw met 1,09.",
  },
  {
    question: "Hoe bereken je btw exclusief?",
    answer: "Deel het bedrag inclusief btw door (1 + het btw-percentage gedeeld door 100). Bij 21% btw deel je door 1,21. Bij 9% btw door 1,09.",
  },
  {
    question: "Wat is het verschil tussen inclusief en exclusief btw?",
    answer: "Exclusief btw is het bedrag zónder btw. Inclusief btw is het bedrag mét btw. Het btw-bedrag is het verschil tussen beide. Bedrijven rekenen vaak met exclusieve bedragen; consumenten zien meestal inclusieve prijzen.",
  },
  {
    question: "Hoe reken je 21% btw uit?",
    answer: "Van exclusief naar inclusief: vermenigvuldig met 1,21. Van inclusief naar exclusief: deel door 1,21. Het btw-bedrag is het verschil tussen beide.",
  },
  {
    question: "Hoe reken je 9% btw uit?",
    answer: "Van exclusief naar inclusief: vermenigvuldig met 1,09. Van inclusief naar exclusief: deel door 1,09. Het btw-bedrag is het verschil tussen beide.",
  },
  {
    question: "Is 0% btw hetzelfde als vrijgesteld van btw?",
    answer: "Nee. Het 0%-tarief (nultarief) betekent dat je 0% btw berekent, maar je moet dit op je factuur vermelden. Je mag het nultarief alleen in specifieke situaties toepassen, zoals bij export. Een vrijstelling betekent dat er helemaal geen btw in rekening wordt gebracht.",
  },
  {
    question: "Kan ik deze berekening gebruiken voor mijn btw-aangifte?",
    answer: "De uitkomst is een indicatie. Gebruik de berekening als hulpmiddel, maar controleer voor je administratie of btw-aangifte altijd de officiële informatie van de <a href=\"https://www.belastingdienst.nl\" target=\"_blank\" rel=\"noopener\">Belastingdienst</a> of vraag een adviseur.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://calculatieloket.nl/",
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "BTW inclusief en exclusief",
      "item": "https://calculatieloket.nl/btw-inclusief-exclusief/",
    },
  ],
};

---

<BaseLayout title={title} description={description} containerClass="container-wide">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <AdSlot slot="1234567890" format="auto" style="min-height:100px" />

  <CalculatorShell title="BTW inclusief en exclusief" subtitle="Bereken een bedrag van exclusief btw naar inclusief btw, of reken terug van inclusief naar exclusief. Kies 21%, 9% of 0% btw.">
    <InputPanel title="Jouw bedrag" slot="input">
      <div class="form-group">
        <label for="amount">Bedrag</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="amount" value={defaultAmount} min="0" step="0.01" />
        </div>
      </div>

      <div class="quick-chips">
        <span class="quick-chips-label">Snel kiezen:</span>
        {quickAmounts.map((amount) => (
          <button type="button" class="quick-chip" data-amount={amount}>
            &euro; {amount.toLocaleString("nl-NL")}
          </button>
        ))}
      </div>

      <div class="form-group">
        <label>Bereken</label>
        <div class="radio-group" id="btwDirection">
          <button type="button" data-direction="excl" class={defaultDirection === "excl" ? "active" : ""}>Exclusief &rarr; inclusief</button>
          <button type="button" data-direction="incl" class={defaultDirection === "incl" ? "active" : ""}>Inclusief &rarr; exclusief</button>
        </div>
      </div>

      <div class="form-group">
        <label>BTW-tarief</label>
        <div class="radio-group" id="btwRate">
          <button type="button" data-rate="21" class={defaultRate === 21 ? "active" : ""}>21%</button>
          <button type="button" data-rate="9" class={defaultRate === 9 ? "active" : ""}>9%</button>
          <button type="button" data-rate="0" class={defaultRate === 0 ? "active" : ""}>0%</button>
        </div>
        <p class="btw-nul-waarschuwing">0% btw geldt alleen in specifieke situaties, zoals internationale handel. Controleer altijd of je dit tarief mag toepassen.</p>
      </div>

      <button id="berekenBtn" class="btn btn-primary btn-lg" style="width:100%">Bereken btw</button>
      <p class="calc-error" id="calcError" style="display:none;">Vul een geldig bedrag in (0 of hoger).</p>
    </InputPanel>

    <ResultPanel
      slot="result"
      title="BTW inclusief/exclusief resultaat"
      heroLabel={heroLabel}
      heroValue={heroValue}
      heroSubtext={heroSubtext}
      badge="Indicatie"
    >
      <div class="result-meta">
        <span class="meta-badge">Bijgewerkt: 2026</span>
        <span class="meta-badge">Bron: Belastingdienst</span>
      </div>

      <div class="result-row"><span class="label">Bedrag exclusief btw</span><span class="value" id="detailExcl">{formatEuro(initialResult.amountExcl, 2)}</span></div>
      <div class="result-row"><span class="label">Btw-bedrag</span><span class="value" id="detailBtw">{formatEuro(initialResult.btwAmount, 2)}</span></div>
      <div class="result-row"><span class="label">Bedrag inclusief btw</span><span class="value" id="detailIncl">{formatEuro(initialResult.amountIncl, 2)}</span></div>
      <div class="result-divider"></div>
      <div class="result-row"><span class="label">Gebruikt tarief</span><span class="value" id="detailRate">{`${initialResult.rate}% btw`}</span></div>

      <FinancialJourney recommendations={initialRecommendations} />

      <button class="copy-link-btn" id="copyLinkBtn" type="button" slot="actions">
        <span class="copy-link-icon">🔗</span>
        <span class="copy-link-text">Deel deze berekening</span>
      </button>
    </ResultPanel>

    <UseCasesPanel title="Wat kun je hiermee?" items={useCases} slot="useCases" />

    <SourceCards title="Bronnen" items={sources} slot="sources" />

    <FaqAccordion title="Veelgestelde vragen" items={faq} slot="faq" />

    <ToolFooter
      slot="footer"
      disclaimer="Deze berekening is een indicatie op basis van de ingevoerde gegevens en de bekende btw-tarieven van 2026. Controleer belangrijke bedragen altijd via officiële bronnen of een financieel adviseur. Aan de uitkomst kunnen geen rechten worden ontleend."
      lastUpdated={lastUpdated}
    />
  </CalculatorShell>

  <div class="calculator-card calc-content" id="calculator-content">
    <h2 class="page-title">Wat is het verschil tussen inclusief en exclusief btw?</h2>
    <p><strong>Exclusief btw</strong> is het bedrag zonder btw. Dit is het nettobedrag dat een bedrijf ontvangt voor een product of dienst. <strong>Inclusief btw</strong> is het bedrag met btw erbij — dit is wat de klant uiteindelijk betaalt. Het <strong>btw-bedrag</strong> is het verschil tussen het inclusieve en het exclusieve bedrag.</p>
    <p>Bedrijven werken in hun administratie en offertes vaak met bedragen exclusief btw, terwijl consumenten in winkels en webshops meestal prijzen inclusief btw zien. Het is daarom handig om snel tussen beide te kunnen wisselen.</p>

    <h2>Formules voor inclusief en exclusief btw</h2>

    <h3>Van exclusief naar inclusief btw</h3>
    <div class="formula-box">
      <p><strong>Bedrag inclusief btw = bedrag exclusief btw &times; (1 + btw-percentage)</strong></p>
    </div>
    <p>In de praktijk:</p>
    <ul class="calc-list">
      <li>Bij 21% btw: vermenigvuldig met <strong>1,21</strong></li>
      <li>Bij 9% btw: vermenigvuldig met <strong>1,09</strong></li>
      <li>Bij 0% btw: het bedrag blijft gelijk</li>
    </ul>

    <h3>Van inclusief naar exclusief btw</h3>
    <div class="formula-box">
      <p><strong>Bedrag exclusief btw = bedrag inclusief btw &divide; (1 + btw-percentage)</strong></p>
    </div>
    <p>In de praktijk:</p>
    <ul class="calc-list">
      <li>Bij 21% btw: deel door <strong>1,21</strong></li>
      <li>Bij 9% btw: deel door <strong>1,09</strong></li>
      <li>Bij 0% btw: het bedrag blijft gelijk</li>
    </ul>

    <h2>Voorbeelden van btw inclusief en exclusief berekenen</h2>

    <h3>Voorbeeld 1: van exclusief naar inclusief (21%)</h3>
    <ul class="calc-list">
      <li>Bedrag exclusief btw: <strong>&euro;100</strong></li>
      <li>Btw-tarief: <strong>21%</strong></li>
      <li>Berekening: &euro;100 &times; 1,21 = <strong>&euro;121</strong></li>
      <li>Btw-bedrag: &euro;121 &minus; &euro;100 = <strong>&euro;21</strong></li>
    </ul>

    <h3>Voorbeeld 2: van inclusief naar exclusief (21%)</h3>
    <ul class="calc-list">
      <li>Bedrag inclusief btw: <strong>&euro;121</strong></li>
      <li>Btw-tarief: <strong>21%</strong></li>
      <li>Berekening: &euro;121 &divide; 1,21 = <strong>&euro;100</strong></li>
      <li>Btw-bedrag: &euro;121 &minus; &euro;100 = <strong>&euro;21</strong></li>
    </ul>

    <h3>Voorbeeld 3: van exclusief naar inclusief (9%)</h3>
    <ul class="calc-list">
      <li>Bedrag exclusief btw: <strong>&euro;100</strong></li>
      <li>Btw-tarief: <strong>9%</strong></li>
      <li>Berekening: &euro;100 &times; 1,09 = <strong>&euro;109</strong></li>
      <li>Btw-bedrag: &euro;109 &minus; &euro;100 = <strong>&euro;9</strong></li>
    </ul>

    <h3>Voorbeeld 4: van inclusief naar exclusief (9%)</h3>
    <ul class="calc-list">
      <li>Bedrag inclusief btw: <strong>&euro;109</strong></li>
      <li>Btw-tarief: <strong>9%</strong></li>
      <li>Berekening: &euro;109 &divide; 1,09 = <strong>&euro;100</strong></li>
      <li>Btw-bedrag: &euro;109 &minus; &euro;100 = <strong>&euro;9</strong></li>
    </ul>

    <h2>Veelgemaakte fouten bij btw inclusief en exclusief berekenen</h2>
    <ul class="calc-list">
      <li><strong>21% van een inclusief bedrag aftrekken:</strong> dit is niet hetzelfde als btw terugrekenen. Je moet delen door 1,21, niet aftrekken of vermenigvuldigen met 0,79.</li>
      <li><strong>Verkeerd tarief toepassen:</strong> controleer welk btw-tarief (21% of 9%) van toepassing is op jouw product of dienst.</li>
      <li><strong>0% btw verwarren met vrijgesteld:</strong> het 0%-tarief is iets anders dan een btw-vrijstelling. Bij het nultarief breng je 0% btw in rekening maar vermeld je dit op je factuur. Een vrijstelling betekent dat je helemaal geen btw mag berekenen.</li>
      <li><strong>Rondingsverschillen negeren:</strong> bij facturen met meerdere regels kunnen kleine verschillen ontstaan door afronding. Dit is normaal, maar wees je ervan bewust.</li>
      <li><strong>Niet controleren bij de Belastingdienst:</strong> btw-regels kunnen wijzigen. Controleer bij twijfel de officiële informatie van de <a href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/zakelijk/btw/btw_berekenen_aan_uw_klanten/btw_berekenen/btw_tarief/btw_tarief" target="_blank" rel="noopener">Belastingdienst</a>.</li>
    </ul>

    <h2>Bronnen</h2>
    <ul class="calc-list">
      <li><a href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/zakelijk/btw/btw_berekenen_aan_uw_klanten/btw_berekenen/btw_tarief/btw_tarief" target="_blank" rel="noopener">Belastingdienst — Btw-tarieven</a></li>
      <li><a href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/zakelijk/btw/btw_berekenen_aan_uw_klanten/btw_berekenen/rekenvoorbeeld_btw_berekenen" target="_blank" rel="noopener">Belastingdienst — Rekenvoorbeeld btw berekenen</a></li>
    </ul>
  </div>

  <CrossSellCards
    title="Ook handig om te berekenen"
    items={[
      { href: "/btw-calculator/", title: "BTW Calculator", description: "Bereken btw over elk bedrag.", accent: "#2563eb" },
      { href: "/btw-terugrekenen/", title: "BTW terugrekenen", description: "Van inclusief naar exclusief btw.", accent: "#3b82f6" },
      { href: "/zzp-calculator/", title: "ZZP Calculator", description: "Handig voor ondernemers.", accent: "#7c3aed" },
      { href: "/bruto-netto-2026/", title: "Bruto netto 2026", description: "Bereken een indicatie van je nettoloon.", accent: "#059669" },
    ]}
  />
</BaseLayout>

<script>
  import { calculateBtw } from "../lib/calculators/btw";
  import { formatEuro } from "../lib/format/currency";
  import { getRecommendations } from "../lib/recommendations/engine";
  import { updateFinancialJourney } from "../lib/recommendations/client";

  const amountInput = document.getElementById("amount") as HTMLInputElement;
  const hero = document.querySelector("[data-calc-result-hero]") as HTMLElement;
  const heroLabel = document.querySelector(".calc-result-panel-label") as HTMLElement;
  const heroSubtext = document.querySelector(".calc-result-panel-subtext") as HTMLElement;
  const errorBox = document.getElementById("calcError") as HTMLElement;
  const berekenBtn = document.getElementById("berekenBtn") as HTMLButtonElement;
  const copyLinkBtn = document.getElementById("copyLinkBtn") as HTMLButtonElement;
  const financialJourney = document.querySelector(".calc-financial-journey") as HTMLElement;

  const detailExcl = document.getElementById("detailExcl")!;
  const detailBtw = document.getElementById("detailBtw")!;
  const detailIncl = document.getElementById("detailIncl")!;
  const detailRate = document.getElementById("detailRate")!;

  let rate = 21;
  let direction: "excl" | "incl" = "excl";

  function updateUseCases(amount: number, rate: number, direction: "excl" | "incl", result: { amountExcl: number; amountIncl: number; btwAmount: number }) {
    const incl = direction === "excl" ? result.amountIncl : amount;
    const replacements: Record<string, string> = {
      "{{bedrag}}": formatEuro(amount, 2),
      "{{btw}}": formatEuro(result.btwAmount, 2),
      "{{excl}}": formatEuro(result.amountExcl, 2),
      "{{incl}}": formatEuro(incl, 2),
    };

    document.querySelectorAll("[data-usecase]").forEach((card) => {
      const id = card.getAttribute("data-usecase");
      const desc = card.querySelector(".calc-use-cases-card-desc") as HTMLElement;
      if (!desc) return;
      const template = desc.dataset.template;
      if (!template) return;
      let text = template;
      Object.entries(replacements).forEach(([key, value]) => {
        text = text.replaceAll(key, value);
      });
      desc.textContent = text;

      const anchor = card as HTMLAnchorElement;
      if (id === "btw-calculator") {
        anchor.href = `/btw-calculator/?bedrag=${amount}&tarief=${rate}&richting=${direction}`;
      } else if (id === "terugrekenen") {
        anchor.href = `/btw-terugrekenen/?bedrag=${incl}&tarief=${rate}`;
      }
    });
  }


  function updateUrl() {
    const params = new URLSearchParams(window.location.search);
    const amount = parseFloat(amountInput.value) || 0;

    if (amount > 0) params.set("bedrag", amount.toString());
    else params.delete("bedrag");

    params.set("tarief", rate.toString());
    params.set("richting", direction);

    const newUrl = `${window.location.pathname}?${params.toString()}`;
    window.history.replaceState(null, "", newUrl);
  }

  function calculate() {
    const amount = parseFloat(amountInput.value);
    const engineDirection = direction === "excl" ? "exclusive_to_inclusive" : "inclusive_to_exclusive";
    const result = calculateBtw({ amount, rate, direction: engineDirection });

    if (!result.valid) {
      errorBox.style.display = "block";
      hero.textContent = "—";
      detailExcl.textContent = "—";
      detailBtw.textContent = "—";
      detailIncl.textContent = "—";
      detailRate.textContent = "—";
      return;
    }

    errorBox.style.display = "none";

    hero.textContent = formatEuro(direction === "excl" ? result.amountIncl : result.amountExcl, 2);
    heroLabel.textContent = direction === "excl" ? "Bedrag inclusief btw" : "Bedrag exclusief btw";
    heroSubtext.textContent = `Gebaseerd op ${rate}% btw over ${formatEuro(amount, 2)}`;

    detailExcl.textContent = formatEuro(result.amountExcl, 2);
    detailBtw.textContent = formatEuro(result.btwAmount, 2);
    detailIncl.textContent = formatEuro(result.amountIncl, 2);
    detailRate.textContent = `${result.rate}% btw`;

    updateUseCases(amount, rate, direction, result);
    if (financialJourney) {
      const recs = getRecommendations({
        calculator: "btw-inclusief-exclusief",
        values: { amount, rate, direction },
        result,
      });
      updateFinancialJourney(financialJourney, recs);
    }
    updateUrl();
  }

  function applyUrlParams() {
    const params = new URLSearchParams(window.location.search);
    const bedrag = params.get("bedrag");
    const tarief = params.get("tarief");
    const richting = params.get("richting");

    if (bedrag !== null) amountInput.value = bedrag;
    if (tarief !== null) {
      rate = parseInt(tarief, 10);
      document.querySelectorAll("#btwRate button").forEach((btn) => {
        const button = btn as HTMLButtonElement;
        button.classList.toggle("active", button.dataset.rate === tarief);
      });
    }
    if (richting !== null && (richting === "excl" || richting === "incl")) {
      direction = richting;
      document.querySelectorAll("#btwDirection button").forEach((btn) => {
        const button = btn as HTMLButtonElement;
        button.classList.toggle("active", button.dataset.direction === richting);
      });
    }
  }

  function initQuickChips() {
    document.querySelectorAll(".quick-chip").forEach((btn) => {
      btn.addEventListener("click", () => {
        const amount = (btn as HTMLElement).dataset.amount;
        if (amount) {
          amountInput.value = amount;
          amountInput.focus();
          calculate();
        }
      });
    });
  }

  function initCopyLink() {
    copyLinkBtn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const textEl = copyLinkBtn.querySelector(".copy-link-text") as HTMLElement;
        const originalText = textEl.textContent || "Deel deze berekening";
        textEl.textContent = "Link gekopieerd";
        copyLinkBtn.classList.add("copy-link-success");
        setTimeout(() => {
          textEl.textContent = originalText;
          copyLinkBtn.classList.remove("copy-link-success");
        }, 2000);
      } catch (err) {
        console.error("Kon link niet kopiëren", err);
      }
    });
  }

  function initRateButtons() {
    document.getElementById("btwRate")!.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button") as HTMLButtonElement | null;
      if (!btn) return;
      document.querySelectorAll("#btwRate button").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      rate = parseInt(btn.dataset.rate!, 10);
      calculate();
    });
  }

  function initDirectionButtons() {
    document.getElementById("btwDirection")!.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button") as HTMLButtonElement | null;
      if (!btn) return;
      document.querySelectorAll("#btwDirection button").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      direction = btn.dataset.direction as "excl" | "incl";
      calculate();
    });
  }

  applyUrlParams();
  calculate();
  initQuickChips();
  initCopyLink();
  initRateButtons();
  initDirectionButtons();

  amountInput.addEventListener("input", calculate);
  berekenBtn.addEventListener("click", calculate);
  amountInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      calculate();
      amountInput.blur();
    }
  });
</script>

