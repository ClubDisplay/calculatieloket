---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdSlot from "../components/AdSlot.astro";
import CrossSellCards from "../components/CrossSellCards.astro";
---

<BaseLayout
  title="Btw inclusief en exclusief berekenen — 21%, 9% en 0%"
  description="Bereken eenvoudig btw inclusief of exclusief. Kies 21%, 9% of 0% btw en krijg een duidelijke indicatie van het bedrag inclusief btw, exclusief btw en het btw-bedrag."
>
  <h1 class="page-title">Btw inclusief en exclusief berekenen</h1>
  <p class="page-subtitle">
    Bereken een bedrag van exclusief btw naar inclusief btw, of reken juist terug van inclusief naar exclusief. Kies je tarief (21%, 9% of 0%) en zie direct het resultaat.
    <strong>De uitkomst is een indicatie.</strong>
    Gebruik ook onze <a href="/btw-calculator/">uitgebreide BTW Calculator</a> of <a href="/btw-terugrekenen/">btw terugrekenen</a> voor meer uitleg.
  </p>

  <AdSlot slot="1234567890" format="auto" style="min-height:100px" />

  <div class="calculator-card calc-modern">
    <div class="calc-fields">
    <div class="form-group">
      <label for="amount">Bedrag</label>
      <div class="input-prefix">
        <span class="prefix">&euro;</span>
        <input type="number" id="amount" placeholder="Bijv. 100" min="0" step="0.01" value="100" />
      </div>
    </div>

    <div class="form-group">
      <label>Bereken van</label>
      <div class="radio-group" id="calcDirection">
        <button data-direction="excl" class="active">Exclusief btw &rarr; inclusief btw</button>
        <button data-direction="incl">Inclusief btw &rarr; exclusief btw</button>
      </div>
    </div>

    <div class="form-group">
      <label>Btw-tarief</label>
      <div class="radio-group" id="btwRate">
        <button data-rate="21" class="active">21% &mdash; hoog tarief</button>
        <button data-rate="9">9% &mdash; laag tarief</button>
        <button data-rate="0">0% &mdash; nultarief</button>
      </div>
    </div>
    </div>

    <button id="berekenBtn" class="btn btn-primary btn-lg calc-btn">Bereken btw</button>
    <p class="calc-error" id="calcError" style="display:none;">Vul een geldig bedrag in (0 of hoger).</p>

    <div class="result-box" id="result">
      <h3>Resultaat <span class="badge-indicatie">Indicatie</span></h3>
      <div class="result-row">
        <span class="label">Bedrag exclusief btw</span>
        <span class="value" id="resultExcl">&mdash;</span>
      </div>
      <div class="result-row">
        <span class="label">Btw-bedrag</span>
        <span class="value" id="resultBtw">&mdash;</span>
      </div>
      <div class="result-row">
        <span class="label">Bedrag inclusief btw</span>
        <span class="value" id="resultIncl">&mdash;</span>
      </div>
      <div class="result-row">
        <span class="label">Gebruikt tarief</span>
        <span class="value" id="resultRate">&mdash;</span>
      </div>
      <p class="result-note">Deze berekening is een indicatie.</p>
    </div>

    <p class="calc-disclaimer">Deze berekening is een indicatie. Controleer belangrijke bedragen altijd via offici&euml;le bronnen of een adviseur.</p>
  </div>

  <div class="calculator-card">
    <h2>Wat is het verschil tussen inclusief en exclusief btw?</h2>
    <p><strong>Exclusief btw</strong> is het bedrag zonder btw. Dit is het nettobedrag dat een bedrijf ontvangt voor een product of dienst. <strong>Inclusief btw</strong> is het bedrag met btw erbij &mdash; dit is wat de klant uiteindelijk betaalt. Het <strong>btw-bedrag</strong> is het verschil tussen het inclusieve en het exclusieve bedrag.</p>
    <p>Bedrijven werken in hun administratie en offertes vaak met bedragen exclusief btw, terwijl consumenten in winkels en webshops meestal prijzen inclusief btw zien. Het is daarom handig om snel tussen beide te kunnen wisselen.</p>

    <h2>Formules voor inclusief en exclusief btw</h2>

    <h3>Van exclusief naar inclusief btw</h3>
    <div class="formula-box">
      <p><strong>Bedrag inclusief btw = bedrag exclusief btw &times; (1 + btw-percentage)</strong></p>
    </div>
    <p>In de praktijk:</p>
    <ul>
      <li>Bij 21% btw: vermenigvuldig met <strong>1,21</strong></li>
      <li>Bij 9% btw: vermenigvuldig met <strong>1,09</strong></li>
      <li>Bij 0% btw: het bedrag blijft gelijk</li>
    </ul>

    <h3>Van inclusief naar exclusief btw</h3>
    <div class="formula-box">
      <p><strong>Bedrag exclusief btw = bedrag inclusief btw &divide; (1 + btw-percentage)</strong></p>
    </div>
    <p>In de praktijk:</p>
    <ul>
      <li>Bij 21% btw: deel door <strong>1,21</strong></li>
      <li>Bij 9% btw: deel door <strong>1,09</strong></li>
      <li>Bij 0% btw: het bedrag blijft gelijk</li>
    </ul>

    <h2>Voorbeelden van btw inclusief en exclusief berekenen</h2>

    <h3>Voorbeeld 1: van exclusief naar inclusief (21%)</h3>
    <ul>
      <li>Bedrag exclusief btw: <strong>&euro;100</strong></li>
      <li>Btw-tarief: <strong>21%</strong></li>
      <li>Berekening: &euro;100 &times; 1,21 = <strong>&euro;121</strong></li>
      <li>Btw-bedrag: &euro;121 &minus; &euro;100 = <strong>&euro;21</strong></li>
    </ul>

    <h3>Voorbeeld 2: van inclusief naar exclusief (21%)</h3>
    <ul>
      <li>Bedrag inclusief btw: <strong>&euro;121</strong></li>
      <li>Btw-tarief: <strong>21%</strong></li>
      <li>Berekening: &euro;121 &divide; 1,21 = <strong>&euro;100</strong></li>
      <li>Btw-bedrag: &euro;121 &minus; &euro;100 = <strong>&euro;21</strong></li>
    </ul>

    <h3>Voorbeeld 3: van exclusief naar inclusief (9%)</h3>
    <ul>
      <li>Bedrag exclusief btw: <strong>&euro;100</strong></li>
      <li>Btw-tarief: <strong>9%</strong></li>
      <li>Berekening: &euro;100 &times; 1,09 = <strong>&euro;109</strong></li>
      <li>Btw-bedrag: &euro;109 &minus; &euro;100 = <strong>&euro;9</strong></li>
    </ul>

    <h3>Voorbeeld 4: van inclusief naar exclusief (9%)</h3>
    <ul>
      <li>Bedrag inclusief btw: <strong>&euro;109</strong></li>
      <li>Btw-tarief: <strong>9%</strong></li>
      <li>Berekening: &euro;109 &divide; 1,09 = <strong>&euro;100</strong></li>
      <li>Btw-bedrag: &euro;109 &minus; &euro;100 = <strong>&euro;9</strong></li>
    </ul>

    <h2>Veelgemaakte fouten bij btw inclusief en exclusief berekenen</h2>
    <ul>
      <li><strong>21% van een inclusief bedrag aftrekken:</strong> dit is niet hetzelfde als btw terugrekenen. Je moet delen door 1,21, niet aftrekken of vermenigvuldigen met 0,79.</li>
      <li><strong>Verkeerd tarief toepassen:</strong> controleer welk btw-tarief (&mdash; 21% of 9% &mdash;) van toepassing is op jouw product of dienst.</li>
      <li><strong>0% btw verwarren met vrijgesteld:</strong> het 0%-tarief is iets anders dan een btw-vrijstelling. Bij het nultarief breng je 0% btw in rekening maar vermeld je dit op je factuur. Een vrijstelling betekent dat je helemaal geen btw mag berekenen.</li>
      <li><strong>Rondingsverschillen negeren:</strong> bij facturen met meerdere regels kunnen kleine verschillen ontstaan door afronding. Dit is normaal, maar wees je ervan bewust.</li>
      <li><strong>Niet controleren bij de Belastingdienst:</strong> btw-regels kunnen wijzigen. Controleer bij twijfel de offici&euml;le informatie van de <a href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/zakelijk/btw/btw_berekenen_aan_uw_klanten/btw_berekenen/btw_tarief/btw_tarief" target="_blank" rel="noopener">Belastingdienst</a>.</li>
    </ul>

    <h2>Veelgestelde vragen</h2>

    <h3>Hoe bereken je btw inclusief?</h3>
    <p>Vermenigvuldig het bedrag exclusief btw met (1 + het btw-percentage gedeeld door 100). Bij 21% btw vermenigvuldig je met 1,21. Bij 9% btw met 1,09.</p>

    <h3>Hoe bereken je btw exclusief?</h3>
    <p>Deel het bedrag inclusief btw door (1 + het btw-percentage gedeeld door 100). Bij 21% btw deel je door 1,21. Bij 9% btw door 1,09.</p>

    <h3>Wat is het verschil tussen inclusief en exclusief btw?</h3>
    <p>Exclusief btw is het bedrag z&oacute;nder btw. Inclusief btw is het bedrag m&eacute;t btw. Het btw-bedrag is het verschil tussen beide. Bedrijven rekenen vaak met exclusieve bedragen; consumenten zien meestal inclusieve prijzen.</p>

    <h3>Hoe reken je 21% btw uit?</h3>
    <p>Van exclusief naar inclusief: vermenigvuldig met 1,21. Van inclusief naar exclusief: deel door 1,21. Het btw-bedrag is het verschil tussen beide.</p>

    <h3>Hoe reken je 9% btw uit?</h3>
    <p>Van exclusief naar inclusief: vermenigvuldig met 1,09. Van inclusief naar exclusief: deel door 1,09. Het btw-bedrag is het verschil tussen beide.</p>

    <h3>Is 0% btw hetzelfde als vrijgesteld van btw?</h3>
    <p>Nee. Het 0%-tarief (nultarief) betekent dat je 0% btw berekent, maar je moet dit op je factuur vermelden. Je mag het nultarief alleen in specifieke situaties toepassen, zoals bij export. Een vrijstelling betekent dat er helemaal geen btw in rekening wordt gebracht.</p>

    <h3>Kan ik deze berekening gebruiken voor mijn btw-aangifte?</h3>
    <p>De uitkomst is een indicatie. Gebruik de berekening als hulpmiddel, maar controleer voor je administratie of btw-aangifte altijd de offici&euml;le informatie van de <a href="https://www.belastingdienst.nl" target="_blank" rel="noopener">Belastingdienst</a> of vraag een adviseur.</p>

    <h2>Bronnen</h2>
    <ul>
      <li><a href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/zakelijk/btw/btw_berekenen_aan_uw_klanten/btw_berekenen/btw_tarief/btw_tarief" target="_blank" rel="noopener">Belastingdienst &mdash; Btw-tarieven</a></li>
      <li><a href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/zakelijk/btw/btw_berekenen_aan_uw_klanten/btw_berekenen/rekenvoorbeeld_btw_berekenen" target="_blank" rel="noopener">Belastingdienst &mdash; Rekenvoorbeeld btw berekenen</a></li>
    </ul>

    <p class="disclaimer">Deze berekening is een indicatie. Aan de uitkomsten kunnen geen rechten worden ontleend. Controleer belangrijke bedragen altijd via offici&euml;le bronnen of een financieel adviseur.</p>
    <p class="last-updated">Laatst bijgewerkt: 26 juni 2026</p>
  </div>

  <CrossSellCards
    title="Ook handig bij btw"
    items={[
      { href: "/btw-calculator/", title: "BTW Calculator", description: "Bereken btw over elk bedrag." },
      { href: "/btw-terugrekenen/", title: "Btw terugrekenen", description: "Van inclusief naar exclusief btw." },
      { href: "/auto-importkosten-berekenen/", title: "Auto importkosten", description: "Bereken een indicatie van importkosten." },
      { href: "/zzp-calculator/", title: "ZZP Calculator", description: "Handig voor ondernemers en zakelijke kosten." },
    ]}
  />
</BaseLayout>

<script>
  import { calculateBtw } from "../lib/calculators/btw";
  import { formatEuro } from "../lib/format/currency";

  const amountInput = document.getElementById("amount") as HTMLInputElement;
  const resultExcl = document.getElementById("resultExcl")!;
  const resultBtw = document.getElementById("resultBtw")!;
  const resultIncl = document.getElementById("resultIncl")!;
  const resultRate = document.getElementById("resultRate")!;

  let direction: "excl" | "incl" = "excl";
  let btwRate = 21;

  function calculate() {
    const amount = parseFloat(amountInput.value);
    const errorBox = document.getElementById("calcError") as HTMLElement;
    const engineDirection = direction === "excl" ? "exclusive_to_inclusive" : "inclusive_to_exclusive";
    const result = calculateBtw({ amount, rate: btwRate, direction: engineDirection });

    if (!result.valid) {
      resultExcl.textContent = "—";
      resultBtw.textContent = "—";
      resultIncl.textContent = "—";
      resultRate.textContent = "—";
      errorBox.style.display = "block";
      return;
    }

    errorBox.style.display = "none";
    resultExcl.textContent = formatEuro(result.amountExcl, 2);
    resultBtw.textContent = formatEuro(result.btwAmount, 2);
    resultIncl.textContent = formatEuro(result.amountIncl, 2);
    resultRate.textContent = `${result.rate}% btw`;
  }

  amountInput.addEventListener("input", calculate);
  document.getElementById("berekenBtn")!.addEventListener("click", calculate);

  document.getElementById("calcDirection")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest("button");
    if (!btn) return;
    document.querySelectorAll("#calcDirection button").forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
    direction = btn.dataset.direction as "excl" | "incl";
    calculate();
  });

  document.getElementById("btwRate")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest("button");
    if (!btn) return;
    document.querySelectorAll("#btwRate button").forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
    btwRate = parseInt(btn.dataset.rate!);
    calculate();
  });

  calculate();
</script>

<style>
  h2 { font-size: 1.15rem; margin: 1.5rem 0 0.5rem; }
  h3 { font-size: 1rem; margin: 1rem 0 0.35rem; color: var(--color-text); }
  ul { margin: 0.5rem 0; padding-left: 1.25rem; }
  li { margin-bottom: 0.35rem; font-size: 0.95rem; }
  .badge-indicatie { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; color: var(--color-primary); background: var(--color-primary-light); padding: 2px 8px; border-radius: 4px; vertical-align: middle; margin-left: 8px; }
  .calc-disclaimer { font-size: 0.8rem; color: var(--color-text-muted); margin-top: 1rem; }
  .disclaimer { font-size: 0.85rem; color: var(--color-text-muted); margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--color-border); }
  .last-updated { font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.5rem; }
  .formula-box { background: var(--color-primary-light); border: 1px solid #bfdbfe; border-radius: var(--radius); padding: 1rem 1.25rem; margin: 1rem 0; }
  .formula-box p { margin: 0.25rem 0; font-size: 0.95rem; }
</style>
