---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://calculatieloket.nl/" },
    { "@type": "ListItem", position: 2, name: "Disclaimer", item: "https://calculatieloket.nl/disclaimer/" },
  ],
};
---

<BaseLayout
  title="Disclaimer - Calculatieloket.nl"
  description="Disclaimer van Calculatieloket.nl: onze calculators geven indicaties gebaseerd op officiële bronnen, geen financieel advies. Lees de voorwaarden."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Disclaimer", current: true },
    ]}
    analyticsCategory="site-page"
  />

  <h1 class="page-title">Disclaimer</h1>
  <p class="page-subtitle">Laatst bijgewerkt: 12 juni 2026</p>

  <div class="calculator-card">
    <h2>Indicatieve berekeningen</h2>
    <p>Alle calculators op Calculatieloket.nl geven <strong>indicatieve berekeningen</strong>. De resultaten zijn gebaseerd op de door jou ingevoerde gegevens en de ons bekende tarieven en regels. Aan de uitkomsten kunnen geen rechten worden ontleend.</p>

    <h2>Geen financieel of fiscaal advies</h2>
    <p>Calculatieloket.nl geeft <strong>geen</strong> financieel, fiscaal of juridisch advies. Voor persoonlijk advies raden we je aan contact op te nemen met een erkend financieel adviseur, belastingadviseur of de Belastingdienst.</p>

    <h2>Eigen verantwoordelijkheid</h2>
    <p>Je blijft zelf verantwoordelijk voor beslissingen die je neemt op basis van de uitkomsten van onze calculators. Controleer belangrijke berekeningen altijd via officiële bronnen zoals de Belastingdienst, Dienst Toeslagen of een hypotheekadviseur.</p>

    <h2>Juistheid van informatie</h2>
    <p>Wij doen ons best de informatie op deze website actueel en correct te houden. Tarieven en regels kunnen echter wijzigen. We raden aan om bij twijfel de officiële bronnen te raadplegen.</p>

    <h2>Externe links</h2>
    <p>Onze site kan links bevatten naar externe websites. Wij zijn niet verantwoordelijk voor de inhoud van deze websites.</p>

    <h2>Controleerbare bronnen</h2>
    <p>Onze berekeningen zijn gebaseerd op officiële, publiek toegankelijke bronnen zoals de Belastingdienst, de Rijksoverheid en het Nibud. We vermelden per calculator welke bronnen we gebruiken.</p>
  </div>
</BaseLayout>
