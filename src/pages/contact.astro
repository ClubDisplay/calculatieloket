---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://calculatieloket.nl/" },
    { "@type": "ListItem", position: 2, name: "Contact", item: "https://calculatieloket.nl/contact/" },
  ],
};
---

<BaseLayout
  title="Contact - Calculatieloket.nl"
  description="Neem contact op met Calculatieloket.nl. Vragen, suggesties of opmerkingen over onze gratis, op officiële bronnen gebaseerde calculators? We helpen je graag."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Contact", current: true },
    ]}
    analyticsCategory="site-page"
  />

  <h1 class="page-title">Contact</h1>
  <p class="page-subtitle">Heb je een vraag, suggestie of opmerking? We horen het graag.</p>

  <div class="calculator-card">
    <h2>Stuur ons een bericht</h2>
    <p>Je kunt ons bereiken via e-mail op:</p>
    <p style="font-size: 1.1rem; margin: 1rem 0;">
      <strong>contact@calculatieloket.nl</strong>
    </p>

    <h2>Waarvoor kun je contact opnemen?</h2>
    <ul>
      <li>Vragen over de werking van een calculator</li>
      <li>Suggesties voor nieuwe calculators</li>
      <li>Melden van fouten in tarieven of berekeningen</li>
      <li>Technische problemen met de website</li>
      <li>Privacy-gerelateerde vragen</li>
    </ul>

    <h2>Wat kun je niet van ons verwachten?</h2>
    <ul>
      <li>Persoonlijk financieel advies &mdash; wij zijn geen adviseurs</li>
      <li>Hulp bij belastingaangifte &mdash; neem contact op met de Belastingdienst</li>
      <li>Hypotheekadvies &mdash; raadpleeg een erkend adviseur</li>
    </ul>

    <p style="margin-top: 1rem; font-size: 0.9rem; color: var(--color-text-muted);">
      We streven ernaar om binnen 2 werkdagen te reageren.
    </p>

    <h2>Onze belofte</h2>
    <p>Calculatieloket.nl bouwt calculators op basis van officiële bronnen en controleert deze jaarlijks. We slaan geen persoonlijke gegevens op en geven geen financieel advies.</p>
  </div>
</BaseLayout>
