---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AdSlot from "../components/AdSlot.astro";
import CrossSellCards from "../components/CrossSellCards.astro";
import CalculatorShell from "../components/calculator/CalculatorShell.astro";
import InputPanel from "../components/calculator/InputPanel.astro";
import ResultPanel from "../components/calculator/ResultPanel.astro";
import UseCasesPanel from "../components/calculator/UseCasesPanel.astro";
import FaqAccordion from "../components/calculator/FaqAccordion.astro";
import ToolFooter from "../components/calculator/ToolFooter.astro";
import SourceCards from "../components/SourceCards.astro";
import { calculateMortgage } from "../lib/calculators/mortgage";
import FinancialJourney from "../components/calculator/FinancialJourney.astro";
import HowToSchema from "../components/calculator/HowToSchema.astro";
import InlineSources from "../components/calculator/InlineSources.astro";
import { getRecommendations } from "../lib/recommendations/engine";
import { formatEuro } from "../lib/format/currency";

const title = "Hypotheek Calculator 2026 — Indicatie maandlasten | Calculatieloket.nl";
const description = "Bereken een indicatie van je hypotheeklasten, rentelasten en hypotheekbedrag op basis van je inkomen. Geen officiële hypotheekofferte.";

const defaultIncome = 60000;
const defaultRate = 3.8;
const defaultTerm = 30;
const defaultPartner = false;
const defaultPartnerIncome = 40000;

const initialResult = calculateMortgage({
  income: defaultIncome,
  interestRate: defaultRate,
  termYears: defaultTerm,
  partnerIncome: defaultPartnerIncome,
  includePartner: defaultPartner,
});

const initialRecommendations = getRecommendations({
  calculator: "hypotheek",
  values: { totalYearlyIncome: initialResult.totalIncome, partner: defaultPartner },
  result: initialResult,
});

const lastUpdated = "30 juni 2026";

const quickIncomeAmounts = [40000, 50000, 60000, 70000, 80000];

const useCases = [
  {
    id: "bruto-netto",
    title: "Bruto-netto 2026",
    description: "Bereken je netto salaris bij een bruto inkomen van {{inkomen}}.",
    href: "/bruto-netto-2026/",
    accent: "#2563eb",
  },
  {
    id: "salaris",
    title: "Salaris calculator",
    description: "Vergelijk bruto en netto op basis van {{inkomen}} per jaar.",
    href: "/salaris-calculator/",
    accent: "#3b82f6",
  },
  {
    id: "toeslagen",
    title: "Toeslagen berekenen",
    description: "Check of je recht hebt op huur- of zorgtoeslag met dit inkomen.",
    href: "/toeslagen-calculator/",
    accent: "#059669",
  },
  {
    id: "zzp",
    title: "ZZP uurtarief berekenen",
    description: "Bereken het benodigde uurtarief om dit inkomen als ZZP'er te halen.",
    href: "/zzp-calculator/",
    accent: "#7c3aed",
  },
];

const sources = [
  {
    label: "Onafhankelijke bron",
    title: "Nibud — Budgetvoorlichting",
    description: "Informatie over verantwoord lenen en hypotheeklasten.",
    href: "https://www.nibud.nl",
  },
  {
    label: "Officiële bron",
    title: "Rijksoverheid — Hypotheek",
    description: "Algemene informatie over hypotheken en regelgeving.",
    href: "https://www.rijksoverheid.nl/hypotheek",
  },
];

const faq = [
  {
    question: "Is dit een officiële hypotheekofferte?",
    answer: "Nee, dit is een indicatie. Een geldverstrekker gebruikt eigen acceptatieregels en kijkt naar veel meer factoren: studieschuld, BKR-registratie, gezinssituatie, rentevaste periode, energieprestatie, vaste lasten, en of je een koop- of huurhuis hebt.",
  },
  {
    question: "Wat is het verschil tussen bruto en netto maandlasten?",
    answer: "Bruto is wat je aan de bank betaalt. Netto is na verrekening van de belastingteruggave via hypotheekrenteaftrek.",
  },
  {
    question: "Welke rol speelt rente?",
    answer: "Een lagere rente betekent lagere maandlasten en een hoger leenbedrag. Bij een hogere rente daalt het maximale hypotheekbedrag.",
  },
  {
    question: "Waarom kan mijn hypotheekindicatie afwijken?",
    answer: "Banken hanteren specifieke normen en modellen (Nibud). Vooral een studieschuld, BKR-registratie en alimentatie wegen zwaar mee. Gebruik deze calculator alleen als startpunt.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://calculatieloket.nl/",
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Hypotheek Calculator",
      "item": "https://calculatieloket.nl/hypotheek-calculator/",
    },
  ],
};
---

<BaseLayout title={title} description={description} containerClass="container-wide">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <HowToSchema
    slot="head"
    name="Hypotheek berekenen op basis van inkomen"
    description="Stappen om een indicatie van je maximale hypotheek en maandlasten te berekenen."
    totalTime="PT1M"
    steps={[
      { name: "Vul je bruto jaarinkomen in", text: "Voer je bruto jaarinkomen in, inclusief vakantiegeld." },
      { name: "Vul de hypotheekrente in", text: "Voer een actuele voorbeeldrente in, bijvoorbeeld 3,8%." },
      { name: "Kies de looptijd", text: "Selecteer 10, 20 of 30 jaar." },
      { name: "Voeg eventueel een partner inkomen toe", text: "Zet de partner-toggle aan en vul het tweede inkomen in." },
      { name: "Bekijk je hypotheekindicatie", text: "De calculator toont het maximale hypotheekbedrag, bruto en netto maandlasten." },
    ]}
  />

  <AdSlot slot="1234567894" format="auto" style="min-height:100px" />

  <Breadcrumbs items={[
    { label: "Home", href: "/" },
    { label: "Wonen", href: "/categorie/wonen/" },
    { label: "Hypotheek calculator", current: true },
  ]} />

  <CalculatorShell title="Hypotheek calculator" subtitle="Bereken een indicatie van je maximale hypotheek en maandlasten op basis van je inkomen en rente.">
    <InputPanel title="Jouw situatie" slot="input">
      <div class="form-group">
        <label for="income">Bruto jaarinkomen</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="income" value={defaultIncome} min="0" step="100" />
        </div>
      </div>

      <div class="quick-chips">
        <span class="quick-chips-label">Snel inkomen:</span>
        {quickIncomeAmounts.map((amount) => (
          <button type="button" class="quick-chip" data-amount={amount} data-analytics="quick-chip" data-analytics-category="calculator-page" data-analytics-action="select" data-analytics-label={amount}>
            &euro; {amount.toLocaleString("nl-NL")}
          </button>
        ))}
      </div>

      <div class="form-group">
        <label for="rate">Hypotheekrente <span class="hint">(voorbeeldrente)</span></label>
        <div class="input-suffix">
          <input type="number" id="rate" value={defaultRate} min="0" max="15" step="0.1" />
          <span class="suffix">%</span>
        </div>
      </div>

      <div class="form-group">
        <label>Looptijd</label>
        <div class="radio-group" id="termGroup">
          <button type="button" data-term="10" class={defaultTerm === 10 ? "active" : ""} data-analytics="radio-button" data-analytics-category="calculator-page" data-analytics-action="select" data-analytics-label="term-10">10 jaar</button>
          <button type="button" data-term="20" class={defaultTerm === 20 ? "active" : ""} data-analytics="radio-button" data-analytics-category="calculator-page" data-analytics-action="select" data-analytics-label="term-20">20 jaar</button>
          <button type="button" data-term="30" class={defaultTerm === 30 ? "active" : ""} data-analytics="radio-button" data-analytics-category="calculator-page" data-analytics-action="select" data-analytics-label="term-30">30 jaar</button>
        </div>
      </div>

      <div class="form-group">
        <div class="toggle-row">
          <span class="toggle-label">Tweede inkomen meerekenen</span>
          <label class="toggle" for="partnerToggle">
            <input type="checkbox" id="partnerToggle" checked={defaultPartner} />
            <span class="slider"></span>
          </label>
        </div>
      </div>

      <div class="form-group" id="partnerGroup" style={defaultPartner ? undefined : "display:none;"}>
        <label for="partnerIncome">Bruto jaarinkomen partner</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="partnerIncome" value={defaultPartnerIncome} min="0" step="100" />
        </div>
      </div>

      <button id="berekenBtn" class="btn btn-primary btn-lg" style="width:100%" data-analytics="cta" data-analytics-category="calculator-page" data-analytics-action="click" data-analytics-label="bereken">Bereken hypotheek</button>
      <p class="calc-error" id="calcError" style="display:none;">Vul een geldig inkomen en rente in (hoger dan 0).</p>
    </InputPanel>

    <ResultPanel
      slot="result"
      title="Hypotheekindicatie"
      heroLabel="Maximaal hypotheekbedrag"
      heroValue={formatEuro(initialResult.maxMortgage, 0)}
      heroSubtext="Indicatie op basis van 2026-rente"
      badge="Indicatie"
    >
      <div class="result-meta">
        <span class="meta-badge">Bijgewerkt: 2026</span>
        <span class="meta-badge">Bron: Nibud / Rijksoverheid</span>
      </div>

      <div class="result-row"><span class="label">Totaal bruto jaarinkomen</span><span class="value" id="detailTotalIncome">{formatEuro(initialResult.totalIncome, 0)}</span></div>
      <div class="result-row"><span class="label">Inkomensfactor</span><span class="value" id="detailIncomeFactor">{initialResult.incomeFactor.toFixed(2).replace(".", ",")}</span></div>
      <div class="result-divider"></div>
      <div class="result-row"><span class="label">Hypotheekbedrag (indicatie)</span><span class="value" id="detailMaxMortgage">{formatEuro(initialResult.maxMortgage, 0)}</span></div>
      <div class="result-row"><span class="label">Bruto maandlasten</span><span class="value" id="detailMonthly">{formatEuro(initialResult.monthlyPayment, 0)}</span></div>
      <div class="result-row"><span class="label">Netto maandlasten <span class="hint">(incl. hypotheekrenteaftrek)</span></span><span class="value" id="detailNetMonthly">{formatEuro(initialResult.netMonthlyPayment, 0)}</span></div>
      <div class="result-row"><span class="label">Totale rentekosten</span><span class="value" id="detailTotalInterest">{formatEuro(initialResult.totalInterest, 0)}</span></div>

      <button class="copy-link-btn" id="copyLinkBtn" type="button" slot="actions" data-analytics="copy-link" data-analytics-category="calculator-page" data-analytics-action="click" data-analytics-label="copy-link">
        <span class="copy-link-icon">🔗</span>
        <span class="copy-link-text">Deel deze berekening</span>
      </button>

      <FinancialJourney recommendations={initialRecommendations} />
      <InlineSources title="Gebruikte bronnen" items={sources} />
    </ResultPanel>

    <UseCasesPanel title="Wat kun je hiermee?" items={useCases} slot="useCases" />

    <SourceCards title="Bronnen" items={sources} slot="sources" />

    <FaqAccordion title="Veelgestelde vragen" items={faq} slot="faq" />

    <ToolFooter categoryLink="/categorie/wonen/" categoryLabel="Wonen"
      slot="footer"
      disclaimer="Deze berekening is geen officiële hypotheekofferte. Geldverstrekkers gebruiken eigen acceptatieregels en kijken onder meer naar studieschuld, BKR, gezinssituatie, rentevaste periode, energieprestatie en vaste lasten. Vraag altijd een officiële berekening aan bij een hypotheekadviseur."
      lastUpdated={lastUpdated}
    />
  </CalculatorShell>

  <div class="calculator-card calc-content" id="calculator-content">
    <h2 class="page-title">Hypotheek calculator</h2>
    <p>Bereken een indicatie van je hypotheeklasten, rentelasten en hypotheekbedrag op basis van je inkomen. Gebruik deze calculator als startpunt; het is geen officiële hypotheekofferte.</p>
    <p>Wil je weten hoeveel je <a href="/bruto-netto-2026/">netto overhoudt</a> van dit inkomen, of welk <a href="/zzp-calculator/">ZZP-uurtarief</a> je nodig hebt? Ook <a href="/toeslagen-calculator/">toeslagen</a> en je <a href="/salaris-calculator/">salaris</a> bereken je eenvoudig op Calculatieloket.nl.</p>

    <h2>Hoe werkt deze berekening?</h2>
    <p>Deze calculator geeft een indicatie op basis van je inkomen, de ingevulde rente en de gekozen looptijd. Gebruikte uitgangspunten:</p>
    <ul class="calc-list">
      <li>Inkomen × factor (afhankelijk van rente)</li>
      <li>Annuïtaire aflossing</li>
      <li>Hypotheekrenteaftrek tegen 37,56% (2026)</li>
    </ul>
  </div>

  <CrossSellCards
    title="Ook handig om te berekenen"
    items={[
      { href: "/bruto-netto-2026/", title: "Bruto netto 2026", description: "Bereken een indicatie van je nettoloon in 2026.", accent: "#2563eb" },
      { href: "/salaris-calculator/", title: "Salaris Calculator", description: "Bereken een indicatie van bruto naar netto.", accent: "#3b82f6" },
      { href: "/toeslagen-calculator/", title: "Toeslagen Calculator", description: "Bekijk mogelijke invloed van inkomen op toeslagen.", accent: "#059669" },
    ]}
  />
</BaseLayout>

<script>
  import { calculateMortgage } from "../lib/calculators/mortgage";
  import { formatEuro } from "../lib/format/currency";
  import { getRecommendations } from "../lib/recommendations/engine";
  import { updateFinancialJourney } from "../lib/recommendations/client";

  const incomeInput = document.getElementById("income") as HTMLInputElement;
  const rateInput = document.getElementById("rate") as HTMLInputElement;
  const partnerToggle = document.getElementById("partnerToggle") as HTMLInputElement;
  const partnerGroup = document.getElementById("partnerGroup") as HTMLDivElement;
  const partnerIncomeInput = document.getElementById("partnerIncome") as HTMLInputElement;
  const hero = document.querySelector(".calc-result-panel-hero") as HTMLElement;
  const errorBox = document.getElementById("calcError") as HTMLElement;
  const berekenBtn = document.getElementById("berekenBtn") as HTMLButtonElement;
  const copyLinkBtn = document.getElementById("copyLinkBtn") as HTMLButtonElement;
  const financialJourney = document.querySelector(".calc-financial-journey") as HTMLElement;

  const detailTotalIncome = document.getElementById("detailTotalIncome")!;
  const detailIncomeFactor = document.getElementById("detailIncomeFactor")!;
  const detailMaxMortgage = document.getElementById("detailMaxMortgage")!;
  const detailMonthly = document.getElementById("detailMonthly")!;
  const detailNetMonthly = document.getElementById("detailNetMonthly")!;
  const detailTotalInterest = document.getElementById("detailTotalInterest")!;

  let termYears = 30;

  const formatNumber = (n: number, decimals = 0): string =>
    n.toFixed(decimals).replace(".", ",").replace(/\B(?=(\d{3})+(?!\d))/g, ".");

  function updateUseCases(income: number) {
    const replacements: Record<string, string> = {
      "{{inkomen}}": formatNumber(income, 0),
    };

    document.querySelectorAll("[data-usecase]").forEach((card) => {
      const desc = card.querySelector(".calc-use-cases-card-desc") as HTMLElement;
      if (!desc) return;
      const template = desc.dataset.template;
      if (!template) return;
      let text = template;
      Object.entries(replacements).forEach(([key, value]) => {
        text = text.replaceAll(key, value);
      });
      desc.textContent = text;
    });
  }

  function updateUrl() {
    const params = new URLSearchParams(window.location.search);
    const income = parseFloat(incomeInput.value) || 0;
    const rate = parseFloat(rateInput.value) || 0;
    const partnerIncome = parseFloat(partnerIncomeInput.value) || 0;

    if (income > 0) params.set("inkomen", income.toString());
    else params.delete("inkomen");

    if (rate >= 0) params.set("rente", rate.toString());
    else params.delete("rente");

    params.set("looptijd", termYears.toString());
    params.set("partner", partnerToggle.checked ? "1" : "0");

    if (partnerToggle.checked && partnerIncome > 0) params.set("partnerInkomen", partnerIncome.toString());
    else params.delete("partnerInkomen");

    const newUrl = `${window.location.pathname}?${params.toString()}`;
    window.history.replaceState(null, "", newUrl);
  }

  function calculate() {
    const income = parseFloat(incomeInput.value) || 0;
    const rate = parseFloat(rateInput.value) || 0;
    const partnerIncome = parseFloat(partnerIncomeInput.value) || 0;

    const result = calculateMortgage({
      income,
      interestRate: rate,
      termYears,
      partnerIncome,
      includePartner: partnerToggle.checked,
    });

    if (!result.valid) {
      errorBox.style.display = "block";
      hero.textContent = "—";
      detailTotalIncome.textContent = "—";
      detailIncomeFactor.textContent = "—";
      detailMaxMortgage.textContent = "—";
      detailMonthly.textContent = "—";
      detailNetMonthly.textContent = "—";
      detailTotalInterest.textContent = "—";
      return;
    }

    errorBox.style.display = "none";

    hero.textContent = formatEuro(result.maxMortgage, 0);
    detailTotalIncome.textContent = formatEuro(result.totalIncome, 0);
    detailIncomeFactor.textContent = result.incomeFactor.toFixed(2).replace(".", ",");
    detailMaxMortgage.textContent = formatEuro(result.maxMortgage, 0);
    detailMonthly.textContent = formatEuro(result.monthlyPayment, 0);
    detailNetMonthly.textContent = formatEuro(result.netMonthlyPayment, 0);
    detailTotalInterest.textContent = formatEuro(result.totalInterest, 0);

    updateUseCases(result.totalIncome);
    if (financialJourney) {
      const recs = getRecommendations({
        calculator: "hypotheek",
        values: { totalYearlyIncome: result.totalIncome, partner: partnerToggle.checked },
        result,
      });
      updateFinancialJourney(financialJourney, recs);
    }
    updateUrl();
  }

  function applyUrlParams() {
    const params = new URLSearchParams(window.location.search);
    const income = params.get("inkomen");
    const rate = params.get("rente");
    const term = params.get("looptijd");
    const partner = params.get("partner");
    const partnerIncome = params.get("partnerInkomen");

    if (income !== null) incomeInput.value = income;
    if (rate !== null) rateInput.value = rate;
    if (partner !== null) partnerToggle.checked = partner === "1";
    if (partnerIncome !== null) partnerIncomeInput.value = partnerIncome;

    if (term !== null) {
      const termValue = parseInt(term, 10);
      if ([10, 20, 30].includes(termValue)) {
        termYears = termValue;
      }
    }

    document.querySelectorAll("#termGroup button").forEach((btn) => {
      const button = btn as HTMLButtonElement;
      const active = parseInt(button.dataset.term!, 10) === termYears;
      button.classList.toggle("active", active);
    });
  }

  function initQuickChips() {
    document.querySelectorAll(".quick-chip").forEach((btn) => {
      btn.addEventListener("click", () => {
        const amount = (btn as HTMLElement).dataset.amount;
        if (amount) {
          incomeInput.value = amount;
          incomeInput.focus();
          calculate();
        }
      });
    });
  }

  function initCopyLink() {
    copyLinkBtn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const textEl = copyLinkBtn.querySelector(".copy-link-text") as HTMLElement;
        const originalText = textEl.textContent || "Deel deze berekening";
        textEl.textContent = "Link gekopieerd";
        copyLinkBtn.classList.add("copy-link-success");
        setTimeout(() => {
          textEl.textContent = originalText;
          copyLinkBtn.classList.remove("copy-link-success");
        }, 2000);
      } catch (err) {
        console.error("Kon link niet kopiëren", err);
      }
    });
  }

  function initTermButtons() {
    document.getElementById("termGroup")!.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button") as HTMLButtonElement | null;
      if (!btn) return;
      document.querySelectorAll("#termGroup button").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      termYears = parseInt(btn.dataset.term!, 10);
      calculate();
    });
  }

  function initPartnerToggle() {
    partnerToggle.addEventListener("change", () => {
      partnerGroup.style.display = partnerToggle.checked ? "block" : "none";
      calculate();
    });
  }

  applyUrlParams();
  calculate();
  initQuickChips();
  initCopyLink();
  initTermButtons();
  initPartnerToggle();

  incomeInput.addEventListener("input", calculate);
  rateInput.addEventListener("input", calculate);
  partnerIncomeInput.addEventListener("input", calculate);
  berekenBtn.addEventListener("click", calculate);
  incomeInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      calculate();
      incomeInput.blur();
    }
  });
</script>

<style>
  .calc-content {
    padding: 1.5rem;
  }

  .calc-content h2,
  .calc-content .page-title {
    font-size: 1.3rem;
    font-weight: 700;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .calc-content .page-title {
    font-size: 1.75rem;
    margin-top: 0;
  }

  .calc-content p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .calc-content ul {
    margin-left: 1.25rem;
    margin-bottom: 1rem;
  }

  .calc-content li {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .calc-error {
    color: #b91c1c;
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .result-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .meta-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.2rem 0.5rem;
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .result-row .label {
    color: var(--color-text-muted);
  }

  .result-row .value {
    font-weight: 600;
    color: var(--color-text);
  }

  .result-divider {
    height: 1px;
    background: var(--color-border);
    margin: 0.35rem 0;
  }

  .quick-chips {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin: -0.25rem 0 0.75rem;
  }

  .quick-chips-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .quick-chip {
    appearance: none;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
