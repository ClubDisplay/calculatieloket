---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AdSlot from "../components/AdSlot.astro";
import CrossSellCards from "../components/CrossSellCards.astro";
import CalculatorShell from "../components/calculator/CalculatorShell.astro";
import InputPanel from "../components/calculator/InputPanel.astro";
import ResultPanel from "../components/calculator/ResultPanel.astro";
import UseCasesPanel from "../components/calculator/UseCasesPanel.astro";
import FaqAccordion from "../components/calculator/FaqAccordion.astro";
import ToolFooter from "../components/calculator/ToolFooter.astro";
import SourceCards from "../components/SourceCards.astro";
import TrustPanel from "../components/calculator/TrustPanel.astro";
import FinancialJourney from "../components/calculator/FinancialJourney.astro";
import HowToSchema from "../components/calculator/HowToSchema.astro";
import InlineSources from "../components/calculator/InlineSources.astro";
import { calculateNetIncomeEstimate2026 } from "../lib/calculators/tax";
import { formatEuro } from "../lib/format/currency";
import { getRecommendations } from "../lib/recommendations/engine";

const title = "Bruto netto 2026 | Nettoloon berekenen | Calculatieloket.nl";
const description = "Bereken je bruto-netto salaris in 2026. Zie direct je nettoloon, loonheffing, vakantiegeld, pensioen en loonheffingskorting. Gebaseerd op officiële Belastingdienst tarieven.";

const defaultGross = 3000;
const defaultPension = 150;
const defaultLhk = true;

const initialResult = calculateNetIncomeEstimate2026({
  grossMonthlySalary: defaultGross,
  pensionAmount: defaultPension,
  applyLoonheffingskorting: defaultLhk,
});

const initialNoLhkResult = calculateNetIncomeEstimate2026({
  grossMonthlySalary: defaultGross,
  pensionAmount: defaultPension,
  applyLoonheffingskorting: false,
});

const initialRecommendations = getRecommendations({
  calculator: "bruto-netto",
  values: { grossMonthly: defaultGross, pensionAmount: defaultPension, lhk: defaultLhk ? 1 : 0 },
  result: initialResult,
});

const initialNetTax = Math.max(0, initialResult.incomeTax - initialResult.totalCredits);
const initialEffectiveRate = initialResult.grossYearly > 0
  ? ((initialNetTax / initialResult.grossYearly) * 100).toFixed(1).replace(".", ",")
  : "0,0";

const lastUpdated = "30 juni 2026";

const quickAmounts = [2500, 3000, 3500, 4000, 5000];

const useCases = [
  {
    id: "toeslagen",
    title: "Toeslagen berekenen",
    description: "Met een netto jaarinkomen van {{netto_jaar}} kun je checken of je recht hebt op huur- of zorgtoeslag.",
    href: "/toeslagen-calculator/",
    accent: "#059669",
  },
  {
    id: "hypotheek",
    title: "Hypotheek berekenen",
    description: "Op basis van een bruto jaarinkomen van {{bruto_jaar}} bekijk je een hypotheekindicatie.",
    href: "/hypotheek-calculator/",
    accent: "#d97706",
  },
  {
    id: "salaris",
    title: "Salaris vergelijken",
    description: "Vergelijk bruto {{bruto}} met netto {{netto}} op de salaris calculator.",
    href: "/salaris-calculator/",
    accent: "#2563eb",
  },
  {
    id: "zzp",
    title: "ZZP uurtarief berekenen",
    description: "Om {{netto}} netto per maand als ZZP'er te halen, bereken je het benodigde uurtarief.",
    href: "/zzp-calculator/",
    accent: "#7c3aed",
  },
];

const sources = [
  {
    label: "Officiële bron",
    title: "Belastingdienst — Box 1 tarieven 2026",
    description: "Actuele tarieven en schijven voor de inkomstenbelasting.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/boxen_en_tarieven/box_1/box_1",
  },
  {
    label: "Officiële bron",
    title: "Belastingdienst — Algemene heffingskorting 2026",
    description: "Tabel en maximale bedragen voor de algemene heffingskorting.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/heffingskortingen/algemene_heffingskorting/tabel-algemene-heffingskorting-2026",
  },
  {
    label: "Officiële bron",
    title: "Belastingdienst — Arbeidskorting 2026",
    description: "Tabel en maximale bedragen voor de arbeidskorting.",
    href: "https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/heffingskortingen/arbeidskorting/tabel-arbeidskorting-2026",
  },
];

const faq = [
  {
    question: "Waarom is dit een indicatie?",
    answer: "Dit is een schatting op basis van de meest voorkomende aannames: een voltijds dienstverband, 8% vakantiegeld, een standaard pensioenpremie en de loonheffingskorting. Je uiteindelijke nettoloon kan afwijken door cao-afwijkingen, bijzondere beloningen, lease-auto bijtelling, tweede baan of extra aftrekposten. Gebruik de uitkomst als richtlijn, niet als definitieve loonstrook.",
  },
  {
    question: "Wat is het verschil tussen bruto en netto salaris?",
    answer: "Bruto salaris is wat je werkgever je betaalt voor je werk, inclusief vakantiegeld. Netto salaris is het bedrag dat daadwerkelijk op je bankrekening komt, nadat inkomstenbelasting, premies en heffingskortingen zijn verrekend.",
  },
  {
    question: "Hoe werkt loonheffingskorting?",
    answer: "Loonheffingskorting is de verzamelnaam voor de algemene heffingskorting en arbeidskorting. Als je deze toepast, betaal je minder belasting. Je kunt de loonheffingskorting maar bij één werkgever tegelijk laten toepassen. ZZP’ers en mensen met meerdere banen moeten hier extra op letten.",
  },
  {
    question: "Waarom kan mijn loonstrook afwijken?",
    answer: "Je loonstrook kan afwijken door het soort pensioenfonds, extra verzekeringen via de werkgever, cao-regelingen, bijzondere beloningen, reiskostenvergoedingen, lease-auto bijtelling, of andere toeslagen en kortingen.",
  },
  {
    question: "Wordt pensioenpremie meegenomen?",
    answer: "Ja, je kunt je eigen werknemersbijdrage aan de pensioenpremie invullen. Deze wordt afgetrokken van je bruto inkomen voordat de belasting wordt berekend. De werkgeversbijdrage betaalt je werkgever zelf en zie je niet op je loonstrook.",
  },
  {
    question: "Welke tarieven gelden in 2026?",
    answer: "In 2026 zijn er twee Box 1 schijven: 35,75% over inkomen tot € 38.441, en 37,56% over inkomen van € 38.441 tot € 75.518. Boven de € 75.518 geldt 49,50%. De algemene heffingskorting is maximaal € 3.115 en loopt af vanaf € 29.736. De arbeidskorting loopt op tot maximaal € 5.685.",
  },
  {
    question: "Wat verandert er als ik mijn salaris verhoog?",
    answer: "Hoger salaris betekent meer inkomstenbelasting over de extra euro's. In 2026 betaal je over inkomen boven € 75.518 49,50% inkomstenbelasting. Boven bepaalde grenzen loopt de arbeidskorting ook sneller af, waardoor de netto winst per extra bruto euro kleiner wordt.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://calculatieloket.nl/",
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Bruto netto 2026",
      "item": "https://calculatieloket.nl/bruto-netto-2026/",
    },
  ],
};
---

<BaseLayout title={title} description={description} containerClass="container-wide">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <HowToSchema
    slot="head"
    name="Bruto netto salaris berekenen in 2026"
    description="Stappen om je netto salaris in 2026 te berekenen."
    totalTime="PT1M"
    steps={[
      { name: "Vul je bruto maandsalaris in", text: "Voer je bruto maandsalaris in, inclusief vakantiegeld." },
      { name: "Vul je pensioenpremie in", text: "Voer het werknemersdeel van je pensioenpremie per maand in." },
      { name: "Pas loonheffingskorting toe", text: "Zet de loonheffingskorting aan als je deze bij je werkgever hebt." },
      { name: "Bekijk je netto salaris", text: "De calculator toont je netto salaris per maand en per jaar." },
      { name: "Vergelijk met en zonder korting", text: "Zie direct het verschil als je de loonheffingskorting niet zou toepassen." },
    ]}
  />

  <AdSlot slot="1234567898" format="auto" style="min-height:280px" />

  <Breadcrumbs items={[
    { label: "Home", href: "/" },
    { label: "Inkomen", href: "/categorie/inkomen/" },
    { label: "Bruto netto 2026", current: true },
  ]} />

  <CalculatorShell title="Bruto netto 2026 berekenen" subtitle="Vul je bruto maandsalaris, pensioenpremie en loonheffingskorting in en zie direct een indicatie van je nettoloon.">
    <InputPanel title="Jouw situatie" slot="input">
      <div class="form-group">
        <label for="grossSalary">Bruto maandsalaris</label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="grossSalary" value={defaultGross} min="0" step="1" />
        </div>
      </div>

      <div class="quick-chips">
        <span class="quick-chips-label">Snel kiezen:</span>
        {quickAmounts.map((amount) => (
          <button type="button" class="quick-chip" data-amount={amount} data-analytics="quick-chip" data-analytics-category="calculator-page" data-analytics-action="select" data-analytics-label={amount}>
            &euro; {amount.toLocaleString("nl-NL")}
          </button>
        ))}
      </div>

      <div class="form-group">
        <label for="pensionAmount">Pensioenpremie per maand <span class="hint">(werknemersdeel)</span></label>
        <div class="input-prefix">
          <span class="prefix">&euro;</span>
          <input type="number" id="pensionAmount" value={defaultPension} min="0" step="1" />
        </div>
      </div>

      <div class="form-group">
        <div class="toggle-row">
          <span class="toggle-label" id="toggleLabel-loonheffingskorting">Loonheffingskorting toepassen</span>
          <label class="toggle" for="loonheffingskorting">
            <input type="checkbox" id="loonheffingskorting" checked={defaultLhk} aria-labelledby="toggleLabel-loonheffingskorting" />
            <span class="slider"></span>
          </label>
        </div>
      </div>

      <button id="berekenBtn" class="btn btn-primary btn-lg" style="width:100%" data-analytics="cta" data-analytics-category="calculator-page" data-analytics-action="click" data-analytics-label="bereken">Bereken netto</button>
      <p class="calc-error" id="calcError" style="display:none;">Vul een geldig bruto maandsalaris in (hoger dan 0).</p>
    </InputPanel>

    <ResultPanel
      slot="result"
      title="Netto salaris"
      heroLabel="Jouw netto salaris per maand"
      heroValue={formatEuro(initialResult.netMonthly, 0)}
      heroSubtext="Indicatie op basis van 2026-tarieven"
      badge="Indicatie"
    >
      <div class="result-meta">
        <span class="meta-badge">Bijgewerkt: 2026</span>
        <span class="meta-badge">Bron: Belastingdienst</span>
      </div>

      <div class="result-row"><span class="label">Bruto maandsalaris</span><span class="value" id="detailGross">{formatEuro(defaultGross, 0)}</span></div>
      <div class="result-row"><span class="label">Bruto jaarsalaris (incl. 8% vakantiegeld)</span><span class="value" id="detailGrossYear">{formatEuro(initialResult.grossYearly, 0)}</span></div>
      <div class="result-row"><span class="label">Vakantiegeld (8%)</span><span class="value" id="detailHoliday">{formatEuro(initialResult.breakdown.holidayPay, 0)}</span></div>
      <div class="result-row"><span class="label">Pensioenpremie per jaar</span><span class="value" id="detailPension">{formatEuro(initialResult.breakdown.pensionAmount, 0)}</span></div>
      <div class="result-divider"></div>
      <div class="result-row"><span class="label">Belastbaar jaarinkomen</span><span class="value" id="detailTaxable">{formatEuro(initialResult.taxableIncome, 0)}</span></div>
      <div class="result-row"><span class="label">Inkomstenbelasting</span><span class="value" id="detailTax">{formatEuro(initialResult.incomeTax, 0)}</span></div>
      <div class="result-row"><span class="label">Heffingskortingen</span><span class="value" id="detailCredits">{formatEuro(initialResult.totalCredits, 0)}</span></div>
      <div class="result-row"><span class="label">Loonheffing na kortingen</span><span class="value" id="detailNetTax">{formatEuro(initialNetTax, 0)}</span></div>
      <div class="result-row"><span class="label">Effectief belastingtarief</span><span class="value" id="detailEffectiveRate">{initialEffectiveRate}%</span></div>
      <div class="result-divider"></div>
      <div class="result-row result-row-total"><span class="label">Netto per jaar</span><span class="value" id="detailNetYear">{formatEuro(initialResult.netYearly, 0)}</span></div>

      <div class="result-brackets" id="resultBrackets">
        <div class="result-brackets-title">Belastingschijven 2026</div>
        <div class="result-bracket-row"><span class="label">Tot € 38.441</span><span class="value">35,75%</span></div>
        <div class="result-bracket-row"><span class="label">€ 38.441 – € 75.518</span><span class="value">37,56%</span></div>
        <div class="result-bracket-row"><span class="label">Boven € 75.518</span><span class="value">49,50%</span></div>
      </div>

      <div class="result-comparison" id="lhkComparison">
        <div class="result-comparison-title">Loonheffingskorting</div>
        <div class="result-row"><span class="label">Netto met korting</span><span class="value" id="detailNetWithLhk">{formatEuro(initialResult.netMonthly, 0)}</span></div>
        <div class="result-row"><span class="label">Netto zonder korting</span><span class="value" id="detailNetWithoutLhk">{formatEuro(initialNoLhkResult.netMonthly, 0)}</span></div>
        <div class="result-row result-row-total"><span class="label">Voordeel per maand</span><span class="value" id="detailLhkBenefit">{formatEuro(initialResult.netMonthly - initialNoLhkResult.netMonthly, 0)}</span></div>
      </div>

      <button class="copy-link-btn" id="copyLinkBtn" type="button" slot="actions" data-analytics="copy-link" data-analytics-category="calculator-page" data-analytics-action="click" data-analytics-label="copy-link" aria-label="Deel deze berekening">
        <span class="copy-link-icon" aria-hidden="true">🔗</span>
        <span class="copy-link-text">Deel deze berekening</span>
      </button>

      <FinancialJourney recommendations={initialRecommendations} />

      <InlineSources title="Gebruikte bronnen" items={sources} />
    </ResultPanel>

    <TrustPanel slot="result" lastUpdated={lastUpdated} sourcesId="calculator-sources" />

    <UseCasesPanel title="Wat kun je hiermee?" items={useCases} slot="useCases" />

    <SourceCards id="calculator-sources" title="Bronnen" items={sources} slot="sources" />

    <FaqAccordion title="Veelgestelde vragen" items={faq} slot="faq" />

    <ToolFooter categoryLink="/categorie/inkomen/" categoryLabel="Inkomen"
      slot="footer"
      disclaimer="Deze berekening is een indicatie op basis van de ingevoerde gegevens en de bekende belastingtarieven van 2026. Je loonstrook kan afwijken door pensioen, cao, werkgever, bijzondere beloningen en persoonlijke situatie. Gebruik de uitkomst als richtlijn, niet als definitief bedrag. Raadpleeg bij belangrijke financiële beslissingen een financieel adviseur."
      lastUpdated={lastUpdated}
    />
  </CalculatorShell>

  <div class="calculator-card calc-content" id="calculator-content">
    <p class="badge-indicatie">Indicatie 2026</p>

    <h2 class="page-title">Bruto netto 2026</h2>
    <p>Met deze bruto-netto calculator bereken je eenvoudig hoeveel je netto per maand (en per jaar) overhoudt in 2026. We gebruiken de actuele Box 1 inkomstenbelastingtarieven, vakantiegeld (8%), loonheffingskorting, algemene heffingskorting en arbeidskorting.</p>
    <p>Wil je een ander bruto bedrag vergelijken? Gebruik de <a href="/salaris-calculator/">salaris calculator</a>. Voor je hypotheekindicatie, toeslagen of ZZP-uurtarief gebruik je de <a href="/hypotheek-calculator/">hypotheek calculator</a>, <a href="/toeslagen-calculator/">toeslagen calculator</a> of <a href="/zzp-calculator/">ZZP calculator</a>.</p>

    <h2>Waarom kun je deze berekening vertrouwen?</h2>
    <p>Deze calculator is gebaseerd op de officiële <a href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/boxen_en_tarieven/box_1/box_1" target="_blank" rel="noopener">Box 1 tarieven</a>, <a href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/heffingskortingen/algemene_heffingskorting/tabel-algemene-heffingskorting-2026" target="_blank" rel="noopener">algemene heffingskorting</a> en <a href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/prive/inkomstenbelasting/heffingskortingen_boxen_tarieven/heffingskortingen/arbeidskorting/tabel-arbeidskorting-2026" target="_blank" rel="noopener">arbeidskorting</a> van de Belastingdienst voor 2026. De uitkomst is een indicatie: je loonstrook kan afwijken door cao, pensioenregeling, bijtelling en andere persoonlijke factoren.</p>

    <h2>Tarieven 2026</h2>
    <p>Voor 2026 gelden de volgende Box 1 tarieven (inkomstenbelasting):</p>
    <table class="rate-table">
      <thead>
        <tr><th>Schijf</th><th>Inkomen</th><th>Tarief</th></tr>
      </thead>
      <tbody>
        <tr><td>1</td><td>Tot € 38.441</td><td>35,75%</td></tr>
        <tr><td>2</td><td>€ 38.441 - € 75.518</td><td>37,56%</td></tr>
        <tr><td>3</td><td>Boven € 75.518</td><td>49,50%</td></tr>
      </tbody>
    </table>
    <p>De percentages gelden voor mensen die de AOW-leeftijd nog niet hebben bereikt. Boven de 65 jaar gelden vaak lagere tarieven.</p>

    <h2>Factoren die je nettoloon beïnvloeden</h2>
    <ul class="calc-list">
      <li><strong>Bruto salaris:</strong> hoe hoger het brutoloon, hoe meer belasting je betaalt.</li>
      <li><strong>Pensioenpremie:</strong> een hogere werknemersbijdrage verlaagt je belastbare inkomen.</li>
      <li><strong>Loonheffingskorting:</strong> met deze korting houd je meer netto over.</li>
      <li><strong>Vakantiegeld:</strong> 8% vakantiegeld telt mee in je jaarsalaris.</li>
      <li><strong>Bijtelling:</strong> een lease-auto of andere vergoedingen kunnen je belastbaar inkomen verhogen.</li>
      <li><strong>Extra inkomsten:</strong> een tweede baan of bonus kan je in een hogere belastingschijf plaatsen.</li>
    </ul>

    <h2>Voorbeeldberekeningen</h2>
    <p>Onderstaande voorbeelden geven een indicatie op basis van 2026 tarieven, inclusief vakantiegeld en loonheffingskorting:</p>
    <div class="example-grid">
      <div class="example-card">
        <strong>€ 2.500 bruto</strong>
        <p>Netto per maand: circa € 2.240</p>
      </div>
      <div class="example-card">
        <strong>€ 3.500 bruto</strong>
        <p>Netto per maand: circa € 2.760</p>
      </div>
      <div class="example-card">
        <strong>€ 5.000 bruto</strong>
        <p>Netto per maand: circa € 3.490</p>
      </div>
    </div>

    <h2>Veelgemaakte fouten</h2>
    <ul class="calc-list">
      <li><strong>Geen vakantiegeld meerekenen:</strong> je bruto-jaarsalaris is inclusief 8% vakantiegeld.</li>
      <li><strong>Pensioen vergeten:</strong> de werknemersbijdrage wordt afgetrokken vóór de belasting.</li>
      <li><strong>Loonheffingskorting onterecht dubbel toegepast:</strong> je kunt deze maar bij één werkgever tegelijk hebben.</li>
      <li><strong>Extra inkomsten negeren:</strong> verdien je meer? Dan verandert je belastingschijf en korting.</li>
    </ul>
  </div>

  <CrossSellCards
    title="Ook handig om te berekenen"
    items={[
      { title: "Salaris vergelijken", description: "Bereken netto bij een ander bruto bedrag.", href: "/salaris-calculator/", accent: "#2563eb" },
      { title: "Hoeveel hypotheek kan ik krijgen?", description: "Indicatie op basis van je inkomen.", href: "/hypotheek-calculator/", accent: "#d97706" },
      { title: "Wat moet ik als ZZP'er vragen?", description: "Van gewenst netto naar uurtarief.", href: "/zzp-calculator/", accent: "#7c3aed" },
    ]}
  />
</BaseLayout>

<script>
  import { calculateNetIncomeEstimate2026 } from "../lib/calculators/tax";
  import { formatEuro } from "../lib/format/currency";
  import { getRecommendations } from "../lib/recommendations/engine";
  import { updateFinancialJourney } from "../lib/recommendations/client";

  const grossInput = document.getElementById("grossSalary") as HTMLInputElement;
  const pensionInput = document.getElementById("pensionAmount") as HTMLInputElement;
  const lhCheckbox = document.getElementById("loonheffingskorting") as HTMLInputElement;
  const hero = document.querySelector(".calc-result-panel-hero") as HTMLElement;
  const errorBox = document.getElementById("calcError") as HTMLElement;
  const berekenBtn = document.getElementById("berekenBtn") as HTMLButtonElement;
  const copyLinkBtn = document.getElementById("copyLinkBtn") as HTMLButtonElement;
  const financialJourney = document.querySelector(".calc-financial-journey") as HTMLElement;

  const detailGross = document.getElementById("detailGross")!;
  const detailGrossYear = document.getElementById("detailGrossYear")!;
  const detailHoliday = document.getElementById("detailHoliday")!;
  const detailPension = document.getElementById("detailPension")!;
  const detailTaxable = document.getElementById("detailTaxable")!;
  const detailTax = document.getElementById("detailTax")!;
  const detailCredits = document.getElementById("detailCredits")!;
  const detailNetTax = document.getElementById("detailNetTax")!;
  const detailEffectiveRate = document.getElementById("detailEffectiveRate")!;
  const detailNetYear = document.getElementById("detailNetYear")!;
  const detailNetWithLhk = document.getElementById("detailNetWithLhk")!;
  const detailNetWithoutLhk = document.getElementById("detailNetWithoutLhk")!;
  const detailLhkBenefit = document.getElementById("detailLhkBenefit")!;

  const formatNumber = (n: number, decimals = 0): string =>
    n.toFixed(decimals).replace(".", ",").replace(/\B(?=(\d{3})+(?!\d))/g, ".");

  function updateUseCases(gross: number, netMonthly: number, netYearly: number, grossYearly: number) {
    const replacements: Record<string, string> = {
      "{{bruto}}": formatNumber(gross, 0),
      "{{bruto_jaar}}": formatNumber(grossYearly, 0),
      "{{netto}}": formatNumber(netMonthly, 0),
      "{{netto_jaar}}": formatNumber(netYearly, 0),
    };

    document.querySelectorAll("[data-usecase]").forEach((card) => {
      const desc = card.querySelector(".calc-use-cases-card-desc") as HTMLElement;
      if (!desc) return;
      const template = desc.dataset.template;
      if (!template) return;
      let text = template;
      Object.entries(replacements).forEach(([key, value]) => {
        text = text.replaceAll(key, value);
      });
      desc.textContent = text;
    });
  }

  function updateUrl() {
    const params = new URLSearchParams(window.location.search);
    const gross = parseFloat(grossInput.value) || 0;
    const pension = parseFloat(pensionInput.value) || 0;

    if (gross > 0) params.set("bruto", gross.toString());
    else params.delete("bruto");

    if (pension > 0) params.set("pensioen", pension.toString());
    else params.delete("pensioen");

    params.set("lhk", lhCheckbox.checked ? "1" : "0");

    const newUrl = `${window.location.pathname}?${params.toString()}`;
    window.history.replaceState(null, "", newUrl);
  }

  function calculate() {
    const gross = parseFloat(grossInput.value);
    const pension = parseFloat(pensionInput.value) || 0;
    const hasLHK = lhCheckbox.checked;

    if (!Number.isFinite(gross) || gross <= 0) {
      errorBox.style.display = "block";
      hero.textContent = "—";
      detailGross.textContent = "—";
      detailGrossYear.textContent = "—";
      detailHoliday.textContent = "—";
      detailPension.textContent = "—";
      detailTaxable.textContent = "—";
      detailTax.textContent = "—";
      detailCredits.textContent = "—";
      detailNetTax.textContent = "—";
      detailEffectiveRate.textContent = "—";
      detailNetYear.textContent = "—";
      detailNetWithLhk.textContent = "—";
      detailNetWithoutLhk.textContent = "—";
      detailLhkBenefit.textContent = "—";
      return;
    }

    errorBox.style.display = "none";

    const result = calculateNetIncomeEstimate2026({
      grossMonthlySalary: gross,
      pensionAmount: pension,
      applyLoonheffingskorting: hasLHK,
    });

    if (!result.valid) {
      errorBox.style.display = "block";
      hero.textContent = "—";
      return;
    }

    const netTax = Math.max(0, result.incomeTax - result.totalCredits);
    const effectiveRate =
      result.grossYearly > 0
        ? ((netTax / result.grossYearly) * 100).toFixed(1).replace(".", ",")
        : "0,0";

    hero.textContent = formatEuro(result.netMonthly, 0);
    detailGross.textContent = formatEuro(gross, 0);
    detailGrossYear.textContent = formatEuro(result.grossYearly, 0);
    detailHoliday.textContent = formatEuro(result.breakdown.holidayPay, 0);
    detailPension.textContent = formatEuro(result.breakdown.pensionAmount, 0);
    detailTaxable.textContent = formatEuro(result.taxableIncome, 0);
    detailTax.textContent = formatEuro(result.incomeTax, 0);
    detailCredits.textContent = formatEuro(result.totalCredits, 0);
    detailNetTax.textContent = formatEuro(netTax, 0);
    detailEffectiveRate.textContent = `${effectiveRate}%`;
    detailNetYear.textContent = formatEuro(result.netYearly, 0);

    const resultNoLhk = calculateNetIncomeEstimate2026({
      grossMonthlySalary: gross,
      pensionAmount: pension,
      applyLoonheffingskorting: false,
    });
    detailNetWithLhk.textContent = formatEuro(result.netMonthly, 0);
    detailNetWithoutLhk.textContent = formatEuro(resultNoLhk.netMonthly, 0);
    detailLhkBenefit.textContent = formatEuro(result.netMonthly - resultNoLhk.netMonthly, 0);

    updateUseCases(gross, result.netMonthly, result.netYearly, result.grossYearly);

    if (financialJourney) {
      const recs = getRecommendations({
        calculator: "bruto-netto",
        values: { grossMonthly: gross, pensionAmount: pension, lhk: hasLHK ? 1 : 0 },
        result,
      });
      updateFinancialJourney(financialJourney, recs);
    }

    updateUrl();
  }

  function applyUrlParams() {
    const params = new URLSearchParams(window.location.search);
    const gross = params.get("bruto");
    const pension = params.get("pensioen");
    const lhk = params.get("lhk");

    if (gross !== null) grossInput.value = gross;
    if (pension !== null) pensionInput.value = pension;
    if (lhk !== null) lhCheckbox.checked = lhk === "1";
  }

  function initQuickChips() {
    document.querySelectorAll(".quick-chip").forEach((btn) => {
      btn.addEventListener("click", () => {
        const amount = (btn as HTMLElement).dataset.amount;
        if (amount) {
          grossInput.value = amount;
          grossInput.focus();
          calculate();
        }
      });
    });
  }

  function initCopyLink() {
    copyLinkBtn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const textEl = copyLinkBtn.querySelector(".copy-link-text") as HTMLElement;
        const originalText = textEl.textContent || "Deel deze berekening";
        textEl.textContent = "Link gekopieerd";
        copyLinkBtn.classList.add("copy-link-success");
        setTimeout(() => {
          textEl.textContent = originalText;
          copyLinkBtn.classList.remove("copy-link-success");
        }, 2000);
      } catch (err) {
        console.error("Kon link niet kopiëren", err);
      }
    });
  }

  applyUrlParams();
  calculate();
  initQuickChips();
  initCopyLink();

  grossInput.addEventListener("input", calculate);
  pensionInput.addEventListener("input", calculate);
  lhCheckbox.addEventListener("change", calculate);
  berekenBtn.addEventListener("click", calculate);
  grossInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      calculate();
      grossInput.blur();
    }
  });
</script>

