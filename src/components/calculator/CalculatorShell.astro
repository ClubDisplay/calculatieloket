---
interface Props {
  title?: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<article class="calc-shell">
  {title && <h1 class="calc-shell-title">{title}</h1>}
  {subtitle && <p class="calc-shell-subtitle">{subtitle}</p>}

  <div class="calc-shell-grid">
    <div class="calc-shell-main">
      <slot name="input" />
      <slot name="result" />
    </div>
    <div class="calc-shell-side">
      <slot name="useCases" />
      <slot name="nextSteps" />
      <slot name="sources" />
      <slot name="faq" />
    </div>
  </div>

  <slot name="footer" />
</article>

<style>
  .calc-shell {
    padding: 0.5rem 0 2rem;
  }

  .calc-shell-title {
    font-size: clamp(1.6rem, 5vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .calc-shell-subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
    max-width: 60ch;
  }

  .calc-shell-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  .calc-shell-main,
  .calc-shell-side {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 900px) {
    .calc-shell-grid {
      grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
      align-items: start;
    }
  }
</style>
