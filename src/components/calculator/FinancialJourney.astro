---
interface Step {
  id: string;
  label: string;
  description: string;
  href: string;
}

interface Props {
  title?: string;
  steps?: Step[];
  income?: number;
  partnerIncome?: number;
  totalIncome?: number;
  rent?: number;
  isCouple?: boolean;
}

const {
  title = "Je volgende stap",
  steps: customSteps,
  income = 0,
  partnerIncome = 0,
  totalIncome = 0,
  rent = 0,
  isCouple = false,
} = Astro.props;

const primaryIncome = income;
const brutoMonthly = primaryIncome > 0 ? Math.round(primaryIncome / 12) : 0;
const totalIncomeValue = totalIncome > 0 ? totalIncome : primaryIncome + partnerIncome;

const defaultSteps: Step[] = [
  {
    id: "netto",
    label: "Netto salaris berekenen",
    description: "Bekijk wat je netto overhoudt van dit inkomen.",
    href: brutoMonthly > 0 ? `/salaris-calculator/?bruto=${brutoMonthly}` : "/salaris-calculator/",
  },
  {
    id: "hypotheek",
    label: "Hypotheek berekenen",
    description: "Wat kan je lenen met dit jaarinkomen?",
    href:
      totalIncomeValue > 0
        ? `/hypotheek-calculator/?inkomen=${totalIncomeValue}&partner=${isCouple ? 1 : 0}&partnerInkomen=${partnerIncome}`
        : "/hypotheek-calculator/",
  },
  {
    id: "zzp",
    label: "ZZP vergelijken",
    description: "Hoeveel moet je als ZZP'er vragen?",
    href: "/zzp-calculator/",
  },
  {
    id: "vakantiegeld",
    label: "Vakantiegeld berekenen",
    description: "Binnenkort beschikbaar.",
    href: "#",
  },
];

const steps = customSteps ?? defaultSteps;
---

<div
  class="calc-financial-journey"
  data-income={income}
  data-partner-income={partnerIncome}
  data-total-income={totalIncome}
  data-rent={rent}
  data-couple={isCouple}
>
  <h3 class="calc-financial-journey-title">{title}</h3>
  <div class="calc-financial-journey-steps">
    {
      steps.map((step) => (
        <a href={step.href} class="calc-financial-journey-step" data-step={step.id}>
          <span class="step-check">✓</span>
          <span class="step-content">
            <span class="step-label">{step.label}</span>
            <span class="step-desc">{step.description}</span>
          </span>
        </a>
      ))
    }
  </div>
</div>

<style>
  .calc-financial-journey {
    margin-top: 0.75rem;
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .calc-financial-journey-title {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .calc-financial-journey-steps {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .calc-financial-journey-step {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.7rem;
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s, border-color 0.15s;
    border: 1px solid transparent;
  }

  .calc-financial-journey-step:hover,
  .calc-financial-journey-step:focus-visible {
    background: var(--color-primary-light);
    border-color: var(--color-primary);
  }

  .calc-financial-journey-step[data-step="vakantiegeld"] {
    opacity: 0.7;
    cursor: default;
  }

  .calc-financial-journey-step[data-step="vakantiegeld"]:hover,
  .calc-financial-journey-step[data-step="vakantiegeld"]:focus-visible {
    background: transparent;
    border-color: transparent;
  }

  .step-check {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--color-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .step-content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .step-label {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .step-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
