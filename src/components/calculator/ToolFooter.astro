---
interface Props {
  disclaimer?: string;
  lastUpdated?: string;
  categoryLink?: string;
  categoryLabel?: string;
}

const {
  disclaimer = "Deze berekening is een indicatie. Controleer belangrijke bedragen altijd via officiële bronnen of een financieel adviseur.",
  lastUpdated,
  categoryLink,
  categoryLabel,
} = Astro.props;

const categorySlug = categoryLabel
  ? categoryLabel.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, "")
  : "";
---

<div class="calc-tool-footer">
  {categoryLink && categoryLabel && (
    <p class="calc-tool-footer-category">
      Bekijk meer calculators in de categorie{" "}
      <a
        href={categoryLink}
        data-analytics="tool-footer-category-link"
        data-analytics-category="calculator-page"
        data-analytics-action="click"
        data-analytics-label={categorySlug}
      >
        {categoryLabel}
      </a>.
    </p>
  )}
  <p class="calc-tool-footer-disclaimer">{disclaimer}</p>
  {lastUpdated && (
    <p class="calc-tool-footer-updated">Laatst bijgewerkt: {lastUpdated}</p>
  )}
</div>

<style>
  .calc-tool-footer {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .calc-tool-footer-category {
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .calc-tool-footer-category a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: underline;
  }

  .calc-tool-footer-category a:hover {
    text-decoration: none;
  }

  .calc-tool-footer-disclaimer {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .calc-tool-footer-updated {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }
</style>
