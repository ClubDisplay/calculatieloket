---
import FaqAccordion from "../calculator/FaqAccordion.astro";

interface Item {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  items: Item[];
}

const { title = "Veelgestelde vragen", items } = Astro.props;
---

<section class="cat-faq" aria-labelledby="catFaqTitle">
  <h2 id="catFaqTitle" class="cat-faq-title">{title}</h2>
  <FaqAccordion items={items} />
</section>

<style>
  .cat-faq {
    margin-bottom: 1.5rem;
  }

  .cat-faq-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  @media (max-width: 640px) {
    .cat-faq-title {
      font-size: 1.15rem;
    }
  }
</style>
