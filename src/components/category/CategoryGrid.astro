---
interface Item {
  title: string;
  href: string;
  description: string;
  badge?: string;
  icon: string;
  accent: string;
}

interface Props {
  title: string;
  items: Item[];
  analyticsCategory?: string;
}

const { title, items, analyticsCategory = "category-page" } = Astro.props;
const slugify = (href: string) => href.replace(/^\//, "").replace(/\/$/, "").replace(/\//g, "-");
---

<section class="cat-grid-section" aria-labelledby="catGridTitle">
  <h2 id="catGridTitle" class="cat-grid-section-title">{title}</h2>
  <div class="cat-grid">
    {items.map((item) => (
      <a
        href={item.href}
        class="cat-card"
        style={`--cat-accent: ${item.accent}`}
        data-analytics="category-calculator-card"
        data-analytics-category={analyticsCategory}
        data-analytics-action="click"
        data-analytics-label={slugify(item.href)}
      >
        <span class="cat-card-icon" set:html={item.icon} />
        <div class="cat-card-body">
          <h3 class="cat-card-title">
            {item.title}
            {item.badge && <span class="cat-card-badge">{item.badge}</span>}
          </h3>
          <p class="cat-card-description">{item.description}</p>
          <span class="cat-card-cta">Bereken direct &rarr;</span>
        </div>
        <span class="cat-card-arrow" aria-hidden="true">&rarr;</span>
      </a>
    ))}
  </div>
</section>

<style>
  .cat-grid-section {
    margin-bottom: 1.5rem;
  }

  .cat-grid-section-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .cat-card {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
    position: relative;
  }

  .cat-card:hover,
  .cat-card:focus-visible {
    box-shadow: var(--shadow-lg);
    border-color: var(--cat-accent, var(--color-primary));
    text-decoration: none;
    transform: translateY(-1px);
  }

  .cat-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    flex-shrink: 0;
    color: var(--cat-accent, var(--color-primary));
    background: var(--color-primary-light);
  }

  .cat-card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cat-card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .cat-card-badge {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text);
    background: var(--color-primary-light);
    border: 1px solid var(--cat-accent, var(--color-primary));
    padding: 1px 6px;
    border-radius: 6px;
  }

  .cat-card-description {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  .cat-card-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 0.25rem;
  }

  .cat-card-arrow {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
    margin-top: 0.15rem;
    transition: transform 0.15s, color 0.15s;
  }

  .cat-card:hover .cat-card-arrow,
  .cat-card:focus-visible .cat-card-arrow {
    transform: translateX(3px);
    color: var(--cat-accent, var(--color-primary));
  }

  @media (max-width: 960px) {
    .cat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }

    .cat-card {
      padding: 1rem;
    }

    .cat-card-icon {
      width: 44px;
      height: 44px;
    }
  }
</style>
