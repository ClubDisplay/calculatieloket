---
interface Category {
  id: string;
  label: string;
  href: string;
}

interface Props {
  current?: string;
  categories: Category[];
  title?: string;
  analyticsCategory?: string;
}

const { current, categories, title = "Gerelateerde categorieën", analyticsCategory = "category-page" } = Astro.props;
const related = current ? categories.filter((c) => c.id !== current) : categories;
---

<section class="cat-related" aria-labelledby="catRelatedTitle">
  <h2 id="catRelatedTitle" class="cat-related-title">{title}</h2>
  <div class="cat-related-grid">
    {related.map((cat) => (
      <a
        href={cat.href}
        class="cat-related-card"
        data-analytics="category-card"
        data-analytics-category={analyticsCategory}
        data-analytics-action="click"
        data-analytics-label={cat.id}
      >
        <span class="cat-related-label">{cat.label}</span>
        <span class="cat-related-arrow" aria-hidden="true">&rarr;</span>
      </a>
    ))}
  </div>
</section>

<style>
  .cat-related {
    margin-bottom: 1.5rem;
  }

  .cat-related-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .cat-related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .cat-related-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-text);
    font-weight: 600;
    transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
  }

  .cat-related-card:hover,
  .cat-related-card:focus-visible {
    box-shadow: var(--shadow);
    border-color: var(--color-primary);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .cat-related-label {
    font-size: 1rem;
  }

  .cat-related-arrow {
    color: var(--color-primary);
    transition: transform 0.15s;
  }

  .cat-related-card:hover .cat-related-arrow,
  .cat-related-card:focus-visible .cat-related-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .cat-related-grid {
      grid-template-columns: 1fr;
    }

    .cat-related-title {
      font-size: 1.15rem;
    }
  }
</style>
