---
import ClientRouter from "astro/components/ClientRouter.astro";
import CookieConsent from "../components/CookieConsent.astro";

const { title, description } = Astro.props;
const adsenseId = import.meta.env.PUBLIC_ADSENSE_ID;
const adsEnabled = import.meta.env.PUBLIC_ADS_ENABLED === "true";
const canonical = new URL(Astro.url.pathname, "https://calculatieloket.nl").href;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="TRZKC7ND9bcmpINNlT34pqz7ZpoI5C_xIXV-Ypg903c" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/logo_Calculatieloket.png" />

    <script is:inline>
      if (location.hostname.includes("pages.dev")) {
        const meta = document.createElement("meta");
        meta.name = "robots";
        meta.content = "noindex";
        document.head.appendChild(meta);
      }
    </script>

    <ClientRouter />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/logo_Calculatieloket.png" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {adsEnabled && adsenseId && (
      <>
        <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
        <link rel="preconnect" href="https://googleads.g.doubleclick.net" />
        <link rel="preconnect" href="https://tpc.googlesyndication.com" />
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseId}`}
          crossorigin="anonymous"
        ></script>
      </>
    )}

    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Calculatieloket.nl",
        url: "https://calculatieloket.nl",
        description: "Gratis online calculators voor BTW, salaris, hypotheek en meer. Snel, duidelijk en eenvoudig.",
        inLanguage: "nl-NL",
        publisher: {
          "@type": "Organization",
          name: "Calculatieloket.nl",
          logo: {
            "@type": "ImageObject",
            url: "https://calculatieloket.nl/logo_Calculatieloket.png",
          },
        },
      })}
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="site-brand" aria-label="Calculatieloket.nl home">
          <img
            src="/logo-calculatieloket-header-tight.png"
            alt="Calculatieloket.nl"
            class="site-logo"
          />
        </a>

        <nav class="site-nav" aria-label="Hoofdnavigatie">
          <a href="/btw-calculator">BTW</a>
          <a href="/salaris-calculator">Salaris</a>
          <a href="/hypotheek-calculator">Hypotheek</a>
          <a href="/zzp-calculator">ZZP</a>
          <a href="/toeslagen-calculator">Toeslagen</a>
        </nav>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer>
      <div class="container">
        <div class="footer-links">
          <a href="/privacy">Privacy</a>
          <a href="/cookies">Cookies</a>
          <a href="/disclaimer">Disclaimer</a>
          <a href="/over-ons">Over ons</a>
          <a href="/contact">Contact</a>
        </div>
        <p>&copy; {new Date().getFullYear()} Calculatieloket.nl &mdash; Snelle, duidelijke online calculators</p>
      </div>
    </footer>
    <CookieConsent />
  </body>
</html>

<style>
  @import "../styles/global.css";
</style>
