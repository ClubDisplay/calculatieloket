---
import ClientRouter from "astro/components/ClientRouter.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { categoryList } from "../lib/category-icons";

const { title, description } = Astro.props;
const containerClass = Astro.props.containerClass ?? "container";
const noindex = Astro.props.noindex ?? false;
const adsenseId = import.meta.env.PUBLIC_ADSENSE_ID;
const adsEnabled = import.meta.env.PUBLIC_ADS_ENABLED === "true";
const canonical = new URL(Astro.url.pathname, "https://calculatieloket.nl").href;
const pathname = Astro.url.pathname;
const isCurrentPage = (href: string) => {
  if (href === "/") return pathname === "/";
  const base = href.replace(/\/$/, "");
  return pathname === base + "/" || pathname.startsWith(base + "/");
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Calculatieloket.nl",
  url: "https://calculatieloket.nl",
  description: "Gratis online calculators voor BTW, salaris, hypotheek en meer. Snel, duidelijk en eenvoudig.",
  inLanguage: "nl-NL",
  publisher: {
    "@type": "Organization",
    name: "Calculatieloket.nl",
    logo: {
      "@type": "ImageObject",
      url: "https://calculatieloket.nl/logo_Calculatieloket.png",
    },
  },
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="TRZKC7ND9bcmpINNlT34pqz7ZpoI5C_xIXV-Ypg903c" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href="/logo_Calculatieloket.png" />

    <slot name="head" />

    <script is:inline>
      if (location.hostname.includes("pages.dev")) {
        const meta = document.createElement("meta");
        meta.name = "robots";
        meta.content = "noindex";
        document.head.appendChild(meta);
      }
    </script>

    <ClientRouter />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/logo_Calculatieloket.png" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {adsEnabled && adsenseId && (
      <>
        <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
        <link rel="preconnect" href="https://googleads.g.doubleclick.net" />
        <link rel="preconnect" href="https://tpc.googlesyndication.com" />
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseId}`}
          crossorigin="anonymous"
        ></script>
      </>
    )}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Spring naar inhoud</a>
    <header class="site-header">
      <div class="site-header-inner">
        <a
          href="/"
          class="site-brand"
          aria-label="Calculatieloket.nl home"
          data-analytics="header-link"
          data-analytics-category="header"
          data-analytics-action="click"
          data-analytics-label="home"
        >
          <img
            src="/logo-calculatieloket-header-tight.png"
            alt="Calculatieloket.nl"
            class="site-logo"
            width="1271"
            height="329"
            loading="eager"
            decoding="async"
          />
        </a>

        <button
          class="site-nav-toggle"
          id="siteNavToggle"
          type="button"
          aria-expanded="false"
          aria-controls="siteNavMenu"
          aria-label="Menu openen"
          data-analytics="header-menu-toggle"
          data-analytics-category="header"
          data-analytics-action="click"
          data-analytics-label="menu"
        >
          <span class="site-nav-burger" aria-hidden="true"></span>
        </button>

        <nav class="site-nav" id="siteNavMenu" aria-label="Hoofdnavigatie">
          <div class="site-nav-section">
            <a
              href="/"
              class="site-nav-link"
              aria-current={isCurrentPage("/") ? "page" : undefined}
              data-analytics="header-link"
              data-analytics-category="header"
              data-analytics-action="click"
              data-analytics-label="home"
            >
              Home
            </a>
          </div>
          <div class="site-nav-section site-nav-dropdown">
            <button
              type="button"
              class="site-nav-dropdown-toggle"
              id="siteNavDropdownToggle"
              aria-expanded="false"
              aria-controls="siteNavDropdown"
              data-analytics="header-dropdown-toggle"
              data-analytics-category="header"
              data-analytics-action="click"
              data-analytics-label="categories"
            >
              Categorieën
            </button>
            <div class="site-nav-dropdown-menu" id="siteNavDropdown">
              {categoryList.map((cat) => (
                <a
                  href={cat.href}
                  class="site-nav-dropdown-link"
                  aria-current={isCurrentPage(cat.href) ? "page" : undefined}
                  data-analytics="header-link"
                  data-analytics-category="header"
                  data-analytics-action="click"
                  data-analytics-label={cat.id}
                >
                  {cat.label}
                </a>
              ))}
            </div>
          </div>
          <div class="site-nav-section">
            <a
              href="/btw-calculator/"
              class="site-nav-link"
              aria-current={isCurrentPage("/btw-calculator/") ? "page" : undefined}
              data-analytics="header-link"
              data-analytics-category="header"
              data-analytics-action="click"
              data-analytics-label="btw"
            >
              BTW
            </a>
            <a
              href="/salaris-calculator/"
              class="site-nav-link"
              aria-current={isCurrentPage("/salaris-calculator/") ? "page" : undefined}
              data-analytics="header-link"
              data-analytics-category="header"
              data-analytics-action="click"
              data-analytics-label="salaris"
            >
              Salaris
            </a>
            <a
              href="/hypotheek-calculator/"
              class="site-nav-link"
              aria-current={isCurrentPage("/hypotheek-calculator/") ? "page" : undefined}
              data-analytics="header-link"
              data-analytics-category="header"
              data-analytics-action="click"
              data-analytics-label="hypotheek"
            >
              Hypotheek
            </a>
            <a
              href="/zzp-calculator/"
              class="site-nav-link"
              aria-current={isCurrentPage("/zzp-calculator/") ? "page" : undefined}
              data-analytics="header-link"
              data-analytics-category="header"
              data-analytics-action="click"
              data-analytics-label="zzp"
            >
              ZZP
            </a>
            <a
              href="/toeslagen-calculator/"
              class="site-nav-link"
              aria-current={isCurrentPage("/toeslagen-calculator/") ? "page" : undefined}
              data-analytics="header-link"
              data-analytics-category="header"
              data-analytics-action="click"
              data-analytics-label="toeslagen"
            >
              Toeslagen
            </a>
          </div>
          <div class="site-nav-section">
            <a
              href="/over-ons/"
              class="site-nav-link"
              aria-current={isCurrentPage("/over-ons/") ? "page" : undefined}
              data-analytics="header-link"
              data-analytics-category="header"
              data-analytics-action="click"
              data-analytics-label="over-ons"
            >
              Over ons
            </a>
            <a
              href="/contact/"
              class="site-nav-link"
              aria-current={isCurrentPage("/contact/") ? "page" : undefined}
              data-analytics="header-link"
              data-analytics-category="header"
              data-analytics-action="click"
              data-analytics-label="contact"
            >
              Contact
            </a>
          </div>
        </nav>
      </div>
    </header>
    <main id="main-content">
      <div class={containerClass}>
        <slot />
      </div>
    </main>
    <footer>
      <div class="container footer-grid">
        <div class="footer-col">
          <h3 class="footer-title">Categorieën</h3>
          <div class="footer-links">
            {categoryList.map((cat) => (
              <a
                href={cat.href}
                aria-current={isCurrentPage(cat.href) ? "page" : undefined}
                data-analytics="footer-link"
                data-analytics-category="footer"
                data-analytics-action="click"
                data-analytics-label={cat.id}
              >
                {cat.label}
              </a>
            ))}
          </div>
        </div>
        <div class="footer-col">
          <h3 class="footer-title">Alle calculators</h3>
          <div class="footer-links">
            <a
              href="/bruto-netto-2026/"
              aria-current={isCurrentPage("/bruto-netto-2026/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="bruto-netto-2026"
            >
              Bruto netto 2026
            </a>
            <a
              href="/salaris-calculator/"
              aria-current={isCurrentPage("/salaris-calculator/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="salaris"
            >
              Salaris
            </a>
            <a
              href="/vakantiegeld-calculator/"
              aria-current={isCurrentPage("/vakantiegeld-calculator/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="vakantiegeld"
            >
              Vakantiegeld
            </a>
            <a
              href="/toeslagen-calculator/"
              aria-current={isCurrentPage("/toeslagen-calculator/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="toeslagen"
            >
              Toeslagen
            </a>
            <a
              href="/hypotheek-calculator/"
              aria-current={isCurrentPage("/hypotheek-calculator/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="hypotheek"
            >
              Hypotheek
            </a>
            <a
              href="/btw-calculator/"
              aria-current={isCurrentPage("/btw-calculator/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="btw"
            >
              BTW
            </a>
            <a
              href="/zzp-calculator/"
              aria-current={isCurrentPage("/zzp-calculator/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="zzp"
            >
              ZZP
            </a>
            <a
              href="/auto-importkosten-berekenen/"
              aria-current={isCurrentPage("/auto-importkosten-berekenen/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="auto-importkosten"
            >
              Auto importkosten
            </a>
          </div>
        </div>
        <div class="footer-col">
          <h3 class="footer-title">Calculatieloket</h3>
          <div class="footer-links">
            <a
              href="/privacy/"
              aria-current={isCurrentPage("/privacy/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="privacy"
            >
              Privacy
            </a>
            <a
              href="/cookies/"
              aria-current={isCurrentPage("/cookies/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="cookies"
            >
              Cookies
            </a>
            <a
              href="/disclaimer/"
              aria-current={isCurrentPage("/disclaimer/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="disclaimer"
            >
              Disclaimer
            </a>
            <a
              href="/over-ons/"
              aria-current={isCurrentPage("/over-ons/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="over-ons"
            >
              Over ons
            </a>
            <a
              href="/contact/"
              aria-current={isCurrentPage("/contact/") ? "page" : undefined}
              data-analytics="footer-link"
              data-analytics-category="footer"
              data-analytics-action="click"
              data-analytics-label="contact"
            >
              Contact
            </a>
          </div>
        </div>
      </div>
      <div class="container footer-bottom">
        <p>&copy; {new Date().getFullYear()} Calculatieloket.nl &mdash; Snelle, duidelijke online calculators</p>
      </div>
    </footer>
    <CookieConsent />

    <script>
      const toggle = document.getElementById("siteNavToggle") as HTMLButtonElement | null;
      const menu = document.getElementById("siteNavMenu") as HTMLElement | null;
      const dropdownToggle = document.getElementById("siteNavDropdownToggle") as HTMLButtonElement | null;
      const dropdownMenu = document.getElementById("siteNavDropdown") as HTMLElement | null;

      if (toggle && menu) {
        toggle.addEventListener("click", () => {
          const expanded = toggle.getAttribute("aria-expanded") === "true";
          toggle.setAttribute("aria-expanded", String(!expanded));
          toggle.setAttribute("aria-label", !expanded ? "Menu sluiten" : "Menu openen");
          menu.classList.toggle("is-open", !expanded);
        });

        menu.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            toggle.setAttribute("aria-expanded", "false");
            toggle.setAttribute("aria-label", "Menu openen");
            menu.classList.remove("is-open");
          });
        });
      }

      if (dropdownToggle && dropdownMenu) {
        dropdownToggle.addEventListener("click", () => {
          const expanded = dropdownToggle.getAttribute("aria-expanded") === "true";
          dropdownToggle.setAttribute("aria-expanded", String(!expanded));
          dropdownMenu.classList.toggle("is-open", !expanded);
        });

        document.addEventListener("click", (e) => {
          const target = e.target as Node;
          if (!dropdownToggle.contains(target) && !dropdownMenu.contains(target)) {
            dropdownToggle.setAttribute("aria-expanded", "false");
            dropdownMenu.classList.remove("is-open");
          }
        });
      }

      document.addEventListener("keydown", (e) => {
        if (e.key !== "Escape") return;
        if (toggle && menu && toggle.getAttribute("aria-expanded") === "true") {
          toggle.setAttribute("aria-expanded", "false");
          toggle.setAttribute("aria-label", "Menu openen");
          menu.classList.remove("is-open");
        }
        if (dropdownToggle && dropdownMenu && dropdownToggle.getAttribute("aria-expanded") === "true") {
          dropdownToggle.setAttribute("aria-expanded", "false");
          dropdownMenu.classList.remove("is-open");
        }
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  /* ===== HEADER NAVIGATION ===== */
  .site-header-inner {
    position: relative;
  }

  .site-nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
  }

  .site-nav-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .site-nav-burger,
  .site-nav-burger::before,
  .site-nav-burger::after {
    display: block;
    width: 20px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
  }

  .site-nav-burger {
    position: relative;
  }

  .site-nav-burger::before,
  .site-nav-burger::after {
    content: "";
    position: absolute;
    left: 0;
  }

  .site-nav-burger::before {
    top: -6px;
  }

  .site-nav-burger::after {
    top: 6px;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .site-nav-section {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .site-nav-link,
  .site-nav-dropdown-toggle {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.75rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .site-nav-link:hover,
  .site-nav-link:focus-visible,
  .site-nav-dropdown-toggle:hover,
  .site-nav-dropdown-toggle:focus-visible {
    background: var(--color-primary-light);
    color: var(--color-primary);
  }

  .site-nav-dropdown {
    position: relative;
  }

  .site-nav-dropdown-toggle::after {
    content: " ▼";
    font-size: 0.65rem;
    margin-left: 0.25rem;
  }

  .site-nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    min-width: 180px;
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
    z-index: 100;
  }

  .site-nav-dropdown.is-open .site-nav-dropdown-menu,
  .site-nav-dropdown:hover .site-nav-dropdown-menu,
  .site-nav-dropdown:focus-within .site-nav-dropdown-menu {
    display: flex;
  }

  .site-nav-dropdown-link {
    padding: 0.55rem 0.75rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  .site-nav-dropdown-link:hover,
  .site-nav-dropdown-link:focus-visible {
    background: var(--color-primary-light);
    color: var(--color-primary);
  }

  /* ===== FOOTER ===== */
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding: 2rem 1rem;
  }

  .footer-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-links a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .footer-bottom {
    text-align: center;
    padding: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .site-nav-toggle {
      display: flex;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      padding: 1rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      box-shadow: var(--shadow-lg);
      z-index: 100;
    }

    .site-nav.is-open {
      display: flex;
    }

    .site-nav-section {
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
    }

    .site-nav-dropdown-toggle {
      display: none;
    }

    .site-nav-dropdown-menu {
      display: flex;
      position: static;
      box-shadow: none;
      border: none;
      padding: 0;
      gap: 0.25rem;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 1.5rem 1rem;
    }
  }
</style>
